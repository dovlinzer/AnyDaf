  "macro_segments": [
    {
      "title": "The Debate of Rav and Shmuel: Whether Admission to a Knas Exempts from Liability When Witnesses Later Testify",
      "display_title": "Rav vs. Shmuel: Modeh B'…",
      "timestamp": "00:08",
      "micro_segments": [
        {
          "title": "Introduction to the Dispute: Does Admission Exempt or Just Not Obligate?",
          "display_title": "Admission vs. Obligation",
          "timestamp": "00:08"
        },
        {
          "title": "The Distinction Between Knas and Mammon: Why Knas Requires Beis Din Imposition",
          "display_title": "Knas vs. Mammon",
          "timestamp": "00:23"
        },
        {
          "title": "Rabbah bar Ilai's Explanation: Proving Rav's Position from Two Pessukim",
          "display_title": "Rabbah bar Ilai on Rav",
          "timestamp": "01:45"
        },
        {
          "title": "Shmuel's Response: The Two Pesukim Teach About Different Cases, Not Exemption",
          "display_title": "Shmuel's Counter",
          "timestamp": "03:31"
        }
      ]
    },
    {
      "title": "The Baraitah of One Who Admits Before Witnesses Arrive: Rav's Proof and Shmuel's Challenge",
      "display_title": "Baraitah: Admitting Befo…",
      "timestamp": "04:18",
      "micro_segments": [
        {
          "title": "The Case: Admitting to Theft Without Shechita U'Mechira Before Witnesses Testify to Both",
          "display_title": "Case Setup",
          "timestamp": "04:18"
        },
        {
          "title": "Rav's Proof: The Exemption from Kfel Proves Admission Exempts from All Obligations",
          "display_title": "Rav's Proof",
          "timestamp": "04:55"
        },
        {
          "title": "Shmuel's Defense: The Witnesses Never Actually Testified Because of the Admission",
          "display_title": "Shmuel's Defense",
          "timestamp": "05:47"
        },
        {
          "title": "The Baraitah's Second Opinion: Rabbi Elazar b'Rabbi Shimon Says Witnesses Should Testify",
          "display_title": "R. Elazar's Opinion",
          "timestamp": "06:40"
        },
        {
          "title": "Analysis: Tana Kama vs. Rabbi Elazar b'Rabbi Shimon on Whether Admission Exempts",
          "display_title": "Tana Kama vs. R. Elazar",
          "timestamp": "07:02"
        }
      ]
    },
    {
      "title": "Rav's Refinement: Distinguishing Sincere Admission from Fear-Motivated Admission",
      "display_title": "Sincere vs. Fear-Motivat…",
      "timestamp": "08:28",
      "micro_segments": [
        {
          "title": "Rav's Position: Admission Only Exempts When Genuinely Motivated, Not to Preempt Witnesses",
          "display_title": "Rav's Refinement",
          "timestamp": "08:28"
        },
        {
          "title": "The Distinction: Real Hoda'ah from One's Own Initiative vs. Admission Out of Fear of Witnesses",
          "display_title": "Demodei Me'Anfsheih",
          "timestamp": "09:02"
        },
        {
          "title": "Even Rabbi Elazar Agrees: In Normal Cases of Self-Motivated Admission, Exemption Applies",
          "display_title": "R. Elazar Concedes",
          "timestamp": "10:18"
        }
      ]
    },
    {
      "title": "Rav Hamnuna's Principle: Exemption Requires Obligating Oneself in at Least the Principal",
      "display_title": "Rav Hamnuna: Chiyuv Atzm…",
      "timestamp": "11:06",
      "micro_segments": [
        {
          "title": "The Condition for Exemption: Must Admit to Something That Obligates You in Mammon (Principal)",
          "display_title": "Obligation in Principal…",
          "timestamp": "11:06"
        },
        {
          "title": "The Logic: Incentive to Admit Requires Loss; Pure Exemption Has No Incentive Value",
          "display_title": "Incentive Theory",
          "timestamp": "11:46"
        },
        {
          "title": "Contrasting Cases: Admitting to Theft vs. Admitting to Shechita U'Mechira Alone",
          "display_title": "Theft vs. Shechita U'Mec…",
          "timestamp": "11:50"
        }
      ]
    },
    {
      "title": "Rava's Challenge to Rav Hamnuna: The Case of Rabban Gamliel and the Servant",
      "display_title": "Rava Challenges Rav Hamn…",
      "timestamp": "14:18",
      "micro_segments": [
        {
          "title": "Rava's Reference: Rabban Gamliel's Admission About Blinding His Servant Tavi",
          "display_title": "Rabban Gamliel & Tavi",
          "timestamp": "14:18"
        },
        {
          "title": "The Problem: In That Case Admission Is Pure Exemption (No Principal Obligation), Yet Exempts",
          "display_title": "Pure Exemption Problem",
          "timestamp": "14:39"
        },
        {
          "title": "Rava's Conclusion: Rav's Position Doesn't Require Chiyuv B'Keren for Exemption",
          "display_title": "Rava's Position",
          "timestamp": "15:02"
        }
      ]
    },
    {
      "title": "Rabbi Yochanan's Compromise: Exemption Distinguished by Presence or Absence of Principal Obligation",
      "display_title": "R. Yochanan's Middle Pos…",
      "timestamp": "16:46",
      "micro_segments": [
        {
          "title": "Admission with Principal Obligation: Exemption Applies (Ganavti Case)",
          "display_title": "Admission + Principal",
          "timestamp": "16:46"
        },
        {
          "title": "Admission Without Principal Obligation: No Exemption; Only Fails to Obligate (Tavachti U'Macharti Case)",
          "display_title": "Admission Without Princi…",
          "timestamp": "16:58"
        },
        {
          "title": "Rabbi Yochanan as Live Halakha: A Live Principle Even if Not Rav's Position",
          "display_title": "R. Yochanan's Authority",
          "timestamp": "17:36"
        }
      ]
    },
    {
      "title": "Rav Ashi's Textual Proof: The Mishnah and Baraitah Encode the Principal-Obligation Distinction",
      "display_title": "Rav Ashi's Textual Proof",
      "timestamp": "18:56",
      "micro_segments": [
        {
          "title": "Why the Mishnah Specifies Witnesses for Theft but Admission for Shechita U'Mechira",
          "display_title": "Mishnah's Specificity",
          "timestamp": "18:56"
        },
        {
          "title": "The Comparison: Admission Paralleled to One Witness Only When Admitting to Shechita U'Mechira",
          "display_title": "Admission = One Witness",
          "timestamp": "19:50"
        },
        {
          "title": "The Logic: When Not Obligating Oneself in Principal, Admission Is Like One Witness (Not Exempting)",
          "display_title": "No Principal = No Exempt…",
          "timestamp": "20:16"
        },
        {
          "title": "Contrast: If Admitting to Theft (Chiyuv B'Keren), Admission Would NOT Be Like One Witness but Would Exempt",
          "display_title": "With Principal = Exempts",
          "timestamp": "22:49"
        }
      ]
    }
  ],
