  "macro_segments": [
    {
      "title": "Daughter-in-law and Mother-in-law: Abaye and Rava on Analogy and Context",
      "display_title": "Daughter-in-law debate",
      "timestamp": "00:38",
      "micro_segments": [
        {
          "title": "Introduction: Why isn't step-daughter-in-law forbidden by analogy?",
          "display_title": "Step-daughter-in-law",
          "timestamp": "00:38"
        },
        {
          "title": "Abaye's approach: Textual limitation—'your son's wife' is explicit",
          "display_title": "Abaye: textual limit",
          "timestamp": "01:15"
        },
        {
          "title": "Rava's approach: Analogy fails regardless of context-inclusion rule",
          "display_title": "Rava: analogy fails",
          "timestamp": "01:31"
        },
        {
          "title": "Rava's first objection: Weightier vs. lighter penalties on each side",
          "display_title": "Penalty weight mismatch",
          "timestamp": "02:36"
        },
        {
          "title": "Rava's second objection: Inconsistency between daughter and daughter-in-law",
          "display_title": "Inconsistency objection",
          "timestamp": "03:17"
        },
        {
          "title": "If you apply context, all her family becomes sreifa uniformly—but this breaks the distinction",
          "display_title": "Context application prob…",
          "timestamp": "04:14"
        }
      ]
    },
    {
      "title": "Forbidden Daughter Outside of Marriage: Sources and Proofs",
      "display_title": "Daughter from rape",
      "timestamp": "08:29",
      "micro_segments": [
        {
          "title": "Abaye's kal vachomer: If granddaughter, then certainly daughter",
          "display_title": "Abaye kal vachomer",
          "timestamp": "08:29"
        },
        {
          "title": "Objection: Punishments cannot derive from kal vachomer alone",
          "display_title": "No punishment via kal",
          "timestamp": "08:47"
        },
        {
          "title": "Resolution: Giluy milta—implicit, not a formal derivation",
          "display_title": "Giluy milta concept",
          "timestamp": "08:59"
        },
        {
          "title": "Rava's alternative: Gezeirah shavah links daughter to granddaughter",
          "display_title": "Rava gezeirah shavah",
          "timestamp": "09:35"
        },
        {
          "title": "Baraita: Explicit source from 'bat ish kohen'—both prohibition and sreifa",
          "display_title": "Bat ish kohen source",
          "timestamp": "10:31"
        }
      ]
    },
    {
      "title": "Bat Kohen vs. His Daughter: Why Split Punishment or Unified Punishment?",
      "display_title": "Bat kohen analogy",
      "timestamp": "11:07",
      "micro_segments": [
        {
          "title": "Question: Why not split punishment like bat kohen (she burns, he doesn't)?",
          "display_title": "Split punishment Q",
          "timestamp": "11:07"
        },
        {
          "title": "Abaye: The split only applies when she brings shame to her father",
          "display_title": "Abaye: shame context",
          "timestamp": "11:07"
        },
        {
          "title": "When father violates her, no split—both get sreifa",
          "display_title": "No split if father",
          "timestamp": "11:10"
        },
        {
          "title": "Rava: We can remove bat kohen status and still apply death—but here, what law applies?",
          "display_title": "Rava: status removal",
          "timestamp": "11:17"
        }
      ]
    },
    {
      "title": "Bat Kohen vs. His Daughter: Why Split Punishment or Unified Punishment? (continued)",
      "display_title": "Bat kohen analogy…",
      "timestamp": "11:34",
      "micro_segments": [
        {
          "title": "If she's not his daughter, she'd be a single woman—but then he wouldn't be punished",
          "display_title": "Impossible outcome",
          "timestamp": "11:34"
        },
        {
          "title": "Conclusion: Both must get sreifa; no alternative category works",
          "display_title": "Both get sreifa",
          "timestamp": "11:34"
        }
      ]
    },
    {
      "title": "Source of Prohibition: Where is Daughter's Forbidden Status Stated?",
      "display_title": "Prohibition source",
      "timestamp": "11:34",
      "micro_segments": [
        {
          "title": "Abaye and Rava derive prohibition implicitly from granddaughter and gezeirah shavah",
          "display_title": "Implicit derivation",
          "timestamp": "11:34"
        },
        {
          "title": "Baraita of Rabbi Avin: Source is 'al techalel et bitcha l'haznotah'—desecrating daughter",
          "display_title": "Al techalel source",
          "timestamp": "11:34"
        },
        {
          "title": "Ulla explains: The verse prohibits desecrating daughter in forbidden sexual intercourse",
          "display_title": "Ulla interpretation",
          "timestamp": "11:34"
        }
      ]
    },
    {
      "title": "Multiple Meanings of 'Al Techalel': Marrying Off vs. Sexual Intercourse",
      "display_title": "Al techalel meanings",
      "timestamp": "11:34",
      "micro_segments": [
        {
          "title": "Rabbi Yaakov challenges: Doesn't the verse teach father shouldn't marry daughter to non-kohanim?",
          "display_title": "Rabbi Yaakov challenge",
          "timestamp": "11:34"
        },
        {
          "title": "The word 'l'haznotah' narrows it—must involve forbidden sexual context",
          "display_title": "L'haznotah limits",
          "timestamp": "11:34"
        }
      ]
    },
    {
      "title": "Multiple Meanings of 'Al Techalel': Marrying Off vs. Sexual Intercourse (continued)",
      "display_title": "Al techalel meanings…",
      "timestamp": "11:53",
      "micro_segments": [
        {
          "title": "Double lamed in 'techalel' suggests two prohibitions: marriage-like transfer and actual sex",
          "display_title": "Double lamed analysis",
          "timestamp": "11:53"
        }
      ]
    },
    {
      "title": "Cases of 'Al Techalel': Elderly Husband and Delaying Adult Daughter",
      "display_title": "Techalel cases",
