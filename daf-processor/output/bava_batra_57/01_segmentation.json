{
  "masechta": "Bava Batra",
  "daf": 57,
  "amud": "a",
  "macro_segments": [
    {
      "title": "Three Years of Chazakah Testimony: Independent Witness Groups and the Brothers Problem",
      "display_title": "Three Years & Brothers",
      "timestamp": "00:00",
      "micro_segments": [
        {
          "title": "Introduction to Daf 57: Finishing the Previous Mishna on Davar ve-Lo Chatzi Davar and Three Separate Witness Groups",
          "display_title": "Three Witness Groups",
          "timestamp": "00:00"
        },
        {
          "title": "The Case of Reuven and Mordechai: One Testifies to His Own Signature, Two Testify to the Other's",
          "display_title": "Signature Testimony",
          "timestamp": "01:19"
        },
        {
          "title": "Ravina's Position: This is Our Mishna—Brothers Can Testify Because Each Testimony Stands Independently",
          "display_title": "Ravina's Position",
          "timestamp": "03:02"
        },
        {
          "title": "Rav Ashi's Objection: Three-Quarters of the Money is Extracted by Reuven and His Brothers, Which is Invalid",
          "display_title": "Rav Ashi Rejects",
          "timestamp": "04:48"
        },
        {
          "title": "Tosafot's Solution: Reuven Can Avoid Being a Double Witness by Making His Signature Available to Others",
          "display_title": "Tosafot's Solution",
          "timestamp": "07:45"
        }
      ]
    },
    {
      "title": "Mishna on What Types of Possession Create Chazakah: Improvements vs. Temporary Use",
      "display_title": "Possession & Chazakah",
      "timestamp": "09:19",
      "micro_segments": [
        {
          "title": "Introductory Framework: Rashbam's Reading Against Rabbeinu Chananel—This Mishna Concerns the Three-Year Chazakah of Evidence, Not Acquisition of Hefker",
          "display_title": "Rashbam's Reading",
          "timestamp": "09:19"
        },
        {
          "title": "First List (No Chazakah): Animals, Ovens, Millstones, and Manure—Temporary Uses Without Permanent Change",
          "display_title": "Temporary Uses",
          "timestamp": "10:30"
        },
        {
          "title": "Second List (Valid Chazakah): Building Fences, Creating Structures, Bringing Animals Into the House—Permanent Improvements",
          "display_title": "Permanent Changes",
          "timestamp": "13:02"
        }
      ]
    },
    {
      "title": "Gemara's Explanation: The Difference Between Chazakah of Possession and Chazakah of Three Years",
      "display_title": "Two Types Chazakah",
      "timestamp": "15:31",
      "micro_segments": [
        {
          "title": "Ula's Position: Anything That Works for Hefker (Improving Property) Should Work for Three-Year Chazakah",
          "display_title": "Ula's Position",
          "timestamp": "15:31"
        },
        {
          "title": "Rav Sheshes's Objection: Nir (Plowing Without Planting) Works for Hefker but Not for Three Years; Harvesting Produce Works for Three Years but Not for Hefker",
          "display_title": "Rav Sheshes Refutes",
          "timestamp": "18:29"
        },
        {
          "title": "Rav Nachman in the Name of Rabba bar Avuha: We Are Discussing a Shared Courtyard (Chatzer Shutafim), Not a Private Yard",
          "display_title": "Chatzer Shutafim",
          "timestamp": "20:22"
        },
        {
          "title": "The Principle: Partners Are Not Mekpid (Do Not Object) to Small Temporary Uses, But Are Mekpid to Structural Changes",
          "display_title": "Mekpid Principle",
          "timestamp": "21:32"
        }
      ]
    },
    {
      "title": "The Status of Shared Courtyard Use and the Neder Discussion",
      "display_title": "Shutafim & Neder",
      "timestamp": "23:17",
      "micro_segments": [
        {
          "title": "Proof From Neder: Partners Who Have Vowed to Forbid Each Other from Benefit Cannot Use a Joint Courtyard",
          "display_title": "Neder Proof",
          "timestamp": "23:17"
        },
        {
          "title": "Rav Pappa's Resolution: In Monetary Matters We Are Lenient (Assume No Objection to Small Use); In Neder We Are Strict (Assume Possible Objection)",
          "display_title": "Leniency Argument",
          "timestamp": "27:28"
        },
        {
          "title": "Ravina's Alternative: Partners Are Never Mekpid on Small Uses; Neder Is Ruled According to Rabbi Eliezer Even on Benefits People Don't Object To",
          "display_title": "Ravina Alternative",
          "timestamp": "31:42"
        }
      ]
    },
    {
      "title": "Partners' Rights to Prevent Use and Exception for Laundry; Digression on Modest Dress and Comportment",
      "display_title": "Laundry Exception",
      "timestamp": "34:16",
      "micro_segments": [
        {
          "title": "Rav Yochanan: Partners Can Prevent Each Other From Most Uses of the Shared Courtyard, Except for Laundry",
          "display_title": "Rav Yochanan",
          "timestamp": "34:16"
        },
        {
          "title": "Reason: Women Performing Laundry at the River Requires Exposure That Violates Tzniut; The Courtyard Provides Semi-Privacy",
          "display_title": "Tzniut Reason",
          "timestamp": "34:16"
        },
        {
          "title": "Gemara's Analysis: Praising Men Who Avert Their Eyes While Passing Women Doing Laundry—Only Praiseworthy If No Alternative Route Exists",
          "display_title": "Averting Eyes",
          "timestamp": "37:27"
        },
        {
          "title": "Rabi Yochanan Questions Rabi Bana'ah: Standards of Dress and Comportment for Talmidei Chachamim",
          "display_title": "Dress Standards",
          "timestamp": "40:58"
        }
      ]
    },
    {
      "title": "Detailed Descriptions of Proper Garments, Tables, and Beds for Scholars vs. Common People",
      "display_title": "Garments & Furniture",
      "timestamp": "41:12",
      "micro_segments": [
        {
          "title": "Tunic of a Talmid Chacham: Must Completely Cover the Body; Outer Garment (Talit) Must Cover Almost All the Tunic",
          "display_title": "Tunic & Talit",
          "timestamp": "41:12"
        },
        {
          "title": "Table of a Talmid Chacham: Two-Thirds Covered With Cloth, One-Third Exposed for Dishes; Ring Placement Depends on Whether Baby or Attendant Present",
          "display_title": "Scholar's Table",
          "timestamp": "42:26"
        },
        {
          "title": "Table of an Am Ha'aretz: Cloth and Food in the Middle, Dishes Around the Edges—Like a Disorganized Campfire",
          "display_title": "Ignorant Person's Table",
          "timestamp": "46:58"
        },
        {
          "title": "Bed of Talmidei Chachamim: Only Seasonal Shoes Stored Underneath; Bed of Am Ha'aretz: Chaotic Accumulation of Belongings",
          "display_title": "Beds & Storage",
          "timestamp": "47:54"
        }
      ]
    }
  ],
