{
  "masechta": "Bekhorot",
  "daf": 24,
  "amud": "a",
  "macro_segments": [
    {
      "title": "Rabban Shimon ben Gamliel's Assumption of Nursing Animals and Mother-Child Relationships",
      "display_title": "Nursing & Chazaka",
      "timestamp": "00:46",
      "micro_segments": [
        {
          "title": "Introduction to Rabban Shimon ben Gamliel's Position on Lactation and Natural Assumptions",
          "display_title": "Lactation Proof",
          "timestamp": "00:46"
        },
        {
          "title": "Two Key Questions: Does Lactation Prove the Mother Has Given Birth, and Does It Prove the Nursing Animal Is the Mother's Child?",
          "display_title": "Two Questions",
          "timestamp": "01:29"
        },
        {
          "title": "First Mishnaic Case: Purchasing a Nursing Animal from a Non-Jew—Proving the Mother Has Given Birth",
          "display_title": "Purchase Case",
          "timestamp": "03:33"
        },
        {
          "title": "Second Mishnaic Case: Multiple Cows and Calves in a Barn—Assuming Which Calves Belong to Which Mothers",
          "display_title": "Barn Case",
          "timestamp": "06:02"
        },
        {
          "title": "Gemara's Analysis: Comparing the Two Cases and Determining When We Can Assume a Mother-Child Relationship",
          "display_title": "Case Comparison",
          "timestamp": "09:27"
        },
        {
          "title": "Unresolved Question: Can We Definitively Assume a Nursing Animal Is the Mother's Child Without Knowing the Mother's Own Offspring Is Present?",
          "display_title": "Unresolved Doubt",
          "timestamp": "10:59"
        }
      ]
    },
    {
      "title": "The Pig Nursing from a Sheep: Determining Species, Maternity, and Permissibility of Consumption",
      "display_title": "Pig & Sheep",
      "timestamp": "12:03",
      "micro_segments": [
        {
          "title": "The Case of a Pig Nursing from a Sheep: Exemption from Bechor and Prohibition on Eating",
          "display_title": "Pig Case",
          "timestamp": "12:03"
        },
        {
          "title": "Gemara's Initial Confusion: Ruling Like Rabban Shimon ben Gamliel for Exemption but Like the Rabbis for the Prohibition",
          "display_title": "Mixed Rulings",
          "timestamp": "14:36"
        },
        {
          "title": "Resolution: The Unresolved Question About Mother-Child Assumption Applies to All Animals, Not Just Different Species",
          "display_title": "Resolution",
          "timestamp": "17:24"
        },
        {
          "title": "Why the Pig Case Rather Than a Sheep: Demonstrating That Even Cross-Species Nursing Leaves Maternity Uncertain",
          "display_title": "Why Pig?",
          "timestamp": "21:00"
        },
        {
          "title": "Specific Questions About Bechor and Consumption: How the Pig Case Tests Rabban Shimon ben Gamliel's Limits",
          "display_title": "Testing Limits",
          "timestamp": "24:40"
        },
        {
          "title": "Unresolved Question (Teiku): Whether Cross-Species Nursing Proves Maternity Even According to Rabban Shimon ben Gamliel",
          "display_title": "Teiku",
          "timestamp": "29:05"
        }
      ]
    },
    {
      "title": "The Firstborn Offering: Removing Wool to Enable Slaughter Without Violating the Prohibition of Shearing",
      "display_title": "Shearing Issue",
      "timestamp": "31:45",
      "micro_segments": [
        {
          "title": "Rabbi Yossi ben Hamishulam's Ruling: Clearing Space with a Cleaver to Slaughter a Firstborn Without Shearing Violations",
          "display_title": "Rabbi Yossi",
          "timestamp": "31:45"
        },
        {
          "title": "Gemara's Interpretation: Using Hands to Remove Hair Rather Than a Tool to Avoid the Prohibition of Shearing",
          "display_title": "Hand vs. Tool",
          "timestamp": "32:51"
        },
        {
          "title": "Rav's Ruling and the Yom Tov Question: Does the Same Halacha Apply When Slaughtering on Yom Tov?",
          "display_title": "Yom Tov Q",
          "timestamp": "37:27"
        }
      ]
    },
    {
      "title": "The Debate on Unintended Actions: Can Removing Hair Be Permitted If It Happens Unintentionally?",
      "display_title": "Intent & Unintended",
      "timestamp": "42:06",
      "micro_segments": [
        {
          "title": "Question: Does Rav Really Permit Unintended Consequences, Given His Position on the Wine Barrel Case (Masochrayya Denazaita)?",
          "display_title": "Wine Barrel",
          "timestamp": "42:06"
        },
        {
          "title": "The Principle of Psik Reisha: When a Definite Consequence Occurs, Unintended Action Still Constitutes a Violation",
          "display_title": "Psik Reisha",
          "timestamp": "47:14"
        },
        {
          "title": "Reconciliation: Rav Holds Like Rabbi Yehuda (Unintended Is Prohibited), But the Mishnah Must Be Read as Describing an Unintended Action",
          "display_title": "Rav & Yehuda",
          "timestamp": "48:27"
        }
      ]
    },
    {
      "title": "Tolesh vs. Gozez: Distinguishing Between Pulling Hair and Shearing as Fundamentally Different Acts",
      "display_title": "Acts Defined",
      "timestamp": "50:00",
      "micro_segments": [
        {
          "title": "Asserting That Pulling Hair (Tolesh) Is Not the Same Act as Shearing (Gozez), Making It Permissible Even Intentionally for Bechor",
          "display_title": "Different Acts",
          "timestamp": "50:00"
        },
        {
          "title": "Application to Yom Tov: Even Though Tolesh Is Permitted for Bechor, Yom Tov Requires Doing It in an Unusual Way (Ke'le'achar Yad)",
          "display_title": "Yom Tov Method",
          "timestamp": "50:40"
        },
        {
          "title": "Final Resolution: Using Hands for Hair Removal Is Permitted on Yom Tov Because It Is Not the Normal Method and Is Allowed for the Purpose of Slaughter",
          "display_title": "Final Allow",
          "timestamp": "51:17"
        },
        {
          "title": "Tosafot's Alternative Approach: Suggesting All Cases Should Be Read as Unintended Rather Than as Different Acts",
          "display_title": "Tosafot View",
          "timestamp": "53:01"
        }
      ]
    }
  ],
