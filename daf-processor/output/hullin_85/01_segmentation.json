      "micro_segments": [
        {
          "title": "Mishnah: Cases Where Shechita is Invalid—Treifa, Avodah Zarah, Slaughtering Outside the Mikdash, Animals to Be Stoned",
          "display_title": "Invalid Shechita Cases",
          "timestamp": "29:46"
        },
        {
          "title": "Dispute: Rabbi Meir Requires Covering Blood Even for Invalid Shechita; Sages Exempt",
          "display_title": "Rabbi Meir vs. Sages",
