{
  "masechta": "Menachot",
  "daf": 14,
  "amud": "a-b",
  "macro_segments": [
    {
      "title": "The Debate of Rabbi Yosi and the Rabbis: Does Pigul Apply to the Whole Object or Only to Specific Parts?",
      "display_title": "Rabbi Yosi vs. Chachamim",
      "timestamp": "00:07",
      "micro_segments": [
        {
          "title": "Introduction to the Pigul Discussion and the Core Question of Object Definition",
          "display_title": "Pigul Overview",
          "timestamp": "00:07"
        },
        {
          "title": "The Mishna on Two Lambs and Two Loaves of Shavuot: Does Pigul on One Loaf Affect the Other?",
          "display_title": "Shavuot Lambs & Loaves",
          "timestamp": "00:43"
        },
        {
          "title": "The Gemara's Interpretation: Rabbi Yosi's Position as Strictly Limiting Pigul to the Specific Object of Intent",
          "display_title": "Rabbi Yosi's Narrow View",
          "timestamp": "01:44"
        },
        {
          "title": "Proof from Baraita: If You Think About Half a Kezayit From Both Loaves, Both Become Pigul",
          "display_title": "Half-Kezayit Proof",
          "timestamp": "03:58"
        },
        {
          "title": "Is the Baraita About Rabbi Yosi or Rabbi (Rebbi)? Distinguishing Between Distinct Objects and Single Units",
          "display_title": "Attribution Question",
          "timestamp": "06:07"
        },
        {
          "title": "The Principle of Chatzi Matir (Half a Permitted Act): Each Lamb Accomplishes Only Half the Task",
          "display_title": "Chatzi Matir Concept",
          "timestamp": "06:43"
        },
        {
          "title": "Clarification: The Baraita Requires the Same Thought During Both Lambs, Not Two Separate Thoughts",
          "display_title": "Same Thought Requirement",
          "timestamp": "08:06"
        },
        {
          "title": "Rashi's Explanation: Why Pigul Does Not Apply to Lebona at the Kemitza Stage",
          "display_title": "Rashi on Lebona",
          "timestamp": "15:40"
        }
      ]
    },
    {
      "title": "Proofs That Rabbi Yosi Agrees Pigul Applies to the Whole Unit When It Is One Object",
      "display_title": "Proofs for Whole Unit",
      "timestamp": "27:39",
      "micro_segments": [
        {
          "title": "First Proof from Rav Ashi: The Inner Chatat—Pigul Applies When Thought and Act Are Both Outside or Both Inside the Heichal",
          "display_title": "Inner Chatat Proof",
          "timestamp": "27:39"
        },
        {
          "title": "The Mechaber's Question: What Becomes Pigul When You Think About Spilling the Blood Tomorrow?",
          "display_title": "Blood Spilling Problem",
          "timestamp": "33:24"
        },
        {
          "title": "Resolution: The Meat Becomes Pigul Even Though the Thought Was About the Blood",
          "display_title": "Meat Becomes Pigul",
          "timestamp": "36:30"
        },
        {
          "title": "Second Proof from Ravina: Burning the Kometz Tomorrow Makes the Shirayim Pigul",
          "display_title": "Kometz Proof",
          "timestamp": "40:16"
        },
        {
          "title": "Conclusion: Rabbi Yosi Agrees the Pigul Status Applies to the Whole Unit; Disagreement Is Only About Unit Definition",
          "display_title": "Unit Definition",
          "timestamp": "42:32"
        }
      ]
    },
    {
      "title": "How the Torah Treats the Two Loaves as One Unit and Two Units Simultaneously",
      "display_title": "One and Two Units",
      "timestamp": "43:18",
      "micro_segments": [
        {
          "title": "The Torah's Dual Designation: 'Lechem' (Singular) and 'Shtayim' (Two) for the Two Loaves of Shavuot",
          "display_title": "Torah's Dual Language",
          "timestamp": "43:18"
        },
        {
          "title": "One Unit: They Prevent One Another From Being Valid (Guf Echad De'Mekabli Ahadadi)",
          "display_title": "Interdependence",
          "timestamp": "44:13"
        },
        {
          "title": "Two Units: They Are Made Separately (Each Dough Prepared Independently)",
          "display_title": "Separate Creation",
          "timestamp": "44:33"
        },
        {
          "title": "Rabbi Yosi's Rule: If You Combine Them Conceptually (by Thinking of Them Together), They Become One Unit for Pigul",
          "display_title": "Conceptual Combination",
          "timestamp": "45:33"
        },
        {
          "title": "Extension to Other Breads: Lachmei Toda and Mincha Ma'aseh Tanur Follow the Same Logic",
          "display_title": "Generalized Principle",
          "timestamp": "47:32"
        }
      ]
    },
    {
      "title": "Combining Thoughts Across Multiple Avodot: Do Two Half-Kezayit Thoughts Combine?",
      "display_title": "Combining Avodot",
      "timestamp": "49:23",
      "micro_segments": [
        {
          "title": "Baraita: Half a Kezayit During Shechita and Half During Zrika Both Create Pigul",
          "display_title": "Shechita & Zrika",
          "timestamp": "49:23"
        },
        {
          "title": "Question: Can Any Avodot Combine or Only Those That Are Both Matirin?",
          "display_title": "Which Avodot Combine",
          "timestamp": "51:14"
        },
        {
          "title": "First Opinion: Only Shechita and Zrika Combine Because Both Are Matirin",
          "display_title": "Matirin Opinion",
          "timestamp": "51:22"
        },
        {
          "title": "Second Opinion: Even Distant Avodot (Shechita and Zrika) Combine, So Closer Ones (Kabala and Holecha) Certainly Do",
          "display_title": "Distant Avodot View",
          "timestamp": "51:58"
        },
        {
          "title": "Contradiction: Levi Teaches That the Four Avodot Do Not Combine at All",
          "display_title": "Levi's Position",
          "timestamp": "52:54"
        },
        {
          "title": "Resolution: The Disagreement Is Between Rabbi and the Rabbis Regarding Chatzi Matir",
          "display_title": "Rabbi vs. Rabbis",
          "timestamp": "53:12"
        },
        {
          "title": "Clarification: Rabbi's Position on Half-Kezayit Thoughts During Two Separate Complete Avodot",
          "display_title": "Rabbi's View Clarified",
          "timestamp": "54:04"
        }
      ]
    }
  ],
