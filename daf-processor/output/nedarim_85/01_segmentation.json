      "micro_segments": [
        {
          "title": "Introduction to the Case: Woman Forbids Benefit to Father and Brother",
          "display_title": "Benefit Forbidden",
          "timestamp": "00:00"
        },
        {
          "title": "The Tanna Kamma's Position: No Annulment Required Because Neder Does Not Affect Husband's Rights",
          "display_title": "Tanna Kamma",
          "timestamp": "00:45"
        },
        {
          "title": "Rabbi Akiva's Position: Annulment Required Due to Wife's Potential Extra Production",
          "display_title": "Rabbi Akiva",
          "timestamp": "01:41"
        },
        {
          "title": "Rabbi Yochanan ben Nuri's Position: Annulment Required Due to Concern About Post-Divorce Effect",
          "display_title": "Rabbi Yochanan",
          "timestamp": "02:35"
        }
      ]
    },
    {
      "title": "Shmuel's Ruling and the Gemara's Question: How Can a Neder Affect Things Not Yet Owned?",
      "display_title": "Shmuel & Ownership",
      "timestamp": "04:56",
      "micro_segments": [
        {
          "title": "Shmuel Rules According to Rabbi Yochanan ben Nuri and Comparison with Hekdesh",
          "display_title": "Shmuel's Ruling",
          "timestamp": "04:56"
        },
        {
          "title": "Challenge: A Man Sanctifying Wife's Labor as Hekdesh When She Has Nothing to Produce",
          "display_title": "Hekdesh Challenge",
          "timestamp": "06:04"
        },
        {
          "title": "Rav Yosef's Solution: Konamos (Vows) Are Different from Hekdesh",
          "display_title": "Konamos Different",
          "timestamp": "12:48"
        }
      ]
    },
    {
      "title": "The Hands as Physical Entity: Distinguishing What Actually Exists from What Does Not Yet Exist",
      "display_title": "Hands as Entity",
      "timestamp": "14:34",
      "micro_segments": [
        {
          "title": "Abaye's Challenge: Konamos Cannot Make Things Forbidden to Others If Not Yet Owned",
          "display_title": "Abaye Challenge",
          "timestamp": "14:34"
        },
        {
          "title": "The Hands Are Physical: Sanctifying the Hands Rather Than Their Products",
          "display_title": "Physical Hands",
          "timestamp": "16:17"
        }
      ]
    },
    {
      "title": "Multiple Analogies Exploring When One Can Make Something Forbidden or Sanctify Future Acquisition",
      "display_title": "Analogies",
      "timestamp": "20:55",
      "micro_segments": [
        {
          "title": "Rabbi Ila's Analogy: Field Being Sold and Later Redeemed Can Be Pre-Sanctified",
          "display_title": "Field Analogy",
          "timestamp": "20:55"
        },
        {
          "title": "Rabbi Yirmiyah's Challenge: Woman Cannot Control Her Hands Like One Controls a Field",
          "display_title": "Yirmiyah Challenge",
          "timestamp": "22:34"
        },
        {
          "title": "Rav Pappa's Analogy: Collateral Field Better Parallels Wife's Hands Situation",
          "display_title": "Collateral Analogy",
          "timestamp": "23:36"
        },
        {
          "title": "Rav Sheshet's Objection: Difference Between Redeeming a Field and Divorcing (One Is in One's Control)",
          "display_title": "Control Objection",
          "timestamp": "26:27"
        },
        {
          "title": "Rav Ashi's Challenge: Woman Has No Fixed End-Point Like Loan Redemption",
          "display_title": "No End-Point",
          "timestamp": "28:03"
        }
      ]
    },
    {
      "title": "The Doctrine of Kedushat Haguf: How Neder (Like Korban) Transforms Identity Rather Than Just Transferring Ownership",
      "display_title": "Kedushat Haguf",
      "timestamp": "28:37",
      "micro_segments": [
        {
          "title": "Rav Ashi's Resolution: Konamos Works Like Kedushat Haguf (Identity Transformation), Not Like Hekdesh (Ownership Transfer)",
          "display_title": "Identity Transform",
          "timestamp": "28:37"
        },
        {
          "title": "Application to Slaves: Freeing a Slave Overrides Liens Because It Changes Status, Not Ownership",
          "display_title": "Slave Example",
          "timestamp": "31:53"
        },
        {
          "title": "Application to Hekdesh and Chametz: How Sanctification and Prohibition Transform Objects Independently of Liens",
          "display_title": "Hekdesh Chametz",
          "timestamp": "33:21"
        }
      ]
    },
    {
      "title": "Conclusion and Remaining Question: Does the Neder Take Effect Immediately or Only Upon Divorce?",
      "display_title": "When Does It Work?",
