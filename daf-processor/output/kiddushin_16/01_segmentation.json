        {
          "title": "The comparison between marriage acquisition (Kiddushin) and slave acquisition: who writes the Shtar",
          "display_title": "Marriage vs Slave",
          "timestamp": "01:40"
        },
        {
          "title": "Two models of Shtar: the master writes (like Kiddushin) versus the father writes (like sale of property)",
          "display_title": "Two Shtar Models",
