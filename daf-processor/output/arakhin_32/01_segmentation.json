      "micro_segments": [
        {
          "title": "Why was it compared to Joshua if not about reinstating? Answer: merit against yetzer hara",
          "display_title": "Joshua Comparison",
          "timestamp": "58:43"
        },
        {
          "title": "Midrash: destroyed yetzer hara of idolatry during Second Temple return",
          "display_title": "Yetzer Hara Removed",
