        },
        {
          "title": "Rabbi Meir's position: underage allows sale but no fine; between 12 and six months allows fine but no sale",
          "display_title": "Rabbi Meir",
          "timestamp": "46:33"
        },
        {
          "title": "Sages' position: overlap of both sale and fine from age three to adulthood",
          "display_title": "Sages' Overlap",
          "timestamp": "47:03"
        }
      ]
    },
    {
      "title": "Miun and Chalitzah by Age Status",
      "display_title": "Miun & Chalitzah",
      "timestamp": "49:44",
      "micro_segments": [
        {
          "title": "Mishnah principle: where there is miun rejection, there is no chalitzah; where there is chalitzah, there is no miun",
          "display_title": "Mutual Exclusion",
          "timestamp": "49:44"
        },
        {
          "title": "Rabbi Meir's position: miun only while minor; chalitzah only when adult",
          "display_title": "Rabbi Meir",
          "timestamp": "52:05"
        },
        {
          "title": "Sages' position: both miun and chalitzah possible for a naarah between 12 and six months",
          "display_title": "Sages' Overlap",
          "timestamp": "52:11"
        }
      ]
