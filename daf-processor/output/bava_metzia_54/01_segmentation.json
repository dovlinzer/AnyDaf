  "macro_segments": [
    {
      "title": "Redemption of Ma'aser Sheni Below a Prutah and the Role of the Fifth",
      "display_title": "Ma'aser Below Prutah",
      "timestamp": "00:26",
      "micro_segments": [
        {
          "title": "Introduction to Ona'ah and the Mishna on Ma'aser Sheni Redemption with Deficient Coins",
          "display_title": "Ona'ah & Coins",
          "timestamp": "00:26"
        },
        {
          "title": "Redemption of Ma'aser Sheni Worth Less Than a Prutah: The Debate Between Rav and Rav Asi",
          "display_title": "Rav vs. Rav Asi",
          "timestamp": "02:09"
        },
        {
          "title": "The Baraita Explaining When One Cannot Redeem Ma'aser Sheni on New Money Versus Used Money",
          "display_title": "New vs. Used Money",
          "timestamp": "04:03"
        }
      ]
    },
    {
      "title": "The Meaning of the Fifth: From the Inside or From the Outside (Chomesh Mi-Legav or Mi-Levar)",
      "display_title": "Chomesh Mi-Legav/Levar",
      "timestamp": "06:49",
      "micro_segments": [
        {
          "title": "Question: Is the Fifth Calculated From the Base Value or From the Total After Adding the Fifth",
          "display_title": "How Fifth Calculated",
          "timestamp": "06:49"
        },
        {
          "title": "Proof From the Be'alim's Right of Redemption: Fifth of Twenty is Five (Mi-Levar)",
          "display_title": "Be'alim Redemption",
          "timestamp": "07:40"
        }
      ]
    },
    {
      "title": "Is the Fifth Me'akev (Essential to Validity) of the Pidyon (Redemption)?",
      "display_title": "Fifth Me'akev?",
      "timestamp": "12:19",
      "micro_segments": [
        {
          "title": "Conceptual Question: Does One Redeem Four at Its Value Plus Add a Fifth, or Does One Redeem Four on Five",
          "display_title": "Four + One or Four on Fi…",
          "timestamp": "12:19"
        },
        {
          "title": "Proof From Demai: Fifth Not Required Shows It is Not Me'akev",
          "display_title": "Demai Proof",
          "timestamp": "14:19"
        },
        {
          "title": "Debate: Rabbi Eliezer Says Fifth Not Me'akev; Rabbi Yehoshua Says Fifth Is Me'akev",
          "display_title": "Rabbi Eliezer vs. Yehosh…",
          "timestamp": "16:19"
        }
      ]
    },
    {
      "title": "Is the Fifth Me'akev (Essential to Validity) of the Pidyon (Redemption)? (continued)",
      "display_title": "Fifth Me'akev? (II)",
      "timestamp": "18:44",
      "micro_segments": [
        {
          "title": "Rav Pappa's Explanation: Even Rabbi Yehoshua Agrees Fifth Not Me'akev de'Oraita; Only Rabbinic Concern for Negligence",
          "display_title": "Rav Pappa Resolves",
          "timestamp": "18:44"
        },
        {
          "title": "Rabbi Yochanan: Disagreement Only Regarding Ma'aser; by Hekdesh Everyone Agrees When Both Hekdesh and Shabbat Apply",
          "display_title": "Hekdesh & Shabbat",
          "timestamp": "20:31"
        }
      ]
    },
    {
      "title": "Redemption of Ma'aser Sheni Below a Prutah and the Role of the Fifth (continued)",
      "display_title": "Ma'aser Below Prutah (II)",
      "timestamp": "18:44",
      "micro_segments": [
        {
          "title": "Resolution: The Fifth is Not Me'akev (Invalidating) at Torah Level; Rabbinic Safeguard Against Negligence",
          "display_title": "Fifth Not Me'akev",
          "timestamp": "18:44"
        }
      ]
    },
    {
      "title": "The Fifth Must Resemble the Original Object (Chomesh K'Moto): Questions of Applicability",
      "display_title": "Chomesh K'Moto",
      "timestamp": "26:51",
      "micro_segments": [
        {
          "title": "Series of Questions: Can the Fifth Be Redeemed on Land, Not From Chullin Food, or on Unmarked Coins",
          "display_title": "Fifth Properties",
          "timestamp": "26:51"
        },
        {
          "title": "Rava's Answer: The Word Alav (Upon It) Teaches the Fifth Must Be Like the Original Object",
          "display_title": "Rava's Drasha",
          "timestamp": "29:20"
        },
        {
          "title": "Ravina's Proof From Terumah: When Fifth Must Be Repaid in Food, Showing Fifth Follows the Nature of the Original",
          "display_title": "Terumah Proof",
          "timestamp": "29:57"
        }
      ]
    },
    {
      "title": "Fifth Upon the Fifth: When Does the Rule Apply (Gezel, Terumah, Hekdesh, but Not Ma'aser)",
      "display_title": "Fifth of Fifth",
      "timestamp": "33:14",
      "micro_segments": [
        {
          "title": "Gezel: Plural Chamishitav Indicates Multiple Fifths Apply When One Swears Falsely on Each Fifth",
          "display_title": "Gezel Case",
          "timestamp": "33:14"
        },
        {
          "title": "Terumah: Fifth of Fifth Applies Even Though Singular Used; Teaching in Mishna Explicitly States It",
          "display_title": "Terumah Case",
          "timestamp": "35:27"
        },
        {
          "title": "Ma'aser: No Fifth of Fifth Because Neither Pesukim Nor Mishna Indicates It; Never Even Questioned",
          "display_title": "Ma'aser No Fifth²",
          "timestamp": "37:05"
        },
        {
          "title": "Hekdesh: Question Whether Fifth of Fifth Applies; Inquiry Into Whether It is From Pesukim or Derasha",
          "display_title": "Hekdesh Question",
          "timestamp": "38:01"
        },
        {
          "title": "Resolution: Fifth of Fifth Applies to Hekdesh Through Makish (Comparison) of the Fifth to the Principal Value",
          "display_title": "Hekdesh Resolution",
          "timestamp": "45:15"
        }
      ]
    },
    {
      "title": "Fifth Only on Original Hekdesh, Not on Transferred Hekdesh: Rabbi Yehoshua ben Levi's Principle",
      "display_title": "Original vs. Transferred",
      "timestamp": "46:00",
      "micro_segments": [
        {
          "title": "Rabbi Yehoshua ben Levi: Fifth Added Only to Original Sanctified Object, Not to Transferred Hekdesh",
          "display_title": "RYBLI Position",
          "timestamp": "46:00"
        },
        {
          "title": "Rava's Proof: Only One Who Sanctifies (Hamakdish) Gets the Fifth, Not One Who Substitutes (Hametfis)",
          "display_title": "Makdish vs. Metfis",
          "timestamp": "46:08"
        },
        {
          "title": "Extended Discussion: Debate Over What Makes a Non-Kosher Animal Different and How It Relates to Original vs. Transferred Hekdesh",
          "display_title": "Non-Kosher Animal",
          "timestamp": "46:40"
        },
        {
          "title": "Final Resolution: The Definite Article Ha in Behemah Ha-Tme'ah Indicates the First Hekdesh, Not Transferred; Therefore No Fifth on Transfer",
          "display_title": "Ha-Article Drasha",
          "timestamp": "54:28"
        }
      ]
    }
  ],
