  "macro_segments": [
    {
      "title": "The Status and Override of Tosefet Shevi'it (Additional Work Period in Sabbatical Year)",
      "display_title": "Tosefet Shevi'it Status",
      "timestamp": "00:06",
      "micro_segments": [
        {
          "title": "Introduction: Overrides of Chol HaMoed and Shemita prohibitions based on Mekom Hefsed",
          "display_title": "Override Framework",
          "timestamp": "00:06"
        },
        {
          "title": "Teaching from Eretz Yisrael: Tosefet Shevi'it prohibition and lack of lashes",
          "display_title": "Tosefet Transmission",
          "timestamp": "00:40"
        },
        {
          "title": "Two explanations for Tosefet: Charisha as Tolada, or pre-Rosh Hashanah period",
          "display_title": "Tosefet Explanations",
          "timestamp": "00:49"
        },
        {
          "title": "Mishnah on Tosefet periods and Rabban Gamliel's override; characterization as Derabbanan",
          "display_title": "Rabban Gamliel Override",
          "timestamp": "01:34"
        },
        {
          "title": "Evidence that Tosefet is Halakha L'Moshe MiSinai: Ten saplings case",
          "display_title": "HLM MiSinai Evidence",
          "timestamp": "02:11"
        },
        {
          "title": "Resolution: Thirty-day Halakha L'Moshe MiSinai boundary with ten-trees exception; earlier period is Derabbanan",
          "display_title": "Two-Layer Structure",
          "timestamp": "02:46"
        }
      ]
    },
    {
      "title": "Gemara's Challenge: Is Tosefet Shevi'it Biblical or Halakha L'Moshe MiSinai?",
      "display_title": "Biblical Status Debate",
      "timestamp": "03:19",
      "micro_segments": [
        {
          "title": "Gemara question: Are these Halakha L'Moshe MiSinai? Probing the hybrid structure",
          "display_title": "HLM Status Question",
          "timestamp": "03:19"
        },
        {
          "title": "Rabbi Akiva's interpretation: Pasuk on Charish and Katzir refers to Tosefet Shevi'it, not Shabbat",
          "display_title": "R. Akiva on Pasuk",
          "timestamp": "06:23"
        },
        {
          "title": "Rabbi Yishmael's counter-interpretation: Pasuk discusses Shabbat, excludes Omer harvest as Mitzvah",
          "display_title": "R. Yishmael on Pasuk",
          "timestamp": "08:30"
        },
        {
          "title": "Rav Nachman bar Yitzchak: Pasuk introduces Tosefet concept; Halakha L'Moshe MiSinai provides exception",
          "display_title": "Synthesis: Pasuk + HLM",
          "timestamp": "09:36"
        },
        {
          "title": "Gemara objection: Pasuk would be superfluous given Halakha L'Moshe MiSinai exception",
          "display_title": "Superfluous Pasuk",
          "timestamp": "10:42"
        },
        {
          "title": "Resolution: Debate between Rabbi Yishmael (Halakha L'Moshe MiSinai) and Rabbi Akiva (Pasuk) regarding source",
          "display_title": "Akiva vs Yishmael",
          "timestamp": "11:14"
        }
      ]
    },
    {
      "title": "Rabban Gamliel's Nullification and its Justification",
      "display_title": "Rabban Gamliel Nullifies",
      "timestamp": "12:20",
      "micro_segments": [
        {
          "title": "Rabbi Yochanan: Rabban Gamliel and Beit Din nullified Tosefet from the Torah (De'oraisa)",
          "display_title": "Nullification Claim",
          "timestamp": "12:20"
        },
        {
          "title": "Support for nullification: Comparison to Shabbat model—only the day itself is forbidden, before and after are permitted",
          "display_title": "Shabbat Comparison",
          "timestamp": "13:01"
        },
        {
          "title": "Tosefet Shabbat clarification: minimal period of adding on, distinction from Tosefet Shevi'it",
          "display_title": "Tosefet Shabbat Parallel",
          "timestamp": "13:29"
        },
        {
          "title": "Rav Ashi's challenge: How can Gezeira Shava override Halakha L'Moshe MiSinai or Pasuk?",
          "display_title": "Rav Ashi Objection",
          "timestamp": "17:04"
        },
        {
          "title": "Rav Ashi's resolution: Rabban Gamliel held like Rabbi Yishmael; Halakha L'Moshe MiSinai applies only when Beit HaMikdash stands",
          "display_title": "HLM Time-Bound",
          "timestamp": "17:55"
        },
        {
          "title": "Conceptual issue: Is Tosefet an actual extension of Kedusha or merely caution against overshooting boundary?",
          "display_title": "Kedusha vs Caution",
          "timestamp": "20:37"
        }
      ]
    },
    {
      "title": "Watering Fields on Chol HaMoed: Spring Water versus Collected Water",
      "display_title": "Watering Restrictions",
      "timestamp": "23:08",
      "micro_segments": [
        {
          "title": "Mishnah rule: Permitted to water from springs; forbidden from rainwater and bucket systems (Mei Kilon)",
          "display_title": "Spring vs Collected",
          "timestamp": "23:08"
        },
        {
          "title": "Gemara explanation: Gezeira—allowing rainwater will lead to permitting bucket system water",
          "display_title": "Gezeira Rationale",
          "timestamp": "23:57"
        },
        {
          "title": "Rav Ashi alternative: Rainwater itself becomes problematic when barrel level drops, requiring bucket effort",
          "display_title": "Rainwater Self-Problem",
          "timestamp": "25:31"
        },
        {
          "title": "Debate: Is concern about Mei Geshamim itself, or will it lead to other scenarios of Mei Kilon?",
          "display_title": "Concern Type Debate",
          "timestamp": "26:20"
        },
        {
          "title": "Rabbi Zeira teaching: Rivers drawing water from swamps are permitted on Chol HaMoed",
          "display_title": "Rivers from Swamps",
          "timestamp": "26:25"
        },
        {
          "title": "Rabbi Yirmiyah challenge: Swamp water is also collected water; why is it different?",
          "display_title": "R. Yirmiyah Challenge",
          "timestamp": "29:20"
        },
        {
          "title": "Response: Swamps in Bavel never run dry; no concern that scarcity will necessitate bucket system",
          "display_title": "Bavel Swamps Inexhaustib…",
          "timestamp": "30:35"
        }
      ]
    },
    {
      "title": "Collected Pools and Channels: Conditions for Permitted Watering",
      "display_title": "Pools and Channels",
      "timestamp": "31:25",
      "micro_segments": [
        {
          "title": "Baraita: Pools filled before Yom Tov with rainwater are forbidden; permitted if water channel passes through them",
          "display_title": "Pools Rule",
          "timestamp": "31:25"
        },
        {
          "title": "Rav Pappa condition: Permitted only if majority of field can be watered from the channel water",
          "display_title": "Majority Field Condition",
          "timestamp": "32:17"
        },
        {
          "title": "Rav Ashi leniency: Even if not majority, permitted if water constantly flows—reliance on continuous supply",
          "display_title": "Continuous Flow Leniency",
          "timestamp": "35:50"
        },
        {
          "title": "Baraita: Dripping well from one field-bed to another is permitted if dripping continues",
          "display_title": "Dripping Well",
          "timestamp": "37:04"
        },
        {
          "title": "Rabbi Yirmiyah condition: Dripping must be ongoing at time of watering",
          "display_title": "Dripping Ongoing",
          "timestamp": "38:52"
        },
        {
          "title": "Abaye addition: Upper spring must also continue providing water; extension of spring concept",
          "display_title": "Upper Spring Flowing",
          "timestamp": "39:07"
        }
      ]
    },
    {
      "title": "Prohibitions on Field Labor: Hauling, Leveling, and Furrow-Making",
      "display_title": "Field Labor Prohibitions",
      "timestamp": "41:33",
      "micro_segments": [
        {
          "title": "Baraita: Cannot draw (haul) water for vegetables to eat; permitted for preservation versus beautification",
          "display_title": "Vegetable Hauling",
          "timestamp": "41:33"
        },
        {
          "title": "Ravina and Rabba Tosfah story: Person drawing water on Chol HaMoed; Rabba Tosfah's reluctance to object",
          "display_title": "Dragging Water Story",
          "timestamp": "42:15"
        },
        {
          "title": "Reinterpretation: Madlin means thinning vegetables (removing some), not drawing water",
          "display_title": "Madlin = Thinning",
          "timestamp": "43:01"
        },
        {
          "title": "Conflicting Baraita: States you can draw water for vegetables; reconciliation by Ravina",
          "display_title": "Conflicting Baraita",
          "timestamp": "44:39"
        },
        {
          "title": "Prohibition: Making circular furrows (Ugiyot) around vines and olive trees to collect water",
          "display_title": "Furrow-Making Ban",
          "timestamp": "45:36"
        },
        {
          "title": "Exception: Permitted if repairing old furrows; distinction from creating new ones",
          "display_title": "Old vs New Furrows",
          "timestamp": "46:24"
        }
      ]
    },
    {
      "title": "Making and Repairing Water Channels (Amot): Shemita and Chol HaMoed Restrictions",
      "display_title": "Canal Making Rules",
      "timestamp": "46:59",
      "micro_segments": [
        {
          "title": "Rabbi Elazar ben Azarya: Forbidden to make canals on Shemita or Chol HaMoed",
          "display_title": "R. Elazar Prohibition",
          "timestamp": "46:59"
        },
        {
          "title": "Rabbis' position: Permitted to initially make canals on Shemita; permitted to repair damaged ones on Chol HaMoed",
          "display_title": "Rabbis' Leniency",
          "timestamp": "47:13"
        },
        {
          "title": "Gemara: Understanding prohibition on Shemita—concern it appears as Oder (working ground) or making banks fit for planting",
          "display_title": "Oder vs Fitness",
          "timestamp": "47:42"
        },
        {
          "title": "Debate: Rabbi Zeira and Rabbi Abba bar Memel on primary reason—appearance or fitness for planting",
          "display_title": "Two Rationales",
          "timestamp": "48:24"
        },
        {
          "title": "Distinguishing factor: If water flows immediately, concern of planting-fitness applies; if dirt thrown far away, Oder concern minimal",
          "display_title": "Water Flow Factor",
          "timestamp": "49:48"
        },
        {
          "title": "Challenge from Amimemar: How can Rabbi Elazar forbid all Oder-like work if he permits making manure piles (digging ditches)?",
          "display_title": "Oder Contradiction",
          "timestamp": "52:26"
        }
      ]
    },
    {
      "title": "Excrement Collection and Field Preparation on Shemita: Halakhic Distinctions",
      "display_title": "Excrement Handling",
      "timestamp": "52:46",
      "micro_segments": [
        {
          "title": "Mishnah: Can collect animal excrement on Shemita; debate on methods to avoid appearance of fertilizing",
          "display_title": "Excrement Collection",
          "timestamp": "52:46"
        },
        {
          "title": "First view: Simply collect excrement without restriction",
          "display_title": "Permissive View",
          "timestamp": "53:25"
        },
        {
          "title": "Rabbi Meir: Must dig pit three handbreadths deep, or create pile three handbreadths high, or pre-existing pile",
          "display_title": "R. Meir Methods",
          "timestamp": "53:35"
        },
        {
          "title": "Rabbi Elazar ben Azarya: Similar requirements to Rabbi Meir; also permits placing on rock",
          "display_title": "R. Elazar Methods",
          "timestamp": "54:19"
        },
        {
          "title": "Resolution to Rabbi Elazar contradiction: Pre-existing pit or excrement pile makes work context clear",
          "display_title": "Context Clarity",
          "timestamp": "54:55"
        },
        {
          "title": "Alternative explanation: Excrement itself indicates purpose of digging, overriding Oder concern",
          "display_title": "Excrement as Proof",
          "timestamp": "55:12"
        }
      ]
    }
  ],
