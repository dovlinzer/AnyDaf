      "micro_segments": [
        {
          "title": "Mishna's principle on sheias heter lakohanim and when meilah status changes",
          "display_title": "Mishna sheia heter",
          "timestamp": "18:55"
        },
        {
          "title": "Bar Kappara feeding his nephew Reb Padda the key question about three possible moments",
          "display_title": "Bar Kappara q",
          "timestamp": "21:38"
        },
        {
          "title": "Three interpretations: heter shechita, heter zerika, or heter achila",
          "display_title": "Three moments",
          "timestamp": "22:46"
        },
        {
          "title": "Chizkiya vs Rabbi Yochanan debate on which moment determines status change",
          "display_title": "Chizkiya/Yochanan",
          "timestamp": "23:25"
        },
        {
          "title": "Rabbi Zeira: Mishna precise reading suggests neither position fully, possibly zerika focus",
          "display_title": "Rabbi Zeira reading",
          "timestamp": "23:51"
        },
        {
          "title": "Gemara analyzes mishna cases to determine if blood or meat determines status",
          "display_title": "Blood vs meat",
          "timestamp": "24:14"
        },
        {
          "title": "Rav Yosef's challenge: stock phrase proof from zecharim on chatas blood ritual",
          "display_title": "Rav Yosef stock",
