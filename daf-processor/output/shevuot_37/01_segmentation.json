      "micro_segments": [
        {
          "title": "Case: Rape or Seduction—Rabbi Shimon Exempts (Knas); Chachamim Obligate (Includes Mammon)",
          "display_title": "Rape/Seduction",
          "timestamp": "14:03"
        },
        {
          "title": "Case: Theft of Ox Without Slaughter—Liable (Mammon); With Slaughter, Admission Before Oath Exempts (Knas Only)",
          "display_title": "Theft of Ox",
          "timestamp": "16:16"
        },
        {
          "title": "Case: Ox Killing Ox—Liable (Mammon); Ox Killing Slave—Exempt (Knas Only)",
          "display_title": "Ox Damages",
          "timestamp": "17:54"
        },
        {
          "title": "Case: Wounding—Liable (Mammon); Slave's Lost Tooth/Eye Leading to Freedom—Exempt (Knas Only)",
          "display_title": "Wounding Scenarios",
          "timestamp": "18:53"
        },
        {
          "title": "The General Rule: Liable if Would Pay Upon Admission; Exempt if Payment is Knas Only",
          "display_title": "General Rule",
          "timestamp": "19:42"
        }
      ]
