{
  "masechta": "Hullin",
  "daf": 108,
  "amud": "a",
  "macro_segments": [
    {
      "title": "Introduction to Basar Bechalav and the Opening Mishna on Milk Dropped on Meat",
      "display_title": "Intro & Mishna",
      "timestamp": "00:00",
      "micro_segments": [
        {
          "title": "Transition from rabbinic concerns to biblical basar bechalav",
          "display_title": "Transition to Basar",
          "timestamp": "00:00"
        },
        {
          "title": "Mishna: drop of milk falls on meat chunk in stew",
          "display_title": "Tipat Chalav",
          "timestamp": "00:31"
        },
        {
          "title": "If milk taste is detectable in the piece, it becomes forbidden",
          "display_title": "Taste Determines Status",
          "timestamp": "00:45"
        },
        {
          "title": "Stirring the pot: milk taste spreads throughout",
          "display_title": "Stirred Pot",
          "timestamp": "01:43"
        },
        {
          "title": "Two interpretations of the mishna regarding what tastes spread",
          "display_title": "Two Readings",
          "timestamp": "02:01"
        }
      ]
    },
    {
      "title": "Abaye and Rava: Is Taste a Biblical Concern in Basar Bechalav?",
      "display_title": "Abaye vs. Rava",
      "timestamp": "03:06",
      "micro_segments": [
        {
          "title": "Abaye: taste without substance is a biblical concern",
          "display_title": "Abaye's Position",
          "timestamp": "03:06"
        },
        {
          "title": "Difficulty: why can't we prove taste is biblical from basar bechalav?",
          "display_title": "Learning from Basar",
          "timestamp": "04:36"
        },
        {
          "title": "Basar bechalav is exceptional because cooking matters, not just taste",
          "display_title": "Exception Theory",
          "timestamp": "05:00"
        },
        {
          "title": "Abaye's response: if cooking alone mattered, no taste requirement",
          "display_title": "Abaye's Proof",
          "timestamp": "07:22"
        },
        {
          "title": "Conceptual difference: cooking creates true intermingling vs. side-by-side tastes",
          "display_title": "Intermingling Concept",
          "timestamp": "09:02"
        },
        {
          "title": "Rava: Torah forbade cooking together; taste is incidental to cooking",
          "display_title": "Rava's Position",
          "timestamp": "09:14"
        },
        {
          "title": "Application to roasting, steaming, and other heat methods",
          "display_title": "Definition of Cooking",
          "timestamp": "11:49"
        }
      ]
    },
    {
      "title": "Chaticha Naaseit Neveila: The Entire Piece Becomes Forbidden",
      "display_title": "Chaticha Neveila",
      "timestamp": "14:22",
      "micro_segments": [
        {
          "title": "Rav's ruling: once milk gives taste to meat, the whole piece becomes forbidden",
          "display_title": "Rav's Ruling",
          "timestamp": "14:22"
        },
        {
          "title": "The forbidden piece forbids other pieces because min bemino",
          "display_title": "Min Bemino",
          "timestamp": "14:32"
        },
        {
          "title": "The meat becomes forbidden as meat, not as a hybrid category",
          "display_title": "Forbidden as Meat",
          "timestamp": "15:35"
        },
        {
          "title": "Question: why doesn't the rest of the pot negate with enough vegetables?",
          "display_title": "Negation Question",
          "timestamp": "18:02"
        },
        {
          "title": "Answer: the pot is thick with mainly meat, not enough other ingredients",
          "display_title": "Thick Stew Answer",
          "timestamp": "18:29"
        }
      ]
    },
    {
      "title": "Efshar Lesochto: Does the Status Revert When Milk is Removed?",
      "display_title": "Efshar Lesochto",
      "timestamp": "19:29",
      "micro_segments": [
        {
          "title": "Question: what is Rav's position on reversing the forbidden status?",
          "display_title": "Reversal Question",
          "timestamp": "19:29"
        },
        {
          "title": "Efshar lesochto mutar vs. efshar lesochto assur",
          "display_title": "Two Positions",
          "timestamp": "19:51"
        },
        {
          "title": "Explanation: status stickiness and the distinction between taste mixture and cooking act",
          "display_title": "Status Stickiness",
          "timestamp": "20:23"
        },
        {
          "title": "Most authorities: even if milk is removed, meat remains forbidden",
          "display_title": "Majority View",
          "timestamp": "24:02"
        }
      ]
    },
    {
      "title": "Meat Falling into Milk: The Milk's Status and Min Bemino Question",
      "display_title": "Meat in Milk Pot",
      "timestamp": "25:02",
      "micro_segments": [
        {
          "title": "Case: chunk of meat falls into pot of hot milk",
          "display_title": "Meat Falls in",
          "timestamp": "25:02"
        },
        {
          "title": "Rav: meat is forbidden, milk is permissible",
          "display_title": "Rav's Ruling",
          "timestamp": "25:21"
        }
      ]
    },
    {
      "title": "Meat Falling into Milk: The Milk's Status and Min Bemino Question (continued)",
      "display_title": "Meat in Milk Pot (II)",
      "timestamp": "25:59",
      "micro_segments": [
        {
          "title": "Question: if status doesn't revert, why isn't all the milk forbidden?",
          "display_title": "Status Problem",
          "timestamp": "25:59"
        }
      ]
    },
    {
      "title": "Efshar Lesochto: Does the Status Revert When Milk is Removed? (continued)",
      "display_title": "Efshar Lesochto (II)",
      "timestamp": "25:59",
      "micro_segments": [
        {
          "title": "Challenge: if reversal doesn't work, why isn't all the milk forbidden?",
          "display_title": "Milk Challenge",
          "timestamp": "25:59"
        },
        {
          "title": "Resolution: Torah forbids the meat, not the milk; only meat becomes forbidden",
          "display_title": "Torah's Focus",
          "timestamp": "28:05"
        }
      ]
    },
    {
      "title": "Half-Kezayit Each: When Do Meat and Milk Combine for Prohibition?",
      "display_title": "Half-Kezayit Debate",
      "timestamp": "29:02",
      "micro_segments": [
        {
          "title": "Case: half-kezayit meat and half-kezayit milk cooked together",
          "display_title": "Half-Kezayit Case",
          "timestamp": "29:02"
        },
        {
          "title": "Rav: you get lashes for eating, not for cooking",
          "display_title": "Rav's Position",
          "timestamp": "29:21"
        }
      ]
    },
    {
      "title": "Meat Falling into Milk: The Milk's Status and Min Bemino Question (continued)",
      "display_title": "Meat in Milk Pot (III)",
      "timestamp": "31:06",
      "micro_segments": [
        {
          "title": "Answer: in a boiling pot, milk doesn't go back out; you remove the meat quickly",
          "display_title": "Boiling Pot Answer",
          "timestamp": "31:06"
        }
      ]
    },
    {
      "title": "Half-Kezayit Each: When Do Meat and Milk Combine for Prohibition? (continued)",
      "display_title": "Half-Kezayit Debate (II)",
      "timestamp": "32:59",
      "micro_segments": [
        {
          "title": "Question: do they combine or not? Inconsistency raised",
          "display_title": "Inconsistency",
          "timestamp": "32:59"
        },
        {
          "title": "Resolution: they only combine for eating from previously-forbidden sources",
          "display_title": "Combination Logic",
          "timestamp": "33:32"
        },
        {
          "title": "Levi's position: you get lashes even for half-kezayit each",
          "display_title": "Levi's View",
          "timestamp": "36:22"
        },
        {
          "title": "Cooking must be to a degree that others would eat it",
          "display_title": "Cooking Standard",
          "timestamp": "36:53"
        }
      ]
    },
    {
      "title": "Baraita on Chaticha Naaseit Neveila and Debate of Tannaim",
      "display_title": "Baraita & Tannaim",
      "timestamp": "37:39",
      "micro_segments": [
        {
          "title": "Baraita: R. Yehuda holds piece becomes forbidden, forbids all pieces of meat",
          "display_title": "R. Yehuda's View",
          "timestamp": "37:39"
        },
        {
          "title": "Sages: forbidden only if taste spreads to all parts of the pot",
          "display_title": "Sages' View",
          "timestamp": "38:50"
        },
        {
          "title": "Rebbi splits: R. Yehuda's rule applies if pot not stirred/covered initially",
          "display_title": "Rebbi's Split",
          "timestamp": "39:34"
        },
        {
          "title": "Clarification: milk falls, piece becomes forbidden, then pot is stirred later",
          "display_title": "Timing Question",
          "timestamp": "40:56"
        },
        {
          "title": "Gemara challenges: doesn't milk go out when stirred? Why doesn't piece revert?",
          "display_title": "Gemara Challenge",
          "timestamp": "41:11"
        },
        {
          "title": "Answer: Rav holds efshar lesochto assur; piece remains forbidden even after stirring",
          "display_title": "Final Answer",
          "timestamp": "42:20"
        }
      ]
    }
