  "amud": "a-b",
  "macro_segments": [
    {
      "title": "Introduction to the New Perek: Cases Where Meilah Does Not Apply",
      "display_title": "No Meilah Overview",
      "timestamp": "00:00",
      "micro_segments": [
        {
          "title": "Opening remarks and context on sanctification and meilah",
          "display_title": "Opening Context",
          "timestamp": "00:00"
        },
        {
          "title": "Distinction between items that are pasul and items destined to die",
          "display_title": "Pasul vs. Destined to Die",
          "timestamp": "00:31"
        }
      ]
    },
    {
      "title": "Chatat Shemeisah: Cases Where a Sin-Offering Must Be Left to Die",
      "display_title": "Chatat Shemeisah",
      "timestamp": "01:38",
      "micro_segments": [
        {
          "title": "Three cases where chatat automatically must die: vlad chatat, tmurat chatat, owners deceased",
          "display_title": "Three Automatic Cases",
          "timestamp": "01:38"
        },
        {
          "title": "Two conditional cases: avrah shnasah and lost animal with mum",
          "display_title": "Conditional Cases",
          "timestamp": "02:28"
        },
        {
          "title": "Distinction based on whether atonement has already been achieved",
          "display_title": "Achieved Atonement",
          "timestamp": "02:45"
        },
        {
          "title": "Halachic status when atonement not yet achieved: wait for mum and redeem",
          "display_title": "Waiting for Mum",
          "timestamp": "05:03"
        },
        {
          "title": "When atonement already achieved: animal must die, no tmura, no meilah",
          "display_title": "No Tmura, No Meilah",
          "timestamp": "05:07"
        },
        {
          "title": "Gemara discussion: why reisha listed without conditions, seifa depends on circumstances",
          "display_title": "Gemara: Reisha vs. Seifa",
          "timestamp": "08:01"
        },
        {
          "title": "Two halachot taught in two different masechot: tmura vs. meilah",
          "display_title": "Two Halachot",
          "timestamp": "08:43"
        }
      ]
    },
    {
      "title": "Nezir Money: Money Set Aside Without Specification of Use",
      "display_title": "Nezir Money",
      "timestamp": "11:47",
      "micro_segments": [
        {
          "title": "Unspecified money for nezir offerings: no benefit, no meilah because could all be shelamim",
          "display_title": "Unspecified Money",
          "timestamp": "11:47"
        },
        {
          "title": "Nezir dies with unspecified money: all goes to olah by default",
          "display_title": "Death Case",
          "timestamp": "15:08"
        },
        {
          "title": "Explicit piles for different offerings: chatat money destroyed, olah money brings olah with meilah",
          "display_title": "Explicit Chatat & Olah",
          "timestamp": "16:20"
        },
        {
          "title": "Shelamim money brought after death: quasi-shelamim nazir status, one day eating but no bread",
          "display_title": "Shelamim After Death",
          "timestamp": "17:08"
        }
      ]
    },
    {
      "title": "Bird Offerings: Too Young or Too Old Birds Without Pidyon",
      "display_title": "Bird Offerings",
      "timestamp": "20:49",
      "micro_segments": [
        {
          "title": "Birds cannot be redeemed even with blemishes: no pidyon, status cannot transfer",
          "display_title": "No Pidyon for Birds",
          "timestamp": "20:49"
        },
        {
          "title": "Reish Lakish's challenge: money set aside for bird offerings should have meilah",
          "display_title": "Reish Lakish Challenge",
          "timestamp": "22:51"
        },
        {
          "title": "Rava's answer: proper use of money assumes fit-for-use offerings, not too-young birds",
          "display_title": "Rava's Answer",
          "timestamp": "24:45"
        }
      ]
    },
    {
      "title": "Blood: Unique Status of Minimal Meilah Before and After Use",
      "display_title": "Blood Status",
      "timestamp": "26:16",
      "micro_segments": [
        {
          "title": "Blood in beginning has no meilah; after going to Kidron stream has rabbinic meilah",
          "display_title": "Blood Paradox",
          "timestamp": "26:16"
        }
      ]
    },
    {
      "title": "Nesachim (Wine Libations): Meilah Before Pouring, Not After",
      "display_title": "Nesachim",
      "timestamp": "26:35",
      "micro_segments": [
        {
          "title": "Wine before pouring has meilah; after going down funnels has no meilah",
          "display_title": "Wine Paradox",
          "timestamp": "26:35"
        }
      ]
    },
    {
      "title": "Blood: Unique Status of Minimal Meilah Before and After Use (continued)",
      "display_title": "Blood Status…",
      "timestamp": "29:45",
      "micro_segments": [
        {
          "title": "Tannaitic dispute: Rabbi Meir says meilah applies; Chachamim say it does not",
          "display_title": "Rabbi Meir vs. Chachamim",
          "timestamp": "29:45"
        },
        {
          "title": "Chachamim's source: blood serves atonement function, taken out of kodshei Hashem category",
          "display_title": "Atonement Function",
          "timestamp": "29:56"
        },
        {
          "title": "Rabbi Yochanan's interpretation: blood has one status before and after atonement",
          "display_title": "One Status Theory",
          "timestamp": "31:13"
        },
        {
          "title": "Principle that nothing retains meilah once nesaia mitzvato is complete, exceptions discussed",
          "display_title": "Nesaia Mitzvato",
          "timestamp": "32:44"
        }
      ]
    },
    {
      "title": "Exceptions to Nesaia Mitzvato Rule: Trumas Hadeshen and Others",
      "display_title": "Nesaia Mitzvato Exceptio…",
      "timestamp": "33:20",
      "micro_segments": [
        {
          "title": "Trumas hadeshen and sheir hamistaleach as two exceptions, cannot generalize rule from two cases",
          "display_title": "Two Exceptions Doctrine",
          "timestamp": "33:20"
        },
        {
          "title": "Additional exceptions: begdei kehunah and egla arufa to prevent generalization",
          "display_title": "Multiple Exceptions",
          "timestamp": "36:52"
        },
        {
          "title": "Torah's limiting language prevents making exceptions into rules",
          "display_title": "Limiting Language",
          "timestamp": "40:00"
        }
      ]
    },
    {
      "title": "Nesachim (Wine Libations): Meilah Before Pouring, Not After (continued)",
      "display_title": "Nesachim…",
      "timestamp": "46:41",
      "micro_segments": [
        {
          "title": "Rabbi Elazar bar Tzadok's view: wine must be burned in sanctity even after use",
          "display_title": "Wine Burning",
          "timestamp": "46:41"
        },
        {
          "title": "Lul: small trapdoor between ramp and altar for cleaning congealed wine",
          "display_title": "Lul Mechanism",
          "timestamp": "46:58"
        },
        {
          "title": "Once per seventy years: priestly youth clean congealed wine and burn it in sanctity",
          "display_title": "Cleaning Frequency",
          "timestamp": "48:11"
        },
        {
          "title": "Gemara resolution: whether meilah applies depends on whether wine hit altar floor",
          "display_title": "Hit Floor Question",
          "timestamp": "50:43"
        },
        {
          "title": "Alternative resolution: Rabbi Elazar bar Tzadok's burning requirement is only rabbinic",
          "display_title": "Rabbinic Burning",
          "timestamp": "51:14"
        }
      ]
    }
  ],
