{
  "masechta": "Bava Batra",
  "daf": 163,
  "amud": "a-b",
  "macro_segments": [
    {
      "title": "White Space Between Document Body and Witness Signatures",
      "display_title": "Body-Witness Gap",
      "timestamp": "00:18",
      "micro_segments": [
        {
          "title": "Two-line gap prevents forgery of intervening text",
          "display_title": "Two-line rule",
          "timestamp": "00:18"
        },
        {
          "title": "Single line gap is permissible to allow witness space to sign",
          "display_title": "One-line gap permitted",
          "timestamp": "00:40"
        },
        {
          "title": "Dots and splotches prevent misuse of blank space",
          "display_title": "Dots prevent abuse",
          "timestamp": "01:26"
        }
      ]
    },
    {
      "title": "Protection Against Erasing and Rewriting the Document Body",
      "display_title": "Erasure concerns",
      "timestamp": "02:46",
      "micro_segments": [
        {
          "title": "Rav's ruling: document with body and witnesses on erased background is valid",
          "display_title": "Rav: erasure kasher",
          "timestamp": "02:46"
        },
        {
          "title": "Concern that entire document could be erased and rewritten with forged validation",
          "display_title": "Full erasure risk",
          "timestamp": "05:01"
        },
        {
          "title": "Solution: validation only used if witnesses sign on clean background",
          "display_title": "Validation voided",
          "timestamp": "09:20"
        }
      ]
    },
    {
      "title": "White Space Between Witness Signatures and Validation Mark",
      "display_title": "Witness-Validation Gap",
      "timestamp": "10:34",
      "micro_segments": [
        {
          "title": "Rabbi Yochanan: one-line document with witnesses on same line is valid",
          "display_title": "One-line doc valid",
          "timestamp": "10:34"
        },
        {
          "title": "But one-line document with witnesses on different line from validation is invalid",
          "display_title": "Separate lines invalid",
          "timestamp": "11:01"
        },
        {
          "title": "Rationale: validation must be far from witnesses to prevent forged small documents",
          "display_title": "Small doc concern",
          "timestamp": "11:22"
        },
        {
          "title": "Addendum concept: witnesses can note validation belongs to their signatures",
          "display_title": "Witness notation",
          "timestamp": "14:00"
        },
        {
          "title": "Risk of adding extra forged witnesses on the blank line",
          "display_title": "Extra witness risk",
          "timestamp": "20:32"
        }
      ]
    },
    {
      "title": "Single-Erasure vs. Double-Erasure Detection",
      "display_title": "Erasure detection",
      "timestamp": "22:54",
      "micro_segments": [
        {
          "title": "Principle: single erasure looks different from double erasure",
          "display_title": "Visual difference",
          "timestamp": "22:54"
        },
        {
          "title": "Concern: forger could erase top of document and rewrite it on erased background",
          "display_title": "Double erase risk",
          "timestamp": "24:41"
        },
        {
          "title": "Witnesses must sign on erased background that was erased in their presence",
          "display_title": "Witnesses witness erasure",
          "timestamp": "25:47"
        },
        {
          "title": "Scenario: document body on clean background, witnesses on erased background is valid",
          "display_title": "Clean body valid",
          "timestamp": "26:47"
        },
        {
          "title": "Scenario: document body on erased background, witnesses on clean background is invalid",
          "display_title": "Erased body invalid",
          "timestamp": "30:48"
        },
        {
          "title": "Solution for invalid scenario: insert notation between witness signatures stating background was erased",
          "display_title": "Notation solution",
          "timestamp": "32:11"
        },
        {
          "title": "Limitation: cannot distinguish between single and double erasures without basis of comparison",
          "display_title": "Comparison needed",
          "timestamp": "33:58"
        },
        {
          "title": "Limitation: age of erasure affects appearance; fresh vs. old erasure look different",
          "display_title": "Age of erasure",
          "timestamp": "37:32"
        },
        {
          "title": "Final rule: Beit Din too prone to error in making such distinctions; document invalid",
          "display_title": "Beit Din error risk",
          "timestamp": "38:40"
        }
      ]
    },
    {
      "title": "Dated Documents and Mekushar (Tied) Contracts",
      "display_title": "Dating systems",
      "timestamp": "40:46",
      "micro_segments": [
        {
          "title": "Introduction to mekushar document form with witnesses on outside of tied scroll",
          "display_title": "Mekushar form",
          "timestamp": "40:46"
        },
        {
          "title": "Rabbi Chanina ben Gamliel: witnesses on inside of mekushar are valid; can be opened and converted",
          "display_title": "Inside witnesses valid",
          "timestamp": "40:47"
        },
        {
          "title": "Objection: different dating systems used for mekushar vs. regular document",
          "display_title": "Dating difference",
          "timestamp": "42:06"
        },
        {
          "title": "Example: postdating risk if mekushar is opened and converted to regular document",
          "display_title": "Postdating risk",
          "timestamp": "45:03"
        },
        {
          "title": "Rav's explanation: one who allows witnesses inside would prohibit writing receipts",
          "display_title": "No receipts",
          "timestamp": "49:41"
        },
        {
          "title": "Anecdote: Rabbi initially unaware of different dating system; learned from Zonim",
          "display_title": "Rabbi's learning",
          "timestamp": "50:48"
        }
      ]
    },
    {
      "title": "Roman Official Titles and Terms of Office",
      "display_title": "Roman archon titles",
      "timestamp": "52:11",
      "micro_segments": [
        {
          "title": "Document dated by archon (governor) name without specifying year of term",
          "display_title": "Archon dating",
          "timestamp": "52:11"
        },
        {
          "title": "Assumption: archon (one-year office) means first year of tenure; digon means second year",
          "display_title": "Archon=year 1",
          "timestamp": "53:05"
        },
        {
          "title": "Concern: archon might have served multiple non-consecutive terms",
          "display_title": "Multiple terms",
          "timestamp": "53:22"
        },
        {
          "title": "Distinction: archon (first term) vs. archon digon (reelected for second term)",
          "display_title": "Term designation",
          "timestamp": "54:49"
        }
      ]
    },
    {
      "title": "Greek Geometric Terms Applied to Nazir Vows and Ritual Impurity",
      "display_title": "Greek geometry terms",
      "timestamp": "55:11",
      "micro_segments": [
        {
          "title": "Greek number-shape terminology: acta (one), digon (two), trigon (three), tetragon (four), pentagon (five)",
          "display_title": "Shape-number terms",
          "timestamp": "55:11"
        },
        {
          "title": "Application to Nazir vows: accepting multiple periods of nazirite sanctity",
          "display_title": "Nazir multiplicity",
          "timestamp": "55:14"
        },
        {
          "title": "House impurity rules: only four-cornered (tetragon) houses susceptible to leprosy impurity",
          "display_title": "Four corners needed",
          "timestamp": "56:07"
        },
        {
          "title": "Biblical source: verses mentioning walls (plural) imply four walls and corners",
          "display_title": "Four walls source",
          "timestamp": "56:42"
        }
      ]
    }
  ],
