  "amud": "a-b",
  "macro_segments": [
    {
      "title": "Introduction and Overview of the Sugya on Gezeirot",
      "display_title": "Intro & Overview",
      "timestamp": "00:00",
      "micro_segments": [
        {
          "title": "Course introduction and scope of daf yud aleph",
          "display_title": "Course Intro",
          "timestamp": "00:00"
        },
        {
          "title": "Framework: when do we make gezeirot to prevent violation of d'oraita",
          "display_title": "Gezeira Framework",
          "timestamp": "01:05"
        }
      ]
    },
    {
      "title": "The Mishnah on Bedika Chametz and Rabbi Yehuda vs. Chachamim Debate",
      "display_title": "Mishna Bedika Chametz",
      "timestamp": "03:05",
      "micro_segments": [
        {
          "title": "Mishnah on yud amud bet: Rabbi Yehuda's three times for bedika versus Chachamim's position",
          "display_title": "Three Times for Bedika",
          "timestamp": "03:05"
        },
        {
          "title": "Gemara: disagreement about timing—Rabbi Yehuda vs. Chachamim really discussing when bedika must stop",
          "display_title": "When Bedika Ends",
          "timestamp": "05:26"
        }
      ]
    },
    {
      "title": "The Principle of Gezeira: When One Might Come to Consume Prohibited Matter",
      "display_title": "Gezeira & Consumption",
      "timestamp": "06:34",
      "micro_segments": [
        {
          "title": "Rabbi Yehuda's position: gezeira dilma ati l'meichal minei—fear one will consume chametz after prohibition",
          "display_title": "Dilma Ati L'Meichal",
          "timestamp": "06:34"
        },
        {
          "title": "Contradiction from Menachot: grain preparation in marketplace without gezeira according to Rabbi Yehuda",
          "display_title": "Chadash Counterexample",
          "timestamp": "07:01"
        }
      ]
    },
    {
      "title": "Rava's Answer: Shinuy and Zachor—The Role of Differentiated Process",
      "display_title": "Rava: Shinuy & Zachor",
      "timestamp": "09:11",
      "micro_segments": [
        {
          "title": "Rava proposes shinuy (different method) in harvesting reminds one and obviates gezeira",
          "display_title": "Shinuy in Harvesting",
          "timestamp": "09:11"
        },
        {
          "title": "Abaye challenges: what about later stages—grinding and sifting without obvious shinuy",
          "display_title": "Abaye's Challenge",
          "timestamp": "12:35"
        },
        {
          "title": "Gemara resolves: shinuy also present in grinding (hand mill) and sifting (reversed sifter)",
          "display_title": "Shinuy Resolved",
          "timestamp": "13:39"
        }
      ]
    },
    {
      "title": "Second Counterexample: Harvesting Fields Not Suitable for Omer",
      "display_title": "Harvesting Non-Omer Fiel…",
      "timestamp": "16:13",
      "micro_segments": [
        {
          "title": "Mishnah allows harvesting from irrigated and valley fields without shinuy—objection to Rava",
          "display_title": "Ella Hadetnan Kashya",
          "timestamp": "16:13"
        },
        {
          "title": "Abaye's revised answer: chadash has built-in separateness (badil minei), doesn't need gezeira",
          "display_title": "Abaye: Badil Minei",
          "timestamp": "19:17"
        }
      ]
    },
    {
      "title": "Rav Ashi's Technical Attempt and Its Rejection",
      "display_title": "Rav Ashi Rejected",
      "timestamp": "24:43",
      "micro_segments": [
        {
          "title": "Rav Ashi: flour and roasted grain in marketplace not edible—no gezeira needed",
          "display_title": "Technical Non-Edibility",
          "timestamp": "24:43"
        },
        {
          "title": "Gemara rejects Rav Ashi as beduta—position unfounded given grain is edible in some forms",
          "display_title": "Beduta Hi Rejection",
          "timestamp": "26:24"
        }
      ]
    },
    {
      "title": "Expanding the Framework: Badil Minei as the Central Organizing Principle",
      "display_title": "Badil Minei Framework",
      "timestamp": "30:37",
      "micro_segments": [
        {
          "title": "Question: Does Rabbi Yehuda make gezeira everywhere we DON'T separate from items (lo badil minei)?",
          "display_title": "Lo Badil Minei Question",
          "timestamp": "30:37"
        },
        {
          "title": "Counterexample—oil feeder in lamp on Shabbat: Chachamim strict, Rabbi Yehuda lenient",
          "display_title": "Shfoferet Shel Beitza",
          "timestamp": "31:39"
        },
        {
          "title": "Resolution: Chumra d'Shabbat causes separateness (badil minei) even for oil; no gezeira needed",
          "display_title": "Chumra d'Shabbat",
          "timestamp": "36:23"
        }
      ]
    },
    {
      "title": "Tangential Sub-Discussion: Tying and Looping on Shabbat",
      "display_title": "Kesher vs. Aniva",
      "timestamp": "40:03",
      "micro_segments": [
        {
          "title": "Baraita on tying a bucket with rope on Shabbat: Chachamim prohibit knots, allow loop; Rabbi Yehuda stricter",
          "display_title": "Bucket Rope Dispute",
          "timestamp": "40:03"
        },
        {
          "title": "Resolution: oil is oil (shemen b'shemen michlaf) but looping ≠ tying (aniva b'keshira lo michlaf)",
          "display_title": "Shemen vs. Aniva",
          "timestamp": "42:12"
        }
      ]
    },
    {
      "title": "Reverse Question: When We DO Separate From Items, Is Gezeira Unnecessary?",
      "display_title": "Badil Minei Question",
      "timestamp": "47:02",
      "micro_segments": [
        {
          "title": "Baraita on bechor with excess blood: Rabbi Yehuda forbids bloodletting; Chachamim allow if no mum created",
          "display_title": "Bechor Bloodletting",
          "timestamp": "47:02"
        },
        {
          "title": "Explanation: Adam bahul al mamono (anxiety about money) overrides badil minei; gezeira needed",
          "display_title": "Adam Bahul al Mamono",
          "timestamp": "49:08"
        },
        {
          "title": "Counterargument—Chachamim: giving permissible option relieves anxiety better than total prohibition",
          "display_title": "Chachamim Pragmatism",
          "timestamp": "51:59"
        }
      ]
    },
    {
      "title": "Final Counterexample: Combing Animals on Yom Tov",
      "display_title": "Kidur vs. Kartsuf",
      "timestamp": "53:29",
      "micro_segments": [
        {
          "title": "Mishnah and baraita on animal grooming methods: fine-tooth (kidur) vs. wide-tooth (kartsuf) combs",
          "display_title": "Combing Methods",
          "timestamp": "53:29"
        },
        {
          "title": "Question: Why does Rabbi Yehuda allow one method but prohibits bedika after chametz time?",
          "display_title": "Comparative Gezeirot",
          "timestamp": "56:29"
        },
        {
          "title": "Resolution: Bread exchanges easily (lechem b'lechem michlaf) but combing methods do not (lo michlaf)",
          "display_title": "Lechem vs. Kidur",
          "timestamp": "57:08"
        }
      ]
    },
    {
      "title": "Summary: Broader Framework for Gezeirot and Multiple Factors in Decision-Making",
      "display_title": "Summary & Framework",
      "timestamp": "57:27",
      "micro_segments": [
        {
          "title": "Abaye's overall principle: gezeira needed when interaction with item risks d'oraita violation and item is not naturally separated from",
          "display_title": "Abaye's Synthesis",
          "timestamp": "57:27"
        },
        {
          "title": "Multiple factors emerge: badil minei, chumra of particular area, adam bahul al mamono, item interchangeability",
          "display_title": "Multiple Factors",
          "timestamp": "57:27"
        }
      ]
    }
  ],
