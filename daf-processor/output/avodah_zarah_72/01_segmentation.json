    {
      "title": "Central Debate: Is Nitzok a Chibur (Connection) for Yayin Nesech?",
      "display_title": "Nitzok Chibur Debate",
      "timestamp": "25:54",
      "micro_segments": [
        {
          "title": "Rav Huna: nitzok may be chibur for yayin nesech even if not for tumah and taharah",
          "display_title": "Rav Huna Position",
          "timestamp": "25:54"
        },
        {
          "title": "Rav Nachman's challenge: Mishnah says nitzok is not chibur for tumah and taharah",
          "display_title": "Rav Nachman Challenge",
          "timestamp": "26:07"
        },
        {
          "title": "Response: cannot infer from one mishnah about tumah to yayin nesech issues",
          "display_title": "Inference Problem",
          "timestamp": "27:16"
        },
        {
          "title": "Rabbi Chiya's baraita: wine becoming forbidden only if vessel splashes back into funnel",
          "display_title": "Rabbi Chiya Baraita",
          "timestamp": "28:27"
        },
        {
          "title": "Gemara: if wine doubled back, definitely forbidden; if not, uncertain from baraita",
          "display_title": "Doubling Back Case",
          "timestamp": "29:28"
        },
        {
          "title": "Second mishnah case: pouring from one vessel to another—what remains in source is permitted",
          "display_title": "Second Mishnah",
          "timestamp": "31:05"
        },
        {
          "title": "Gemara examines whether midair stream is forbidden (nitzok question)",
          "display_title": "Midair Stream Status",
          "timestamp": "32:00"
        },
        {
          "title": "If stream was broken before hitting receiving vessel, source remains permitted",
          "display_title": "Stream Breaking",
          "timestamp": "34:11"
        },
        {
          "title": "Gemara: mishnah does not clearly prove nitzok is chibur because status of midair is ambiguous",
          "display_title": "Ambiguity Conclusion",
          "timestamp": "35:32"
        }
      ]
    },
