      "title": "Principle of Status at Beginning of Shabbat: What Begins Permitted Remains Permitted; What Begins Forbidden Remains Forbidden—Exception of Bittul Reshut",
      "display_title": "Status at Shabbat Start",
      "timestamp": "31:37",
      "micro_segments": [
        {
          "title": "General Principle: Things That Begin Permissible Remain Permissible Throughout Shabbat",
          "display_title": "Begin Permitted",
          "timestamp": "31:37"
        },
        {
          "title": "Examples: Eruv Through Door or Window Sealed on Shabbat—Remains Valid Because Valid at Start",
          "display_title": "Sealed Openings",
          "timestamp": "32:13"
        },
        {
          "title": "Walls Removed on Shabbat: Permissibility Continues if Started with Valid Eruv",
          "display_title": "Walls Fall",
          "timestamp": "32:27"
        },
        {
          "title": "Inverse Principle: Things That Begin Forbidden Remain Forbidden Throughout Shabbat",
          "display_title": "Begin Forbidden",
          "timestamp": "33:09"
        },
        {
          "title": "Example: Non-Jews Build Wall Around Public Domain on Shabbat—Cannot Do Bittul Because Never Started Permitted",
          "display_title": "Wall Built on Shabbat",
          "timestamp": "33:25"
        },
        {
          "title": "Exception: Bittul Reshut Uniquely Allows Change from Forbidden to Permitted Mid-Shabbat",
          "display_title": "Bittul Exception",
          "timestamp": "33:37"
        }
      ]
