        {
          "title": "Introduction to pre-written get and loan document forms",
          "display_title": "Pre-written Forms",
          "timestamp": "00:38"
        },
        {
          "title": "Requirement to leave blanks for essential details in all document types",
          "display_title": "Leaving Blanks",
          "timestamp": "01:06"
        },
        {
          "title": "Concern about whether leaving blanks is a lishmah requirement or practical necessity",
          "display_title": "Lishmah Concern",
          "timestamp": "01:43"
        },
        {
          "title": "Loan documents (shtarei malveh) requiring blank spaces for lender, debtor, amount, and date",
          "display_title": "Loan Documents",
          "timestamp": "01:54"
        },
