{
  "masechta": "Menachot",
  "daf": 17,
  "amud": "a-b",
  "macro_segments": [
    {
      "title": "Piggul from Multiple Small Portions of the Kometz: The Three-Way Amoraic Debate",
      "display_title": "Piggul & Shiyarim",
      "timestamp": "00:14",
      "micro_segments": [
        {
          "title": "Introduction to the Case: Offering the Kometz One Grain at a Time with Intent to Eat Shiyarim",
          "display_title": "Sesame-Grain Offering",
          "timestamp": "00:14"
        },
        {
          "title": "The Three-Way Debate of Rav Chisda, Rav Hamnuna, and Rav Sheshes: Piggul, Passul, or Kasher",
          "display_title": "Chisda/Hamnuna/Sheshes",
          "timestamp": "01:54"
        },
        {
          "title": "Matching Opinions to Tannaim: Piggul According to Rebbi Meir (Mefaglin b'Chatzi Matir)",
          "display_title": "Rebbi Meir Position",
          "timestamp": "02:14"
        },
        {
          "title": "Passul According to Rabbanan: Rejecting Mefaglin b'Chatzi Matir",
          "display_title": "Rabbanan Position",
          "timestamp": "04:05"
        },
        {
          "title": "Kasher According to Rebbi: Separate Half-Kezayis Portions Don't Combine",
          "display_title": "Rebbi Position",
          "timestamp": "04:22"
        },
        {
          "title": "Gemara's Refinement: Each Opinion Could Work for All Tannaim Under Different Conditions",
          "display_title": "Conditional Analysis",
          "timestamp": "05:01"
        },
        {
          "title": "Three Positions Restated: Piggul, Passul, or Kasher Work for All According to Rav Adda bar Ahava",
          "display_title": "All Three Valid",
          "timestamp": "08:36"
        },
        {
          "title": "Position One: Piggul When Derech Haktara and Achila are Valid",
          "display_title": "Piggul Analysis",
          "timestamp": "09:02"
        },
        {
          "title": "Position Two: Passul When Haktara is Not a Valid Method (Ein Derech Haktara)",
          "display_title": "Passul Analysis",
          "timestamp": "10:35"
        },
        {
          "title": "Position Three: Kasher When Haktara is Valid But Eating Pattern Doesn't Constitute Achila",
          "display_title": "Kasher Analysis",
          "timestamp": "11:18"
        }
      ]
    },
    {
      "title": "Haktara Mefagelet Haktara: Whether the Kometz Can Invalidate the Levona with Intent to Offer it Tomorrow",
      "display_title": "Haktara Debate",
      "timestamp": "12:32",
      "micro_segments": [
        {
          "title": "Charifei d'Pumbedita: Haktara of Kometz Creates Piggul if Intent is to Offer Levona Tomorrow",
          "display_title": "Pumbedita Opinion",
          "timestamp": "12:32"
        },
        {
          "title": "Challenge from Meshna: Haktara for Achila and Haktara for Haktara Should Both Work",
          "display_title": "Meshna Challenge",
          "timestamp": "15:46"
        },
        {
          "title": "Gemara's Response: Haktara Stage Only Involves Achila Intent, Not Intent to Offer Again",
          "display_title": "Gemara Response",
          "timestamp": "17:49"
        },
        {
          "title": "Rav Chisda's Opinion (via Rav Menashya): Ein Haktara Mefagelet Haktara",
          "display_title": "Chisda's Position",
          "timestamp": "18:26"
        },
        {
          "title": "Reasoning: Kometz and Levona Don't Relate to One Another—Both Matirim for Shiyarim",
          "display_title": "Non-Relation Logic",
          "timestamp": "19:03"
        },
        {
          "title": "Support from Two Lambs Case: Each Lamb is Not Matir for the Other",
          "display_title": "Two Lambs Proof",
          "timestamp": "21:23"
        },
        {
          "title": "Gemara's Counterpoint: The Two Lambs Are Not Joined in One Vessel",
          "display_title": "Vessel Unity Issue",
          "timestamp": "22:57"
        },
        {
          "title": "Rav Hamnuna: A Teaching from Rabbi Chanina Consolidating Both Chidushim",
          "display_title": "Hamnuna Synthesis",
          "timestamp": "23:48"
        },
        {
          "title": "Textual Analysis: Why Bundle Both Chidushim Together Rather Than State Separately",
          "display_title": "Text Structure",
          "timestamp": "26:40"
        },
        {
          "title": "Rav Adda bar Ahava: Neither Principle Works Alone, But Together They Create Piggul",
          "display_title": "Combined Principles",
          "timestamp": "27:25"
        }
      ]
    },
    {
      "title": "Intent to Eat or Offer Something Not Normally Eaten or Offered: The Position of Rebbi Eliezer",
      "display_title": "Wrong Category",
      "timestamp": "31:34",
      "micro_segments": [
        {
          "title": "Rebbi's Position: Intent to Eat Levona or Offer Shiyarim Makes it Kasher",
          "display_title": "Rebbi: Kasher",
          "timestamp": "31:34"
        },
        {
          "title": "Rebbi Eliezer's Dissent: Such Intent Makes it Passul (But Not Piggul)",
          "display_title": "Eliezer: Passul",
          "timestamp": "33:03"
        },
        {
          "title": "Exception: If Intent is Less Than a Kezayis, Even Rebbi Eliezer Agrees it's Kasher",
          "display_title": "Sub-Kezayis Exception",
          "timestamp": "33:03"
        },
        {
          "title": "Principle: Half-Kezayis Achila and Half-Kezayis Haktara Don't Combine",
          "display_title": "Non-Combination Rule",
          "timestamp": "33:32"
        },
        {
          "title": "Rabbi Assi's Explanation: Rebbi Eliezer Derives from the Double Language of 'Hachol Ye'achel'",
          "display_title": "Pasuk Basis",
          "timestamp": "34:37"
        },
        {
          "title": "Rebbi Eliezer's Interpretation: The Double Language Permits Crossing from Achila to Haktara",
          "display_title": "Eliezer's Reading",
          "timestamp": "36:02"
        },
        {
          "title": "Gemara's Clarification: The Pasuk Addresses Two Types of Achila, Not Category-Crossing",
          "display_title": "Pasuk Limits",
          "timestamp": "36:34"
        }
      ]
    },
    {
      "title": "Braita: Category-Crossing in Animal Sacrifices and the Debate of Rebbi Eliezer vs. Chachamim",
      "display_title": "Animal Sacrifice Cases",
      "timestamp": "40:00",
      "micro_segments": [
        {
          "title": "Tannaitic Dispute: Whether Rebbi Eliezer's Position is D'Oraita (Piggul) or D'Rabbanan (Passul)",
          "display_title": "D'Oraita vs Rabbanan",
          "timestamp": "40:00"
        },
        {
          "title": "Case 1: Intent to Drink Blood or Burn Flesh at Wrong Time Makes it Kasher for Chachamim",
          "display_title": "Drink/Burn Cases",
          "timestamp": "40:29"
        },
        {
          "title": "Rebbi Eliezer's Disagreement: Such Category-Crossing Makes it Passul",
          "display_title": "Eliezer Invalidates",
          "timestamp": "40:29"
        },
        {
          "title": "Case 2: Intent to Leave Blood Over (Lehaniach) Until Tomorrow",
          "display_title": "Lehaniach Case",
          "timestamp": "40:30"
        },
        {
          "title": "Rabbi Yehuda's View: Lehaniach is Passul but Distinct from the Rebbi Eliezer/Chachamim Debate",
          "display_title": "Yehuda's Distinction",
          "timestamp": "42:48"
        },
        {
          "title": "Rabbi Elazar's Counter-View: Lehaniach Falls Under the Same Debate as Category-Crossing",
          "display_title": "Elazar's Position",
          "timestamp": "43:21"
        },
        {
          "title": "Conclusion: Tannaitic Disagreement Reflects Uncertainty on Whether Rebbi Eliezer's Passul is D'Oraita or D'Rabbanan",
          "display_title": "Unresolved Status",
          "timestamp": "45:55"
        }
      ]
    }
  ],
