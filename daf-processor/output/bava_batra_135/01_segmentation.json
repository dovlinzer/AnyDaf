  "macro_segments": [
    {
      "title": "The Principle of Biyado Legarsha and Credibility in Matters of Family Status",
      "display_title": "Biyado Legarsha",
      "timestamp": "00:00",
      "micro_segments": [
        {
          "title": "Opening: The Mishna on Paternity Claims and the Scope of Credibility",
          "display_title": "Paternity Claims",
          "timestamp": "00:00"
        },
        {
          "title": "The Principle of Biyado Legarsha: Since He Can Divorce, He Is Believed About Yibum Status",
          "display_title": "Yibum Credibility",
          "timestamp": "01:38"
        },
        {
          "title": "Rav Yosef's Extension: A Husband Is Believed to Say He Divorced His Wife",
          "display_title": "Divorce Claim",
          "timestamp": "04:07"
        }
      ]
    },
    {
      "title": "The Debate Over Retroactive Divorce Claims and the Limits of Biyado Legarsha",
      "display_title": "Divorce Retroactivity",
      "timestamp": "05:55",
      "micro_segments": [
        {
          "title": "Rav Yitzchak Bar Yosef's Rejection: A Husband Is Not Believed to Say He Divorced His Wife",
          "display_title": "Yitzchak's Rejection",
          "timestamp": "05:55"
        },
        {
          "title": "Rashbam and Tosafos: The Principle Applies Only to Believable Claims, Not to Claims Contradicted by Absence of Evidence",
          "display_title": "Limited Application",
          "timestamp": "07:00"
        },
        {
          "title": "Resolution: Divorce Claims Work Prospectively, Not Retroactively—Lemafrea vs. Lehaba",
          "display_title": "Lemafrea Lehaba",
          "timestamp": "10:34"
        }
      ]
    },
    {
      "title": "The Question of Splitting a Divorce Claim Across Time: Can It Be Believed Going Forward If Stated Retroactively?",
      "display_title": "Splitting Words",
      "timestamp": "11:48",
      "micro_segments": [
        {
          "title": "The Shaila: If Someone Says 'I Divorced My Wife Last Week,' Can We Accept It As Valid From Today Forward?",
          "display_title": "Last Week Claim",
          "timestamp": "11:48"
        },
        {
          "title": "Mi Palginan Dibura: Do We Split His Words or Apply His Entire Statement As One Unit?",
          "display_title": "Split Application",
          "timestamp": "13:27"
        },
        {
          "title": "Comparison to Adultery Testimony: Can Testimony Be Split Between Defendants? Betrei Gufai vs. Chad Gufa",
          "display_title": "Adultery Parallel",
          "timestamp": "14:46"
        }
      ]
    },
    {
      "title": "The Case of the Dying Man's Ambiguous Statement About His Wife's Status",
      "display_title": "Dying Man Case",
      "timestamp": "20:40",
      "micro_segments": [
        {
          "title": "The Story: A Dying Man Says His Wife Can Marry Even the High Priest—Is He Claiming Divorce or Children?",
          "display_title": "Wife Status",
          "timestamp": "20:40"
        },
        {
          "title": "The Interpretation: We Read His Vague Statement to Mean Divorce, Not Children, to Avoid Contradicting the Chazaka",
          "display_title": "Vague Statement",
          "timestamp": "22:28"
        },
        {
          "title": "The Reversal: Abbaye Challenges This Reading; Rava Concedes We Must Be Concerned About the Alternative Interpretation",
          "display_title": "Abbaye Challenge",
          "timestamp": "24:01"
        }
      ]
    },
    {
      "title": "Parallel Case: The Dying Man Without Known Brothers and the Question of Future Concerns",
      "display_title": "No Brothers Case",
      "timestamp": "27:47",
      "micro_segments": [
        {
          "title": "The Story: A Man with No Known Brothers Claims He Has No Brothers as He Dies",
          "display_title": "Dying Claim",
          "timestamp": "27:47"
        },
        {
          "title": "The Problem: What If There Are Rumors of Witnesses in Distant Lands Who Know of a Brother?",
          "display_title": "Distant Witnesses",
          "timestamp": "30:10"
        },
        {
          "title": "The Principle: We Do Not Worry About Rumors of Future Evidence; the Chazaka and Current Claim Control",
          "display_title": "No Rumors",
          "timestamp": "31:31"
        },
        {
          "title": "Exception: If There Is Concrete Concern of Hard Evidence on a Weighty Matter, We May Need to Investigate",
          "display_title": "Concrete Concern",
          "timestamp": "33:56"
        }
      ]
    },
    {
      "title": "The Mishna's Second Part: When a Brother Claims Another Brother Exists, But the Other Brother Denies Knowledge",
      "display_title": "Brother Dispute",
      "timestamp": "35:11",
      "micro_segments": [
        {
          "title": "The Scenario: Reuven Claims Levi Is Their Brother; Shimon Says He Doesn't Know",
          "display_title": "Levi Claim",
          "timestamp": "35:11"
        },
        {
          "title": "The Ruling: Reuven Cannot Force Shimon to Give Levi a Share, But If Levi Dies, They Split His Estate",
          "display_title": "Inheritance Split",
          "timestamp": "36:00"
        },
        {
          "title": "The Explanation: Shimon Takes the Smart Position of 'I Don't Know,' Avoiding Claims While Preserving Inheritance Rights",
          "display_title": "Eini Yodeia",
          "timestamp": "37:08"
        },
        {
          "title": "Analysis: Reuven's Claim Alone Cannot Overcome Shimon's Chazaka; Property Only Follows from the Claimant's Own Position",
          "display_title": "Bari Veshema",
          "timestamp": "39:10"
        },
        {
          "title": "Follow-up Problem: If Levi Earned Money Separately, Both Brothers Inherit; But Property Reuven Gave Returns to Reuven",
          "display_title": "Return Property",
          "timestamp": "41:37"
        },
        {
          "title": "Unresolved Question: Does an Increase in Property Value Go Back to Reuven or Is It Shared?",
          "display_title": "Shevach Value",
          "timestamp": "42:45"
        }
      ]
    },
    {
      "title": "Introduction to the Will (Diatiki): The Requirements for a Deathbed Bequest in Written Form",
      "display_title": "Will Doctrine",
      "timestamp": "45:37",
      "micro_segments": [
        {
          "title": "The Concept: A Diatiki Is a Written Will, a Variation of the Oral Deathbed Bequest",
          "display_title": "Diatiki Defined",
          "timestamp": "45:37"
        },
        {
          "title": "The Mishna: A Will Bound on a Dying Man's Thigh Has No Effect Until It Is Handed Over",
          "display_title": "No Effect",
          "timestamp": "48:43"
        },
        {
          "title": "The Rule: Zichah Bah Leacher—Once the Will Is Handed Over, It Becomes Binding, Regardless of Who Receives It",
          "display_title": "Handed Over",
          "timestamp": "49:16"
        },
        {
          "title": "Why Written Is Different from Oral: A Will Requires Execution; an Oral Bequest Does Not",
          "display_title": "Execution Required",
          "timestamp": "50:21"
        }
      ]
    }
