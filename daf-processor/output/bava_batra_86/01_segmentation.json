      "micro_segments": [
        {
          "title": "Mishnah in Kiddushin: Chattels Are Acquired Only Through Meshicha, Not Money or Document",
          "display_title": "Chattels via Meshicha",
          "timestamp": "03:51"
        },
        {
          "title": "Teaching from Sura/Pumbedita: Meshicha Works Only for Things Not Naturally Lifted; Hagbaha for Things Naturally Lifted",
          "display_title": "Hagbaha vs Meshicha",
          "timestamp": "04:40"
        },
        {
          "title": "Abaye Teaches the Baraita on Wallet Theft: Hagbaha for Small Wallets, Meshicha for Heavy Bags with Ropes",
          "display_title": "Wallet Theft",
          "timestamp": "06:13"
        },
        {
          "title": "Rav Nachman bar Yitzchak Resolves Apparent Contradiction: Different Objects Have Different Modes, Not the Same Object Multiple Modes",
          "display_title": "Different Objects",
          "timestamp": "11:09"
        },
        {
          "title": "Gemara Applies the Teaching to Produce: Large Sacks of Apples via Meshicha, But Flax Requires Hagbaha Due to its Nature",
          "display_title": "Produce Cases",
          "timestamp": "12:32"
        },
        {
          "title": "Baraita on Animals: Large Animals via Mesira, Small Animals Debate Between Rabbi Meir and the Sages on Meshicha vs. Hagbaha",
          "display_title": "Animal Acquisition",
          "timestamp": "17:02"
        }
      ]
    },
    {
      "title": "Finality of Sale and Measurement: When a Sale Becomes Binding Based on Identified Units and Vessel Ownership",
      "display_title": "Sale Finality",
      "timestamp": "18:59",
      "micro_segments": [
        {
          "title": "Rav and Shmuel: Selling a Kor for a Single Lump Sum Means the Sale Is Reversible Until Full Measurement",
          "display_title": "Kor Lump Sum",
          "timestamp": "18:59"
        },
        {
          "title": "Contrast Case: Selling a Kor by Individual Seah Units Makes Each Seah a Separate Sale, Final Upon Each Measurement",
          "display_title": "Per-Unit Pricing",
