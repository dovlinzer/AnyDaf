    {
      "title": "Gemara Analysis: Why Father-to-Son Inheritance is Listed First Despite Being Explicit in Scripture",
      "display_title": "Order Question",
      "timestamp": "24:23",
      "micro_segments": [
        {
          "title": "Question: why does Mishnah list father-to-sons transmission before sons-to-father if both are in the same category",
          "display_title": "Why Order",
          "timestamp": "24:23"
        },
        {
          "title": "Answer: principle that tragic occurrences (children predeceasing parents) should not be mentioned first",
          "display_title": "Tragic First?",
          "timestamp": "26:08"
        },
        {
          "title": "Additional proof: father-to-son is explicit in Torah, while son-to-father requires derasha, yet son-to-father is not listed first because it represents tragic circumstance",
          "display_title": "Derasha vs Tragic",
          "timestamp": "27:48"
        }
      ]
    },
    {
      "title": "Derivation of Inheritance Hierarchy from Scripture: Father, Daughter, and Brother",
      "display_title": "Hierarchy From Pesukim",
      "timestamp": "29:05",
      "micro_segments": [
        {
          "title": "Midrashic interpretation of \"shero\" (relative) to mean father, establishing father as primary heir",
          "display_title": "Father Priority",
          "timestamp": "29:05"
        },
        {
          "title": "General principle of \"korov korov kodem\": closer relative inherits first",
          "display_title": "Closest First",
          "timestamp": "30:02"
        },
        {
          "title": "Scriptural source from case where man dies without son: property goes to daughter or brothers",
          "display_title": "Script Sources",
          "timestamp": "30:02"
        }
      ]
    },
    {
      "title": "Determining Hierarchy Between Son and Brother: Evidence from Ye'udah and Ancestral Fields",
      "display_title": "Son vs Brother",
      "timestamp": "32:45",
      "micro_segments": [
        {
          "title": "Question: How do we know son is closer relative than brother if both are possible heirs",
          "display_title": "Relative Distance",
          "timestamp": "32:45"
        },
        {
          "title": "First evidence: son fills father's role in ye'udah (indentured woman) and ancestral fields (sdei achuza)",
          "display_title": "Role Filling",
          "timestamp": "33:03"
        },
        {
          "title": "Contrast with brother filling role in yibum (levirate marriage)",
          "display_title": "Brother Yibum",
          "timestamp": "35:58"
        },
        {
          "title": "Proof that son is closer than brother: yibum does not apply when there is a son, limiting brother's role",
          "display_title": "Yibum Limitation",
          "timestamp": "37:34"
        },
        {
          "title": "Rhetorical conclusion: two arenas privilege son (ye'udah and sdei achuza) versus one for brother (yibum)",
          "display_title": "Two Against One",
          "timestamp": "38:12"
        }
      ]
    },
    {
      "title": "Property Flow and Daughter's Inheritance: Establishing Downstream vs. Upstream Principles",
      "display_title": "Property Flow",
      "timestamp": "39:13",
      "micro_segments": [
        {
          "title": "General principle: inheritance flows downhill to children before flowing uphill to parents or sideways to siblings",
          "display_title": "Downhill Flow",
          "timestamp": "39:13"
        },
        {
          "title": "Example of daughter inheriting when no sons exist and property passing to her children",
          "display_title": "Daughter Case",
          "timestamp": "39:18"
        },
        {
          "title": "Explanation of how property reverts to father's side when there is no downstream heir",
          "display_title": "Revert to Father",
          "timestamp": "40:07"
        }
      ]
    }
