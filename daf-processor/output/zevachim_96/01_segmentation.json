{
  "masechta": "Zevachim",
  "daf": 96,
  "amud": "a",
  "macro_segments": [
    {
      "title": "Absorption (Blia'ah) versus Cooking (Bishul) in Vessel Kashrut: The Pottery Oven Question",
      "display_title": "Blia'ah vs. Bishul",
      "timestamp": "00:00",
      "micro_segments": [
        {
          "title": "Review of Prior Discussion: Pouring (Iruy) as Blia'ah but Not Bishul",
          "display_title": "Iruy & Blia'ah",
          "timestamp": "00:00"
        },
        {
          "title": "Suspended Food in an Oven: No Blia'ah but Yes Bishul",
          "display_title": "Oven: No Blia'ah",
          "timestamp": "01:05"
        },
        {
          "title": "Pottery Ovens Can Be Kashered by Internal Fire Like a Kiln",
          "display_title": "Pottery Oven Kasher",
          "timestamp": "01:27"
        }
      ]
    },
    {
      "title": "Why Pottery Vessels Were Broken Rather Than Kashered in the Mikdash",
      "display_title": "Pottery Breaking",
      "timestamp": "02:10",
      "micro_segments": [
        {
          "title": "The Gemara's Question: If Pottery Can Be Kashered, Why Does the Torah Require Breaking It?",
          "display_title": "Kasher vs. Break",
          "timestamp": "02:10"
        },
        {
          "title": "Rashi's Answer: Breaking Is Required Because the Model Is Absorption (Blia'ah), Not Mere Kashrut",
          "display_title": "Rashi: Blia'ah Model",
          "timestamp": "05:21"
        },
        {
          "title": "Tosafot's Position: The Core Model Is Absorption, but Cooking Without Absorption Is Treated As If It Were Absorption",
          "display_title": "Tosafot: Include Bishul",
          "timestamp": "06:17"
        },
        {
          "title": "Rashi's Practical Explanation: No Kilns in Yerushalayim During the Wilderness Period",
          "display_title": "No Kilns in Yerushalayim",
          "timestamp": "10:17"
        },
        {
          "title": "Tosafot's Alternative: Breaking Is Actually a Leniency Because It Allows Non-Destruction of Taste",
          "display_title": "Breaking as Leniency",
          "timestamp": "10:49"
        },
        {
          "title": "Abaye's Question: If Breaking Creates Shards, Why Not Make a Kiln?",
          "display_title": "Abaye's Question",
          "timestamp": "12:46"
        },
        {
          "title": "Rav Shmaya's Answer: The Broken Shards Are Absorbed in Place Miraculously",
          "display_title": "Shards Absorbed",
          "timestamp": "13:15"
        }
      ]
    },
    {
      "title": "Metal Ovens in the Mikdash: Why Pottery Ovens Were Not Used Despite Kashrability",
      "display_title": "Metal vs. Pottery",
      "timestamp": "14:02",
      "micro_segments": [
        {
          "title": "Statement: The Mikdash Had a Metal Oven, Not a Pottery One",
          "display_title": "Metal Oven in Mikdash",
          "timestamp": "14:02"
        },
        {
          "title": "Question: If Pottery Can Be Kashered, Why Not Use a Pottery Oven?",
          "display_title": "Why Metal Only?",
          "timestamp": "14:08"
        },
        {
          "title": "Answer: The Kli Shares (Showbread and Special Breads) Required a Metal Vessel",
          "display_title": "Kli Shares Requirement",
          "timestamp": "15:17"
        },
        {
          "title": "Explanation: Pottery Cannot Be Used as a Kli Shares (Sacred Utensil)",
          "display_title": "Pottery Not Kli Shares",
          "timestamp": "15:50"
        }
      ]
    },
    {
      "title": "The Story of Rav Yitzchak bar Yehuda: Relying on Logic (Svara) versus Textual Authority",
      "display_title": "Svara vs. Text",
      "timestamp": "19:04",
      "micro_segments": [
        {
          "title": "Rav Yitzchak Leaves Rami bar Hama for Rav Sheshet; Rami Confronts Him",
          "display_title": "Leaving Rami",
          "timestamp": "19:04"
        },
        {
          "title": "Rav Yitzchak's Complaint: Rami Bar Hama Answers from Logic Alone, Leading to Contradictions",
          "display_title": "Logic Contradicted",
          "timestamp": "20:33"
        },
        {
          "title": "Rav Yitzchak's Preference: Rav Sheshet Grounds Answers in Textual Sources (Braitot)",
          "display_title": "Rav Sheshet & Texts",
          "timestamp": "21:09"
        },
        {
          "title": "Rami Bar Hama's Boast: His Logic Will Be Supported by Braitot",
          "display_title": "Rami's Defense",
          "timestamp": "23:49"
        }
      ]
    },
    {
      "title": "Rami Bar Hama's Test: Cooking in Part of a Vessel (Bishul BeMiktzat HaKli)",
      "display_title": "Bishul BeMiktzat",
      "timestamp": "24:16",
      "micro_segments": [
        {
          "title": "Rami's Question: Must Scalding and Rinsing Be Done on the Whole Pot or Only Where Food Was Cooked?",
          "display_title": "Whole vs. Part",
          "timestamp": "24:16"
        },
        {
          "title": "Rami's Logic: Comparison to Blood on Garments—Only the Affected Area Needs Treatment",
          "display_title": "Blood Analogy",
          "timestamp": "24:50"
        },
        {
          "title": "Rav Yitzchak's Objection: The Analogy Fails Because Taste Spreads Throughout the Pot",
          "display_title": "Taste Spreads",
          "timestamp": "26:06"
        },
        {
          "title": "Rav Yitzchak Produces a Braita Proving Rami Wrong: Scalding Must Cover the Entire Vessel",
          "display_title": "Braita: Whole Vessel",
          "timestamp": "26:46"
        },
        {
          "title": "Rami's Concession: 'If There Is a Braita, There Is a Braita'",
          "display_title": "Rami Concedes",
          "timestamp": "28:32"
        }
      ]
    },
    {
      "title": "Grounding the Kashering Law in Verse: Why the Whole Pot Must Be Treated",
      "display_title": "Verse Basis",
      "timestamp": "29:30",
      "micro_segments": [
        {
          "title": "Rather than Explain the Reason Logically, the Gemara Cites a Verse as the Real Basis",
          "display_title": "Verse Foundation",
          "timestamp": "29:30"
        },
        {
          "title": "Verse Analysis: 'If It Was Cooked in a Vessel' (Veim Bekli Nechoshes Bushala)",
          "display_title": "Nechoshes Verse",
          "timestamp": "29:50"
        }
      ]
    },
    {
      "title": "Scope of Scalding and Rinsing: Offerings Beyond the Sin Offering (Chattat)",
      "display_title": "Scope of Offerings",
      "timestamp": "30:26",
      "micro_segments": [
        {
          "title": "Tannaitic Dispute: Rabbi Yehuda Extends to All Holy Things; Rabbi Shimon Limits to Holy of Holies",
          "display_title": "Yehuda vs. Shimon",
          "timestamp": "30:26"
        },
        {
          "title": "Rabbi Yehuda's Reasoning: The Word 'Otah' (It) Is Needed to Exclude Terumah, Showing Broader Application",
          "display_title": "Otah Exclusion",
          "timestamp": "30:49"
        },
        {
          "title": "Rabbi Shimon's Counter: The Word 'Otah' Applies to an Earlier Law About the Blood, Not This Cooking Law",
          "display_title": "Shimon's Counter",
          "timestamp": "32:54"
        }
      ]
    },
    {
      "title": "Clarifying the Distinction: The Ritual's Requirements Versus Normal Kashering Procedures",
      "display_title": "Ritual vs. Kasher",
      "timestamp": "34:05",
      "micro_segments": [
        {
          "title": "Question: Does Terumah Require Scalding and Rinsing Like Other Offerings?",
          "display_title": "Terumah Kashering",
          "timestamp": "34:05"
        },
        {
          "title": "Braita: General Absorption Law—Meat Pots Cannot Cook Milk; Terumah Pots Cannot Cook Non-Terumah",
          "display_title": "Absorption Principle",
          "timestamp": "34:20"
        },
        {
          "title": "Abaye's Answer: The Ritual Differs from Normal Kashering in Three Ways",
          "display_title": "Ritual Differs",
          "timestamp": "35:55"
        },
        {
          "title": "First Difference: The Ritual Requires Treating the Entire Vessel; Normal Kashering Only Up to the Point of Use",
          "display_title": "Entire vs. Used",
          "timestamp": "35:55"
        },
        {
          "title": "Second Difference: The Ritual Specifically Requires Water; Normal Kashering Can Use Other Liquids",
          "display_title": "Water Only",
          "timestamp": "38:53"
        },
        {
          "title": "Third Difference: The Ritual Includes a Cold Rinse at the End; Normal Kashering Ends with Hot Water",
          "display_title": "Cold Rinse",
          "timestamp": "41:13"
        }
      ]
    },
    {
      "title": "The Mishnah on Scalding and Rinsing: Methods and Vessels",
      "display_title": "Mishna: Methods",
      "timestamp": "43:10",
      "micro_segments": [
        {
          "title": "Rabbi Tarfon: If You Begin Using a Pot at the Start of a Holiday, You Can Use It Throughout Without Kashering",
          "display_title": "Tarfon: Holiday Use",
          "timestamp": "43:10"
        },
        {
          "title": "Sages' View: The Pot Must Be Processed at the End of the Eating Time, Regardless of Holiday Status",
          "display_title": "Sages: End Eating",
          "timestamp": "43:40"
        },
        {
          "title": "Mishnah: Scalding (Merika) Is Like Rinsing the Inside of a Cup; Rinsing (Shtifa) Is Like Rinsing the Outside",
          "display_title": "Cup Analogy",
          "timestamp": "43:55"
        },
        {
          "title": "Both Scalding and Rinsing Use Cold Water (Tzonen) According to This Mishna",
          "display_title": "Cold Water",
          "timestamp": "44:06"
        },
        {
          "title": "Spits and Grills: These Are Immersed in Hot Water (Hagala) Rather Than Scalded and Rinsed",
          "display_title": "Spits & Hagala",
          "timestamp": "44:32"
        }
      ]
    }
