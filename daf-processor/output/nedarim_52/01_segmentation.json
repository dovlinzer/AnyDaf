    {
      "title": "Meat, gravy, and the principle of noten ta'am (imparting flavor)",
      "display_title": "Meat & Flavor",
      "timestamp": "04:53",
      "micro_segments": [
        {
          "title": "Neder against meat permits gravy and cracklings under ordinary circumstances",
          "display_title": "Meat/Gravy Rule",
          "timestamp": "04:53"
        },
        {
          "title": "Rabbi Yose forbids gravy and cracklings because they contain meat flavor and substance",
          "display_title": "Rabbi Yose Opinion",
          "timestamp": "06:02"
        },
        {
          "title": "Rabbi Yehuda's proof from Rabbi Tarfon: eggs cooked with meat are forbidden if person takes neder on that meat",
          "display_title": "Rabbi Tarfon Case",
          "timestamp": "06:13"
        },
        {
          "title": "Clarification: noten ta'am applies only when you say 'this meat' specifically, not 'meat' in general",
          "display_title": "Noten Ta'am Scope",
          "timestamp": "07:49"
        }
      ]
    },
    {
      "title": "Wine and the distinction between the substance and its flavor",
      "display_title": "Wine & Flavor",
      "timestamp": "09:42",
      "micro_segments": [
        {
          "title": "Neder against wine: permitted to eat a dish prepared with wine as an ingredient",
          "display_title": "Wine Dishes",
          "timestamp": "09:42"
        },
        {
          "title": "If you say 'this wine' specifically and it falls into food, it is forbidden if it imparts flavor",
          "display_title": "This Wine",
          "timestamp": "11:19"
        },
        {
          "title": "Discussion of stam yeinam (wine handled by non-Jews) and its halakhic restrictions",
          "display_title": "Stam Yeinam",
          "timestamp": "12:16"
        },
        {
          "title": "Custom during the nine days not to eat meat: application to chicken broth and fleishig dishes",
          "display_title": "Nine Days Custom",
          "timestamp": "15:05"
        }
      ]
    },
