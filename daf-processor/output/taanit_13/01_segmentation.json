  "macro_segments": [
    {
      "title": "Private Fasting (Ta'anit Yachid): Acceptance, Duration, and Deferment",
      "display_title": "Private Fasting Rules",
      "timestamp": "02:01",
      "micro_segments": [
        {
          "title": "Three components of private fasting: kabbalah mibe'od yom, duration through day's end, and borrowing/deferment",
          "display_title": "Components of Ta'anit Ya…",
          "timestamp": "02:01"
        },
        {
          "title": "Shmuel's position: private fasting lacks binding force; only good intentions without obligation",
          "display_title": "Shmuel's Non-Binding View",
          "timestamp": "02:13"
        },
        {
          "title": "Alternative version of Shmuel: fasting is comparable to a vow (neder) that can be deferred to another day",
          "display_title": "Shmuel's Vow Analogy",
          "timestamp": "04:43"
        },
        {
          "title": "Biblical vs. rabbinic categories of vows; nidrei mitzvah and the flexibility of vow fulfillment",
          "display_title": "Types of Vows",
          "timestamp": "05:39"
        },
        {
          "title": "Story of Rav Yehoshua at Rav Ashi's house: offered a steak while fasting; told he can borrow and repay the fast another day",
          "display_title": "Steak Story",
          "timestamp": "09:23"
        },
        {
          "title": "Ta'anit chalom (fast for bad dreams): exception requiring immediate fulfillment; cannot be deferred",
          "display_title": "Dream Fasting Exception",
          "timestamp": "11:57"
        },
        {
          "title": "Tosafos qualifications: borrowing permitted only if unable to fast; disputes whether already-begun fasts can be deferred",
          "display_title": "Tosafos Limitations",
          "timestamp": "15:10"
        }
      ]
    },
    {
      "title": "Communal Fasting (Ta'anit Tzibur): Escalation from Drought to Religious Crisis",
      "display_title": "Communal Fasting",
      "timestamp": "17:03",
      "micro_segments": [
        {
          "title": "Initial three daytime fasts by individuals; subsequent three full-blown fasts by community starting night before",
          "display_title": "Three-Plus-Three Fast Cy…",
          "timestamp": "17:03"
        },
        {
          "title": "Second set of three: full communal fasts with restrictions on labor, bathing, anointing, shoes, and marital relations; closure of stores and bathhouses",
          "display_title": "Full-Blown Restrictions",
          "timestamp": "18:09"
        },
        {
          "title": "Seven additional fasts (thirteen total); public aspects include shofar blasts and store closures with Shabbat leniencies",
          "display_title": "Seven More Fasts",
          "timestamp": "19:08"
        },
        {
          "title": "Distinction between physical crisis (no rain) and spiritual crisis (God not answering); significance of na'anu",
          "display_title": "Crisis Escalation",
          "timestamp": "20:44"
        },
        {
          "title": "Shift from fasting to mourning practices (avelut) when thirteen fasts fail: decrease business, building, planting, betrothals, and greetings",
          "display_title": "Shift to Mourning",
          "timestamp": "26:02"
        },
        {
          "title": "Private fasters (yechidim) continue beyond communal cessation until Nissan ends; rain after Nissan is siman kelalah (negative sign)",
          "display_title": "Yechidim Persistence",
          "timestamp": "28:33"
        }
      ]
    },
    {
      "title": "Structure and Meaning of Communal Fast Days: Public Gathering, Community Repair, and Prayer",
      "display_title": "Fast Structure & Meaning",
      "timestamp": "31:35",
      "micro_segments": [
        {
          "title": "Prohibition of labor compared to Yom Tov: parallels sanctity and public assembly through cessation of work",
          "display_title": "Labor Prohibition",
          "timestamp": "31:35"
        },
        {
          "title": "Scriptural source from Isaiah: Kadshu tzom kir'u atzarah—sanctify fast, call assembly of gathering and elders",
          "display_title": "Scriptural Source",
          "timestamp": "32:10"
        },
        {
          "title": "Community inspection (meiyinin bemilei demata): determining wrongs in city governance and restitution needs",
          "display_title": "Community Inspection",
          "timestamp": "36:01"
        },
        {
          "title": "Distinction between restitution/justice and teshuva: fixing communal problems vs. interior repentance process",
          "display_title": "Justice vs. Repentance",
          "timestamp": "36:35"
        },
        {
          "title": "Liturgical structure of fast day: morning to noon (community repair), noon to afternoon (Torah reading), afternoon onward (prayer)",
          "display_title": "Liturgical Structure",
          "timestamp": "40:03"
        },
        {
          "title": "Priority of action before prayer: fixing wrongs precedes asking God for mercy and rain",
          "display_title": "Action Before Prayer",
          "timestamp": "40:43"
        },
        {
          "title": "Scriptural support from Ezra: addressing communal sin and wrongdoing before prayer; context of intermarriage and breach of covenant",
          "display_title": "Ezra Model",
          "timestamp": "42:00"
        }
      ]
    },
    {
      "title": "Categories of Self-Denial: Mourning (Avelut) vs. Fasting (Ta'anit) Restrictions",
      "display_title": "Mourning vs. Fasting",
      "timestamp": "44:43",
      "micro_segments": [
        {
          "title": "Two categories: avelut (mourning/tragedy-focused) and ta'anit (suffering/pleasure-denial focused)",
          "display_title": "Two Categories",
          "timestamp": "44:43"
        },
        {
          "title": "Avelut restrictions: forbidden both hot and cold water; examples include Tisha B'Av, actual mourning (avel)",
          "display_title": "Avelut Severity",
          "timestamp": "45:10"
        },
        {
          "title": "Ta'anit restrictions: hot water forbidden, cold water permitted; applies to communal fasts",
          "display_title": "Ta'anit Leniency",
          "timestamp": "45:44"
        },
        {
          "title": "Reasoning: avelut represents heightened personal tragedy; ta'anit focuses on self-denial rather than demonstrations of misery",
          "display_title": "Reasoning",
          "timestamp": "46:16"
        },
        {
          "title": "Bathhouse closure in ta'anit emphasizes hot water prohibition; bathhouses as steam facilities",
          "display_title": "Bathhouse Closure",
          "timestamp": "49:53"
        },
        {
          "title": "Braita evidence: people obligated to go to mikvah on Tisha B'Av prove even cold water is forbidden for avelut",
          "display_title": "Mikvah Braita",
          "timestamp": "51:41"
        },
        {
          "title": "Ongoing discussion: whether hot/cold distinction applies to ta'anit; status of Yom Kippur as distinct category",
          "display_title": "Hot/Cold Status",
          "timestamp": "52:38"
        }
      ]
    }
  ],
