    {
      "title": "Admon's Second Ruling: Field Ownership and Witness Signature",
      "display_title": "Field & Witness",
      "timestamp": "17:11",
      "micro_segments": [
        {
          "title": "Case: one claims field stolen but signed as witness to sale document",
          "display_title": "Witness Problem",
          "timestamp": "17:11"
        },
        {
          "title": "Admon: signing doesn't forfeit claim; can argue coercion or different motives",
          "display_title": "Admon Excuses",
          "timestamp": "20:01"
        },
        {
          "title": "חכמים disagree: signature as witness concedes field ownership",
          "display_title": "Chachamim Disagree",
          "timestamp": "20:04"
        },
        {
          "title": "Exception: judge validating signatures (vs. witness) doesn't concede content",
          "display_title": "Judge Exception",
          "timestamp": "22:56"
        },
        {
          "title": "Field used only as boundary marker: even Admon concedes implicitly",
          "display_title": "Boundary Marker",
          "timestamp": "24:33"
        }
      ]
    },
    {
      "title": "Coercion and Moda'a: When One Can Claim Forced Signature",
      "display_title": "Coercion Defense",
      "timestamp": "25:52",
      "micro_segments": [
        {
          "title": "When seller uses buyer's own field as marker: buyer can claim coercion",
          "display_title": "Own Field Used",
          "timestamp": "25:52"
        },
        {
          "title": "Counter-argument: should have issued moda'a (protestation) to witnesses",
          "display_title": "Moda'a Objection",
          "timestamp": "28:10"
        },
        {
          "title": "Response: moda'a impossible due to secrecy ('three people can't keep a secret')",
          "display_title": "Secrecy Problem",
          "timestamp": "29:10"
        }
      ]
    },
    {
      "title": "Case Application: Orphans and Field Inheritance with Implicit Admission",
      "display_title": "Orphans Case",
