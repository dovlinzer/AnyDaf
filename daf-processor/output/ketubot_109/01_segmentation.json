          "display_title": "Initial Ruling",
          "timestamp": "31:38"
        },
        {
          "title": "Guardian argues: father conceded only a small furrow, not entire field",
          "display_title": "Guardian Argument",
          "timestamp": "33:17"
        },
        {
          "title": "Rabbi Yochanan: can claim partial concession or later repurchase",
          "display_title": "Rabbi Yochanan",
          "timestamp": "38:17"
        },
        {
          "title": "Abaye affirms guardian's argument; praises skill of defending orphans' interests",
          "display_title": "Abaye's Praise",
          "timestamp": "38:47"
        }
      ]
    },
