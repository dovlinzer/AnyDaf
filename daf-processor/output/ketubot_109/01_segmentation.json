      "title": "Admon's Third Ruling: Lost Access Path to Enclosed Field",
      "display_title": "Lost Path",
      "timestamp": "40:06",
      "micro_segments": [
        {
          "title": "Setup: field surrounded by others; original access path lost and forgotten",
          "display_title": "Path Lost",
          "timestamp": "40:06"
        },
        {
          "title": "Admon: entitled to shortest available path through neighbor's property",
          "display_title": "Admon Claims",
          "timestamp": "41:38"
        },
        {
          "title": "חכמים: if uncertain which field, neighbor owes nothing; can charge exorbitant price",
          "display_title": "Chachamim Harsh",
          "timestamp": "42:23"
        },
        {
          "title": "Gemara analysis: distinguishes single vs. multiple original owners",
          "display_title": "Ownership Analysis",
          "timestamp": "44:02"
        },
        {
          "title": "Rava's middle position: if four separate owners later consolidated, path seeker loses claim",
          "display_title": "Rava's Rule",
          "timestamp": "45:25"
        }
      ]
    },
    {
      "title": "Case Application: Daughter's Non-Specific Palm Tree in Divided Estate",
      "display_title": "Palm Tree Legacy",
