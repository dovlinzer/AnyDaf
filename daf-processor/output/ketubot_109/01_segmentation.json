      "timestamp": "09:27",
      "micro_segments": [
        {
          "title": "Rabbi Yitzchak's rule: wherever Rabban Gamliel says 'I see Admon's position,' we rule like him",
          "display_title": "Affirmed Cases",
          "timestamp": "09:27"
        },
        {
          "title": "Distinction between חנן's two cases (both ruled like) and אדמון's seven cases (only three ruled like)",
