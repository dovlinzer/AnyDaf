  "macro_segments": [
    {
      "title": "Redeeming Sacred Objects from Non-Jews: The Principle of Tikkun Olam and the Status of Sefer Torah",
      "display_title": "Sefer Torah & Tikkun Olam",
      "timestamp": "00:42",
      "micro_segments": [
        {
          "title": "Introduction: Pidyon Shvuyim and the Concept of Tikkun Olam in Protecting Community Interests",
          "display_title": "Pidyon Shvuyim Intro",
          "timestamp": "00:42"
        },
        {
          "title": "The Mishnah's Rule: Not Purchasing Sacred Objects Above Market Value to Prevent Theft",
          "display_title": "Seforim Pricing Rule",
          "timestamp": "00:45"
        },
        {
          "title": "Rav Budya's Question: Can We Presume a Sefer Torah Found with a Non-Jew is Kosher?",
          "display_title": "Sefer Torah Status",
          "timestamp": "01:51"
        },
        {
          "title": "Dilma Lignoz: The Possibility That Sacred Objects Are Purchased Only for Burial, Not Use",
          "display_title": "Lignoz Principle",
          "timestamp": "02:22"
        },
        {
          "title": "Rav Nachman's Teaching: A Sefer Torah Written by a Min Must Be Burned",
          "display_title": "Min & Yisaref",
          "timestamp": "03:22"
        },
        {
          "title": "The Three Positions on Non-Jewish Authorship: Burning, Burying, and Reading a Sefer Torah",
          "display_title": "Three Opinions",
          "timestamp": "07:54"
        },
        {
          "title": "Rabbi Eliezer's View: Assuming Idolatrous Intent in Non-Jewish Writing Requires Destruction",
          "display_title": "Rabbi Eliezer View",
          "timestamp": "08:18"
        },
        {
          "title": "The Braita on Disqualified Writers: Those Outside the Mitzvah of Tefillin Cannot Write Sacred Texts",
          "display_title": "Disqualified Writers",
          "timestamp": "08:56"
        },
        {
          "title": "Rabban Gamliel's Radical Permission: Purchasing Sifrei Torah Written by Non-Jews and Maintaining Kashrut",
          "display_title": "Rabban Gamliel Permit",
          "timestamp": "11:08"
        },
        {
          "title": "Reinterpreting Rabban Gamliel: The Non-Jew Was Actually an Apostate Jew, Reconciling with the Requirement of Leshem Mitzvah",
          "display_title": "Apostate Explanation",
          "timestamp": "13:15"
        },
        {
          "title": "Tosafot's Alternative: Even a Non-Jew's Writing Can Be Kosher If the Klaf Is Prepared Leshem Mitzvah",
          "display_title": "Tosafot Alternative",
          "timestamp": "14:17"
        }
      ]
    },
    {
      "title": "Divorce and Remarriage: When a Husband Cannot Remarry Due to Rumors or Vows",
      "display_title": "Divorce & Remarriage",
      "timestamp": "20:44",
      "micro_segments": [
        {
          "title": "The Mishnah's Two Prohibitions: Divorcing on Grounds of Bad Reputation or Vows Prevents Remarriage",
          "display_title": "Mishnah Rules",
          "timestamp": "20:44"
        },
        {
          "title": "Two Explanations for the Prohibition: Protecting the Wife's Interests or Controlling Behavior",
          "display_title": "Two Rationales",
          "timestamp": "21:01"
        },
        {
          "title": "Rabbi Yehuda's Limitation: Only Publicly Known Vows Prevent Remarriage",
          "display_title": "Rabbi Yehuda",
          "timestamp": "24:02"
        },
        {
          "title": "Rabbi Meir's Position: Only Vows Requiring Sage Annulment Prevent Remarriage",
          "display_title": "Rabbi Meir",
          "timestamp": "25:51"
        },
        {
          "title": "Rabbi Elazar's Refinement: The Concern is Primarily About Vows That Require Sage Annulment",
          "display_title": "Rabbi Elazar",
          "timestamp": "26:56"
        },
        {
          "title": "The Gemara's Debate: Whether the Prohibition is to Protect Interests or to Control Behavior",
          "display_title": "Gemara Debate",
          "timestamp": "27:50"
        },
        {
          "title": "Rav Nachman's Rule: A Husband Must Explicitly State the Reason for Divorce to Prevent Remarriage",
          "display_title": "Explicit Statement",
          "timestamp": "27:50"
        },
        {
          "title": "Two Gemara Versions: Whether the Prohibition Always Applies or Only When Reason Is Stated",
          "display_title": "Two Versions",
          "timestamp": "28:18"
        },
        {
          "title": "Tosafot vs. Rashi: Disbelief of Claims vs. Undermining of Gemirut Daat",
          "display_title": "Tosafot vs Rashi",
          "timestamp": "29:10"
        },
        {
          "title": "Rav Huna's Interpretation: Why We Want the Reason Stated Publicly for Social Control",
          "display_title": "Public Announcement",
          "timestamp": "29:50"
        },
        {
          "title": "The Case of the Man's Vow: Allowing Remarriage When the Husband Makes a Vow to Divorce",
          "display_title": "Husband's Vow",
          "timestamp": "42:25"
        }
      ]
    },
    {
      "title": "Divorce Due to the Wife Being an Aylonit: Permitting or Prohibiting Remarriage",
      "display_title": "Aylonit Case",
      "timestamp": "47:07",
      "micro_segments": [
        {
          "title": "The Mishnah: Rabbi Yehuda Prohibits Remarriage; Chachamim Permit It",
          "display_title": "Mishnah Position",
          "timestamp": "47:07"
        },
        {
          "title": "The Case: Wife Remarries, Has Children, and Claims Her Ketubah",
          "display_title": "Wife Remarries",
          "timestamp": "49:41"
        },
        {
          "title": "Rabbi Yehuda's Counsel: Advising Silence to Avoid Undermining the Divorce",
          "display_title": "Silence Strategy",
          "timestamp": "50:22"
        },
        {
          "title": "Gemara's Resolution: Reconciling Rabbi Yehuda's Position in This Case with Prior Opinions",
          "display_title": "Reconciliation",
          "timestamp": "52:29"
        },
        {
          "title": "Abyei's Analysis: Rabbi Yehuda Holds Like Rabbi Meir and Rabbi Elazar in Different Contexts",
          "display_title": "Abyei Analysis",
          "timestamp": "53:08"
        },
        {
          "title": "Rabbi Meir's Requirement of Tnai Kafful: Why Claims of Changed Intent Don't Undermine the Divorce",
          "display_title": "Tnai Kafful",
          "timestamp": "55:43"
        },
        {
          "title": "Conclusion: Chachamim Allow Remarriage Because Unformalized Conditions Cannot Invalidate a Get",
          "display_title": "Final Resolution",
          "timestamp": "57:35"
        }
