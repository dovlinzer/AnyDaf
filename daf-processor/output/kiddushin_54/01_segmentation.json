  "amud": "",
  "macro_segments": [
    {
      "title": "The Positions of Rabbi Meir and Rabbi Yehuda on Maaser Sheni and Hekdesh",
      "display_title": "Meir vs. Yehuda",
      "timestamp": "00:05",
      "micro_segments": [
        {
          "title": "Introduction to the two Mishnaic positions on Maaser Sheni and Hekdesh",
          "display_title": "Intro: Two positions",
          "timestamp": "00:05"
        },
        {
          "title": "Rabbi Yirmiyah's explanation: why the woman or both parties wouldn't have wanted the transaction",
          "display_title": "Yirmiyah's answer",
          "timestamp": "01:08"
        },
        {
          "title": "Rabbi Yaakov's reversal: both parties wouldn't want Maaser Sheni, she wants Hekdesh",
          "display_title": "Yaakov reverses",
          "timestamp": "02:26"
        }
      ]
    },
    {
      "title": "The Meaning of 'Error' (Ta'us) and the Effect on Kiddushin When Hekdesh Is Involved",
      "display_title": "Ta'us & Kiddushin",
      "timestamp": "06:01",
      "micro_segments": [
        {
          "title": "Rava's question to Rav Chisda: if the woman is not married due to error, how can the money become chullin?",
          "display_title": "Rava's question",
          "timestamp": "06:01"
        },
        {
          "title": "The principle that a void transaction means no me'ilah occurs",
          "display_title": "Void transaction",
          "timestamp": "07:14"
        },
        {
          "title": "Challenge from the case of the storekeeper (chanvani) and money changer (shulchani)",
          "display_title": "Storekeeper case",
          "timestamp": "10:53"
        },
        {
          "title": "Rav's rejection: we never find Rabbi Meir saying me'ilah only occurs when intentional",
          "display_title": "Rav rejects position",
          "timestamp": "16:50"
        }
      ]
    },
    {
      "title": "The Special Exception of Priestly Garments (Bigdei Kehunah) to the Rules of Me'ilah",
      "display_title": "Priestly garments",
      "timestamp": "22:35",
      "micro_segments": [
        {
          "title": "The case of unworn priestly garments: no me'ilah when used to marry a woman",
          "display_title": "Unworn garments",
          "timestamp": "22:35"
        },
        {
          "title": "The principle: Torah wasn't given to heavenly angels (shelo nitna Torah l'malachei hashareis)",
          "display_title": "Heavenly angels",
          "timestamp": "23:32"
        },
        {
          "title": "Why worn-out garments have me'ilah: they are no longer in active use",
          "display_title": "Worn-out distinction",
          "timestamp": "24:52"
        },
        {
          "title": "The case of new versus old shekels (chadshin vs. attikin) for communal sacrifices",
          "display_title": "New vs. old coins",
          "timestamp": "27:01"
        },
        {
          "title": "Stones from the fallen wall of Jerusalem: me'ilah still applies despite allowances",
          "display_title": "Fallen wall stones",
          "timestamp": "30:08"
        }
      ]
    },
    {
      "title": "Establishing the Halachic Positions: Me'aser Sheni as Mammon Gavoh and Hekdesh Me'ilah Rules",
      "display_title": "Halachic ruling",
      "timestamp": "33:43",
      "micro_segments": [
        {
          "title": "The ruling: we follow Rabbi Meir for Me'aser Sheni (it is always God's money)",
          "display_title": "Follow Meir: Me'aser",
          "timestamp": "33:43"
        },
        {
          "title": "Evidence from the Mishnah on fourth-year vineyard fruit (kerem revai)",
          "display_title": "Kerem revai proof",
          "timestamp": "34:39"
        },
        {
          "title": "The debate of Beit Shammai and Beit Hillel on whether kerem revai is like Me'aser Sheni",
          "display_title": "Shammai vs. Hillel",
          "timestamp": "34:50"
        },
        {
          "title": "Why we rule like Rabbi Yehuda for Hekdesh: the Mishnah on sending an agent with Hekdesh funds",
          "display_title": "Follow Yehuda: Hekdesh",
          "timestamp": "36:17"
        }
      ]
    },
    {
      "title": "The Contradiction Between Hekdesh Me'ilah Rules and Kiddushin: When Does Money Become Chullin?",
      "display_title": "Contradiction: chullin s…",
      "timestamp": "38:00",
      "micro_segments": [
        {
          "title": "Rav Pappa's question: why does Hekdesh money become chullin when used for kiddushin intentionally but not for a bathhouse keeper?",
          "display_title": "Rav Pappa's question",
          "timestamp": "38:00"
        }
      ]
    }
