      "title": "Preventing benefit to others while maintaining basic obligations: Wife, children, and property",
      "display_title": "Wife, Children, Property",
      "timestamp": "00:08",
      "micro_segments": [
        {
          "title": "Mishnah: One who cannot receive benefit can still provide for another's wife and children",
          "display_title": "Feeding Wife & Children",
          "timestamp": "00:08"
        },
        {
          "title": "Gemara clarifies the ruling applies when the beneficiary is an adult and acts of her own will",
          "display_title": "Adult Daughter Marrying",
          "timestamp": "01:17"
        },
