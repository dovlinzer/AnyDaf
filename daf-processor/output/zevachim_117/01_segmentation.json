  "macro_segments": [
    {
      "title": "The Three Camps: Machaneh Yisrael, Machaneh Leviyah, and Machaneh Shechinah in the Wilderness and Their Later Parallels in Jerusalem",
      "display_title": "Three Camps Structure",
      "timestamp": "00:00",
      "micro_segments": [
        {
          "title": "Introduction to the paradigmatic setup of Ohel Moed and the three camps",
          "display_title": "Ohel Moed Overview",
          "timestamp": "00:00"
        },
        {
          "title": "Kodshei Kalim eaten in Machaneh Yisrael and the debate about whether Machaneh Yisrael is a fixed location",
          "display_title": "Kodshei Kalim Debate",
          "timestamp": "00:42"
        },
        {
          "title": "The paradigm of three camps in the wilderness corresponding to the three zones in Jerusalem",
          "display_title": "Wilderness to Jerusalem",
          "timestamp": "01:40"
        },
        {
          "title": "The debate about which camp was absent in Shilo and the function of Machaneh Leviyah as ir miklat (city of refuge)",
          "display_title": "Shilo Camps Question",
          "timestamp": "06:52"
        },
        {
          "title": "The necessity of Machaneh Leviyah based on laws of tumah and the banishment of zavim and temei meisim",
          "display_title": "Machaneh Leviyah Necessi…",
          "timestamp": "08:13"
        }
      ]
    },
    {
      "title": "Cities of Refuge and Machaneh Leviyah as Sanctuary in the Wilderness and Later Periods",
      "display_title": "Cities of Refuge",
      "timestamp": "15:19",
      "micro_segments": [
        {
          "title": "Machaneh Leviyah as a place of refuge for an unintentional murderer in the wilderness period",
          "display_title": "Miklat in Midbar",
          "timestamp": "15:19"
        },
        {
          "title": "The concept of a Ben Levi who kills: exile within one's own city versus exile to another city",
          "display_title": "Ben Levi Refuge",
          "timestamp": "17:30"
        },
        {
          "title": "The debate whether internal exile to a different neighborhood satisfies the requirement of galus (exile)",
          "display_title": "Internal Exile",
          "timestamp": "18:42"
        },
        {
          "title": "The scriptural source for dwelling in one's city of refuge (ir miklato) from Rav Acha",
          "display_title": "Scriptural Source",
          "timestamp": "19:49"
        }
      ]
    },
    {
      "title": "The Period of Bamot Permitted: What Sacrifices Could Be Brought on Private and Central High Places",
      "display_title": "Bamot Permitted",
      "timestamp": "21:31",
      "micro_segments": [
        {
          "title": "The Mishnah debate: what free-will offerings (neder and nedavah) could be brought on a bamah",
          "display_title": "Free-Will on Bamah",
          "timestamp": "21:31"
        },
        {
          "title": "The debate about minchah and nezirut: whether non-animal sacrifices and nazir sacrifices are permitted on a bamah",
          "display_title": "Minchah & Nezirut",
          "timestamp": "22:25"
        },
        {
          "title": "Rabbi Yehudah's position: the tzibur brings everything in Gilgal including all obligatory sacrifices",
          "display_title": "Rabbi Yehudah Gilgal",
          "timestamp": "24:26"
        },
        {
          "title": "The position of the Chachamim: the tzibur brings everything but the yachid (individual) is restricted even in Gilgal",
          "display_title": "Chachamim Position",
          "timestamp": "29:23"
        },
        {
          "title": "Rabbi Shimon's stringent position: even the tzibur is restricted to Pesachim and fixed-time sacrifices",
          "display_title": "Rabbi Shimon",
          "timestamp": "30:12"
        }
      ]
    },
    {
      "title": "The Conceptual Framework of Free-Will versus Obligatory Status and Its Application to Nezirut",
      "display_title": "Free-Will vs. Obligation",
      "timestamp": "31:41",
      "micro_segments": [
        {
          "title": "The distinction between the genre of sacrifice (olah, shelamim vs. chatat, asham) and the actual circumstances of obligation",
          "display_title": "Genre vs. Circumstance",
          "timestamp": "31:41"
        },
        {
          "title": "Shmuel's statement: the debate about nezirut concerns only chatat and asham, not olah and shelamim",
          "display_title": "Shmuel Chatat",
          "timestamp": "34:12"
        },
        {
          "title": "Rava's challenge to Shmuel using the baraita about the gifts from a todah sacrifice on a bamah",
          "display_title": "Rava's Challenge",
          "timestamp": "39:32"
        },
        {
          "title": "The resolution: the debate concerns olah and shelamim of a nazir, requiring both the genre restriction and free-will circumstances",
          "display_title": "Resolution",
          "timestamp": "40:59"
        }
      ]
    },
    {
      "title": "Individual versus Community at Gilgal: The Debate About Whether a Yachid Can Bring Obligatory Sacrifices in the Central Location",
      "display_title": "Yachid in Gilgal",
      "timestamp": "47:56",
      "micro_segments": [
        {
          "title": "The Chachamim's rationale: the phrase 'ish hayashar be-einav' restricts individuals to free-will sacrifices even at Gilgal",
          "display_title": "Chachamim Reasoning",
          "timestamp": "47:56"
        },
        {
          "title": "Rabbi Yehudah's counterargument: 'ish hayashar be-einav' applies only to private bamot, not to the central location",
          "display_title": "Rabbi Yehudah Counter",
          "timestamp": "49:09"
        },
        {
          "title": "The meaning of 'ish' according to Rabbi Yehudah: a layperson can serve without a kohen on a private bamah",
          "display_title": "Meaning of Ish",
          "timestamp": "50:19"
        },
        {
          "title": "The conclusion: the Chachamim are the Tanna Kamma, and the actual debate concerns whether nesachim accompany olah and shelamim",
          "display_title": "Conclusion",
          "timestamp": "52:02"
        }
      ]
    }
  ],
