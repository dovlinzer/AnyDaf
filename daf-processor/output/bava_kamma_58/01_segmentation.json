      "micro_segments": [
        {
          "title": "Rav Kahana: Animal Slipping in Its Own Urine Constitutes Ones",
          "display_title": "Slipping in Urine",
          "timestamp": "17:07"
        },
        {
          "title": "Rava: Fellow Animal Pushing Constitutes Ones; Owner Should Prevent by Single File",
          "display_title": "Single File Requirement",
          "timestamp": "17:18"
        },
        {
          "title": "Tosafot's Limitation: Only Ones if Animal Cannot Descend by Itself",
          "display_title": "Cliff Case Limitation",
          "timestamp": "18:42"
        },
        {
          "title": "Rav Kahana: Eating from Same Row Is Ones; Moving Between Rows Is Pshiah",
          "display_title": "Row-to-Row Movement",
          "timestamp": "22:25"
        },
        {
          "title": "Rav Yochanan: No Set Time Limit; Continues Until Owner Knows and Can Intervene",
          "display_title": "No Time Limit",
          "timestamp": "23:23"
        },
        {
          "title": "Rav Papa: Once Owner Aware of Animal's Escape, Liable Even If It Returns Unknowingly",
          "display_title": "Heightened Liability",
