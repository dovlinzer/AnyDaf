  "macro_segments": [
    {
      "title": "The Debate Between Rabbi Akiva and the Tanna Kama on the Scope of Eating in Oaths",
      "display_title": "Akiva vs. Tanna Kama",
      "timestamp": "00:21",
      "micro_segments": [
        {
          "title": "Introduction to the Foundational Dispute: Does 'Eating' in an Oath Mean a Kezayit or Even a Tiny Amount?",
          "display_title": "Eating Defined",
          "timestamp": "00:21"
        },
        {
          "title": "Rabbi Shimon's General Principle: A Small Amount Violates Even for Lashes, But Only a Kezayit Brings a Korban",
          "display_title": "Rabbi Shimon",
          "timestamp": "00:52"
        },
        {
          "title": "Rashi's Incisive Distinction: The Oath Focuses on Breaking One's Word, Not on Gradations of Sin",
          "display_title": "Rashi's Word-Breaking",
          "timestamp": "02:23"
        },
        {
          "title": "Tosafot's Answer: The Absence of Karet for False Oaths Allows Stringency on the Measure",
          "display_title": "Tosafot on Karet",
          "timestamp": "02:31"
        },
        {
          "title": "The Gemara's Challenge: If Rabbi Akiva Generally Held Like Rabbi Shimon, Why Would He Posit a Different Rule for Oaths?",
          "display_title": "Challenge to Akiva",
          "timestamp": "05:06"
        },
        {
          "title": "Proofs That Rabbi Akiva Normally Requires a Kezayit: The Nazir Dipping Bread in Wine",
          "display_title": "Nazir Proof",
          "timestamp": "08:27"
        },
        {
          "title": "The Oath on Non-Kosher Food: Why Does the Oath Take Effect on Neveilot and Treifot?",
          "display_title": "Non-Kosher Foods",
          "timestamp": "09:29"
        },
        {
          "title": "Three Explanations for Why the Oath on Non-Kosher Food Is Binding: Rav, Shmuel, and Rabbi Yochanan versus Reish Lakish",
          "display_title": "Three Answers",
          "timestamp": "10:48"
        },
        {
          "title": "Rabbi Akiva's Unique Position: Oaths Allow Even Implicit References to a Tiny Amount",
          "display_title": "Akiva Implicit",
          "timestamp": "12:29"
        },
        {
          "title": "Why Not Simply Argue from the Case of Explicit Statements? The Gemara's Challenge",
          "display_title": "Explicit vs. Implicit",
          "timestamp": "13:50"
        }
      ]
    },
    {
      "title": "Exceptions and Anomalies: When 'Eating' Does Not Require a Kezayit",
      "display_title": "Eating Exceptions",
      "timestamp": "15:29",
      "micro_segments": [
        {
          "title": "The Case of a Whole Animal (Briah): Eating a Whole Ant Violates Even Though It May Be Tiny",
          "display_title": "Briah Exception",
          "timestamp": "15:29"
        },
        {
          "title": "Hekdesh and Meilah: Benefit from Consecrated Items Has Its Own Measure (Shaveh Pruta, Not Kezayit)",
          "display_title": "Hekdesh Measure",
          "timestamp": "16:34"
        },
        {
          "title": "Explicit Oaths and Their Significance: If You Say 'I Won't Eat a Tiny Amount,' That Creates an Exception",
          "display_title": "Explicit Tiny Amount",
          "timestamp": "16:59"
        },
        {
          "title": "Eating Dirt: Is It a Normal Act of Eating, or Does It Escape Normal Definitions?",
          "display_title": "Dirt Question",
          "timestamp": "18:47"
        },
        {
          "title": "Konamot (Vows): When You Say Konam Without Using the Word 'Eating,' Do You Create an Exception to the Kezayit Rule?",
          "display_title": "Konamot",
          "timestamp": "20:07"
        },
        {
          "title": "Konamot and Meilah: Is There Meilah by a Konam, and Does It Require a Shaveh Pruta or Have No Measure?",
          "display_title": "Konam Meilah",
          "timestamp": "20:51"
        }
      ]
    },
    {
      "title": "The Combination Rule: Do Multiple Konamot or Multiple Oaths Combine to Create a Violation?",
      "display_title": "Combination Rule",
      "timestamp": "31:52",
      "micro_segments": [
        {
          "title": "The Baraita: Two Konamot Combine; Two Oaths Do Not Combine",
          "display_title": "Baraita Rule",
          "timestamp": "31:52"
        },
        {
          "title": "Rabbi Meir's Dispute: Konamot Are Like Oaths and Should Not Combine",
          "display_title": "Rabbi Meir",
          "timestamp": "33:04"
        },
        {
          "title": "Why Konamot Combine: The Case When You Say 'Eating of These Two Apples Is Forbidden'",
          "display_title": "When Konamot Combine",
          "timestamp": "34:19"
        },
        {
          "title": "Why Oaths Do Not Combine: The Principle of 'One of These' Makes Them Separate Oaths",
          "display_title": "Oath Separation",
          "timestamp": "36:11"
        },
        {
          "title": "Rav Pinchas's Explanation: Different Sin Offerings for Different Items",
          "display_title": "Rav Pinchas",
          "timestamp": "36:11"
        },
        {
          "title": "Ravina's Alternative: Konamot Require a Shaveh Pruta for a Korban Me'ilah, While Oaths Require a Kezayit for Korban",
          "display_title": "Ravina's Answer",
          "timestamp": "40:57"
        },
        {
          "title": "The Problem with Ravina's Answer: Does Rabbi Meir Agree There Is Meilah by Konamot?",
          "display_title": "Ravina Challenged",
          "timestamp": "42:15"
        },
        {
          "title": "The Baraita on Konam and Hekdesh: Subjective vs. Objective Status and the Possibility of Pidyon (Redemption)",
          "display_title": "Konam vs. Hekdesh",
          "timestamp": "43:04"
        },
        {
          "title": "Resolution: Reversing the Positions—Rabbi Meir Says No Meilah; The Rabbis Say There Is Meilah by Konam",
          "display_title": "Resolution",
          "timestamp": "44:49"
        }
      ]
    },
    {
      "title": "Rava's Questions on Anomalous Cases: Dirt, Grape Seeds, and the Nazir",
      "display_title": "Rava's Questions",
      "timestamp": "47:53",
      "micro_segments": [
        {
          "title": "Does Eating Dirt in an Oath Mean a Kezayit or a Kol Shehu? Rava's Question and the Unresolved Teiku",
          "display_title": "Dirt Measure",
          "timestamp": "47:53"
        },
        {
          "title": "Grape Seeds: Are They Like Dirt (Non-Edible, Thus Kol Shehu) or Edible (Thus Kezayit)?",
          "display_title": "Grape Seeds",
          "timestamp": "48:40"
        },
        {
          "title": "Rav Ashi's Question: A Nazir Swearing Not to Eat Grape Seeds—Is the Oath Meaningful or Redundant?",
          "display_title": "Rav Ashi",
          "timestamp": "50:22"
        },
        {
          "title": "The Principle of Non-Redundancy: Must We Interpret Words to Avoid Uselessness, or Do We Accept Redundancy?",
          "display_title": "Non-Redundancy",
          "timestamp": "50:22"
        },
        {
          "title": "The Neveilah Comparison: Even Though Neveilah Is Inedible by Halacha, It Is Edible as a Matter of Biology",
          "display_title": "Neveilah Biology",
          "timestamp": "54:01"
        },
        {
          "title": "Dirt Is Not Bar Achila; Neveilah Is Bar Achila: Therefore Eating Dirt May Escape Normal Definitions",
          "display_title": "Dirt Not Edible",
          "timestamp": "54:01"
        }
      ]
    }
