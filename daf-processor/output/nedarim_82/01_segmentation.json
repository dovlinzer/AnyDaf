{
  "masechta": "Nedarim",
  "daf": 82,
  "amud": "a-b",
  "macro_segments": [
    {
      "title": "Introduction to Inuy Nefesh and Devarim Shebeino L'Veina",
      "display_title": "Inuy Nefesh vs. Beino L'…",
      "timestamp": "00:00",
      "micro_segments": [
        {
          "title": "Opening remarks and review of previous discussion on bathing and makeup",
          "display_title": "Bathing & Makeup",
          "timestamp": "00:00"
        },
        {
          "title": "The distinction between Rabanan and Rabbi Yosi regarding categories of self-denial",
          "display_title": "Rabanan vs. R. Yosi",
          "timestamp": "00:15"
        },
        {
          "title": "Husband's power to annul only the personal aspect (Beino L'Veina) of a vow",
          "display_title": "Husband's Limited Power",
          "timestamp": "00:53"
        }
      ]
    },
    {
      "title": "Rava's Question to Rav Nachman: Is Denial of Sexual Relations Inuy Nefesh?",
      "display_title": "Tashmish HaMita Question",
      "timestamp": "01:01",
      "micro_segments": [
        {
          "title": "Rava asks whether denial of marital relations constitutes Inuy Nefesh or Beino L'Veina for the Rabanan",
          "display_title": "The Question Posed",
          "timestamp": "01:01"
        },
        {
          "title": "Rav Nachman's answer via the Mishnah: woman forbids herself to all Jews; husband can only annul his portion",
          "display_title": "Rav Nachman's Answer",
          "timestamp": "01:53"
        },
        {
          "title": "Rava's objection: the cited Mishnah is Rabbi Yosi's view, not the Rabanan's",
          "display_title": "Rava's Objection",
          "timestamp": "04:00"
        },
        {
          "title": "The entire perek is Rabbi Yosi's view; therefore, no clear conclusion on Rabanan's position regarding sexual relations",
          "display_title": "Attribution to Rabbi Yosi",
          "timestamp": "05:01"
        },
        {
          "title": "Discussion of why the halacha must assume married couples have sexual relations",
          "display_title": "Nature of Marriage",
          "timestamp": "07:59"
        }
      ]
    },
    {
      "title": "Shmuel's Principle: Inuy Nefesh Applies Even to Partial Denial from a Single Source",
      "display_title": "Shmuel's Principle",
      "timestamp": "11:02",
      "micro_segments": [
        {
          "title": "Shmuel's ruling: husband can annul vows of self-denial except those benefiting only others",
          "display_title": "Shmuel's Ruling",
          "timestamp": "11:02"
        },
        {
          "title": "The innovation: denial from one source (e.g., Michael's fruit) is still Inuy Nefesh if the item itself (fruit) is Inuy Nefesh",
          "display_title": "One Source Suffices",
          "timestamp": "11:31"
        },
        {
          "title": "Contradiction with the Mishnah: fruit from one country can be replaced from another country",
          "display_title": "Mishnah's Objection",
          "timestamp": "13:04"
        },
        {
          "title": "Resolution: the Mishnah means she forbids fruit only if provided by the husband; from others is permitted",
          "display_title": "Difficult Reading Propos…",
          "timestamp": "13:27"
        },
        {
          "title": "Further objection: the reading contradicts the case where storekeeper is sole provider",
          "display_title": "Sole Provider Case",
          "timestamp": "18:01"
        },
        {
          "title": "Final resolution: the Mishnah forbids fruit across the board (regardless of source); Shmuel's position is rejected in favor of the Mishnah's plain reading",
          "display_title": "Mishnah's Plain Reading",
          "timestamp": "19:47"
        }
      ]
    },
    {
      "title": "Rav Yehuda's Case of Two Loaves: Partial Inuy Nefesh and Husband's Annulment Power",
      "display_title": "Two Loaves Case",
      "timestamp": "25:27",
      "micro_segments": [
        {
          "title": "The case: woman forbids two loaves, one fine bread (Inuy Nefesh) and one bran/stale (not Inuy Nefesh)",
          "display_title": "Two Loaves Setup",
          "timestamp": "25:27"
        },
        {
          "title": "Shmuel's view: husband can annul both loaves because he can annul the Inuy Nefesh portion",
          "display_title": "Shmuel's Position",
          "timestamp": "26:43"
        },
        {
          "title": "The Ran's explanation: all-or-nothing principle requires husband to have power over the whole if he has power over part",
          "display_title": "Ran's Explanation",
          "timestamp": "27:31"
        },
        {
          "title": "Exception for Beino L'Veina: partial annulment is possible when the vow affects only the spousal relationship",
          "display_title": "Beino L'Veina Exception",
          "timestamp": "30:28"
        }
      ]
    },
    {
      "title": "Rabbi Yochanan's Position: Partial Annulment Only for Inuy Nefesh Aspects",
      "display_title": "R. Yochanan's View",
      "timestamp": "32:20",
      "micro_segments": [
        {
          "title": "Rabbi Yochanan's position: husband annuls only the Inuy Nefesh part, not the non-Inuy Nefesh part",
          "display_title": "Partial Annulment Only",
          "timestamp": "32:20"
        },
        {
          "title": "Objection from the Nazirite case: if husband annuls part of Nazirite vow, what becomes of the obligations?",
          "display_title": "Nazirite Case",
          "timestamp": "32:53"
        },
        {
          "title": "Rav Yosef's resolution: Nazirite is an indivisible package; partial annulment annuls the whole vow",
          "display_title": "Nazirite is Package Deal",
          "timestamp": "35:13"
        },
        {
          "title": "Abaye's clarification: Nazirite cannot be half in quality or half in duration; husband's annulment terminates it entirely",
          "display_title": "Abaye's Clarification",
          "timestamp": "36:23"
        }
      ]
    }
  ],
