{
  "masechta": "Bava Batra",
  "daf": 154,
  "amud": "a",
  "macro_segments": [
    {
      "title": "Introduction to the Mishna Debate: Gift Document (Shtar Matana) Written Without Health Status Designation",
      "display_title": "Shtar Matana Debate",
      "timestamp": "00:06",
      "micro_segments": [
        {
          "title": "Setting up the Mishna case: A gift of all property without explicit designation of health status (Sh'chiv Meira vs. Baria)",
          "display_title": "Case Setup",
          "timestamp": "00:06"
        },
        {
          "title": "Rabbi Meir vs. Chachamim: Two approaches to determining the default status of an undesignated gift document",
          "display_title": "Default Status",
          "timestamp": "01:41"
        },
        {
          "title": "Rav Huna's explanation: Burden of proof based on current state (Rav Huna's approach to retrojection)",
          "display_title": "Rav Huna's Retroj.",
          "timestamp": "03:42"
        },
        {
          "title": "Rav Chisda and Rabbah bar Rav Huna's alternative: Proof through document validation (Kiyum HaShtar), not witness testimony",
          "display_title": "Kiyum HaShtar",
          "timestamp": "05:21"
        },
        {
          "title": "Core principle: Sh'chiv Meira claim lacks inherent credibility; only believable via Migo (could claim forgery) when document is unvalidated",
          "display_title": "Migo & Credibility",
          "timestamp": "08:17"
        }
      ]
    },
    {
      "title": "Gemara's Reconciliation: Two Amoraic Interpretations (Rav Huna vs. Rav Chisda/Rabbah bar Rav Huna) and Citation of Earlier Braiyta",
      "display_title": "Amoraic Debate",
      "timestamp": "22:36",
      "micro_segments": [
        {
          "title": "Rabbah's position on proof with witnesses (Ra'aya Be'Edim): Assumes default health unless proven otherwise",
          "display_title": "Rabbah's View",
          "timestamp": "22:36"
        },
        {
          "title": "Abaye's challenge: Why assume possible Sh'chiv Meira when document lacks designation and he is presently healthy?",
          "display_title": "Abaye's Challenge",
          "timestamp": "24:13"
        },
        {
          "title": "Response: Both possibilities exist (healthy or sick); Safek applies, so Hamotzi Me'Chaveiro Alav Ha'Ra'aya",
          "display_title": "Safek Resolution",
          "timestamp": "25:52"
        },
        {
          "title": "Citation of parallel Amoraic debate: Rabbi Yochanan vs. Resh Lakish on two-stage interpretation (witnesses vs. document validation)",
          "display_title": "R. Yochanan vs. R.L.",
          "timestamp": "26:25"
        }
      ]
    },
    {
      "title": "The Story of Bnei Brak: Sale of Paternal Estate by Minor — Burden of Proof and Challenge to Resh Lakish's Position",
      "display_title": "Bnei Brak Story",
      "timestamp": "27:07",
      "micro_segments": [
        {
          "title": "Case narrative: Brother sold father's estate property; family challenges claim that seller was a minor at time of sale; seller subsequently died",
          "display_title": "Story Setup",
          "timestamp": "27:07"
        },
        {
          "title": "Petition to Rabbi Akiva: Request to exhume body to determine minor status through bodily signs; Rabbi Akiva refuses on grounds of Nivul HaMet and evidentiary futility",
          "display_title": "Nivul HaMet & Autopsy",
          "timestamp": "28:01"
        },
        {
          "title": "Resh Lakish's reading: Property held by purchasers (Shtar Mekuyam); family must prove minor status; Resh Lakish's explanation reconciles case with Kiyum HaShtar approach",
          "display_title": "Property Possession",
          "timestamp": "31:43"
        },
        {
          "title": "Reb Yochanan's counter-reading: Purchasers (Lekuchot) bear burden; family's minor claim still works against Mekuyam Shtar; alternative theory of Kiyum's limits",
          "display_title": "Alternate Reading",
          "timestamp": "32:02"
        },
        {
          "title": "Gemara's analysis: Resh Lakish's consistent position (Kiyum HaShtar suffices) vs. Reb Yochanan's position (witness proof still needed despite Kiyum)",
          "display_title": "Gemara Analysis",
          "timestamp": "36:56"
        }
      ]
    },
    {
      "title": "Mishnat Bar Kappara: Competing Claims Against a Shtar (Forgery vs. Appeasement vs. Trust Document)",
      "display_title": "Bar Kappara Mishna",
      "timestamp": "45:01",
      "micro_segments": [
        {
          "title": "Default case: Person harvesting field in possession; challenged by shtar-holder; claim of forgery requires Kiyum HaShtar to defeat",
          "display_title": "Field Possession",
          "timestamp": "45:01"
        },
        {
          "title": "Shtar Pasim (appeasement document) and Shtar Amana (trust document): Claim that shtar written without payment; requires witness proof or shtar prevails",
          "display_title": "Shtar Types",
          "timestamp": "46:01"
        },
        {
          "title": "Principle: General counter-claims (non-forgery) against unvalidated shtar are not believed unless supported by witnesses",
          "display_title": "Counter-Claim Rules",
          "timestamp": "47:04"
        }
      ]
    },
    {
      "title": "Resolution of Debate Through Bar Kappara's Teaching: Resh Lakish's Application and Reb Yochanan's Defense of Witness-Based Interpretation",
      "display_title": "Debate Resolution",
      "timestamp": "49:01",
      "micro_segments": [
        {
          "title": "Resh Lakish's challenge: Bar Kappara's rule shows shtar stands without Kiyum against non-forgery claims—how does Reb Yochanan's witness-based approach fit?",
          "display_title": "Challenge to R.Y.",
          "timestamp": "49:01"
        },
        {
          "title": "Reb Yochanan's response: General agreement (Modeh BeShtar SheKetavo Ein Tzarich LeKaymo) but Sh'chiv Meira claim is exceptional and creates Safek",
          "display_title": "R.Y. Response",
          "timestamp": "51:29"
        },
        {
          "title": "Gemara's closing: Sh'chiv Meira debate may not be about Kiyum HaShtar at all but about whether that specific claim creates credible Safek against shtar",
          "display_title": "Closing Analysis",
          "timestamp": "53:46"
        }
      ]
    }
  ],
