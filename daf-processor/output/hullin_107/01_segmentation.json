  "macro_segments": [
    {
      "title": "The requirement of a vessel (kli) for netilas yadayim and the minimum measure of revi'is",
      "display_title": "Vessel & Revi'is",
      "timestamp": "00:19",
      "micro_segments": [
        {
          "title": "Rava's ruling that a vessel must be able to hold a revi'is of water for netilas yadayim",
          "display_title": "Rava's Vessel Rule",
          "timestamp": "00:19"
        },
        {
          "title": "The distinction between starting with a revi'is and the remnant of water that was already used",
          "display_title": "Revi'is & Remnant",
          "timestamp": "02:03"
        },
        {
          "title": "Rav Sheshes questioning whether vessel quality matters and Rav's response on vessel, water appearance, and quantity requirements",
          "display_title": "Rav Sheshes' Questions",
          "timestamp": "02:55"
        },
        {
          "title": "Rav Yaakov of Nehar Pakod establishing a standard glass vessel measure and Rav Ashi establishing a pottery vessel measure",
          "display_title": "Standard Measures",
          "timestamp": "05:19"
        },
        {
          "title": "Examples of vessels that may be used including barrel stoppers, flasks, and water skins",
          "display_title": "Acceptable Vessels",
          "timestamp": "06:32"
        },
        {
          "title": "Items that cannot be used for netilas yadayim even if they can hold liquid, such as sacks and boxes",
          "display_title": "Disqualified Items",
          "timestamp": "07:28"
        }
      ]
    },
    {
      "title": "The question of whether wrapping bread or hands exempts one from netilas yadayim",
      "display_title": "Wrapping & Washing",
      "timestamp": "08:35",
      "micro_segments": [
        {
          "title": "The question raised: can wrapping bread or hands in a napkin exempt one from netilas yadayim",
          "display_title": "Wrapping Question",
          "timestamp": "08:35"
        },
        {
          "title": "The case of Rabbi Tzaddok eating less than a kabeitzah wrapped in cloth and not washing hands",
          "display_title": "Rabbi Tzaddok Case",
          "timestamp": "10:07"
        },
        {
          "title": "Analysis of whether size (kabeitzah) or wrapping exempts from netilas yadayim requirements",
          "display_title": "Size vs Wrapping",
          "timestamp": "11:40"
        }
      ]
    },
    {
      "title": "The shiur (minimum amount) of bread requiring netilas yadayim and practical applications",
      "display_title": "Shiur of Bread",
      "timestamp": "11:42",
      "micro_segments": [
        {
          "title": "Discussion of whether the kabeitzah measure applies to netilas yadayim and the kezayit versus kabeitzah distinction",
          "display_title": "Kabeitzah Measure",
          "timestamp": "11:42"
        },
        {
          "title": "The halachic ruling that at least for a kezayit one does netilas yadayim according to most authorities",
          "display_title": "Kezayit Ruling",
          "timestamp": "13:27"
        },
        {
          "title": "Practical halacha regarding netilas yadayim for less than a kabeitzah and the dispute about doing it without a bracha",
          "display_title": "Practical Halacha",
          "timestamp": "13:54"
        }
      ]
    },
    {
      "title": "The question of whether wrapping bread or hands exempts one from netilas yadayim (continued)",
      "display_title": "Wrapping & Washing (II)",
      "timestamp": "14:18",
      "micro_segments": [
        {
          "title": "Shmuel finding Rav eating wrapped bread and their discussion confirming netilas yadayim is required despite wrapping",
          "display_title": "Rav & Shmuel Case",
          "timestamp": "14:18"
        },
        {
          "title": "Rabbi Zeira's finding of Rabbi Ammi and Rabbi Assi eating with worn rags and the distinction regarding terumah for kohanim",
          "display_title": "Rabbi Zeira's Finding",
          "timestamp": "14:56"
        },
        {
          "title": "The ruling that wrapping is not permitted for regular bread but is allowed for those eating terumah who are punctilious about purity",
          "display_title": "Wrapping Terumah",
          "timestamp": "15:58"
        }
      ]
    },
    {
      "title": "Whether netilas yadayim is required for one being fed versus one feeding",
      "display_title": "Eater vs Feeder",
      "timestamp": "18:59",
      "micro_segments": [
        {
          "title": "The question of whether one being fed by another requires netilas yadayim",
          "display_title": "Being Fed",
          "timestamp": "18:59"
        },
        {
          "title": "The case of Rav Huna bar Sachorah being fed by Rav Hamnuna and whether the feeder being trusted prevents netilas yadayim",
          "display_title": "Rav Hamnuna Case",
          "timestamp": "19:31"
        },
        {
          "title": "Rav's teaching that one should not feed bread to a waiter unless certain he has done netilas yadayim",
          "display_title": "Waiter Rule",
          "timestamp": "21:18"
        },
        {
          "title": "The case of Shmuel being criticized for feeding his child without washing hands and his father's response",
          "display_title": "Shmuel's Case",
          "timestamp": "28:04"
        },
        {
          "title": "The final halachic conclusion that the eater requires netilas yadayim but the feeder does not",
          "display_title": "Halachic Conclusion",
          "timestamp": "29:40"
        }
      ]
    },
    {
      "title": "Meat and milk separation regarding eating at the same table and the concept of tfisa achat",
      "display_title": "Meat & Milk Table",
      "timestamp": "31:02",
      "micro_segments": [
        {
          "title": "The mishnah permitting wrapping meat and cheese in one cloth as long as they do not touch",
          "display_title": "Wrapping Meat/Cheese",
          "timestamp": "31:02"
        },
        {
          "title": "Rabban Shimon ben Gamliel's teaching that two strangers (achsanaim) can eat meat and milk at the same table without concern",
          "display_title": "Strangers Rule",
          "timestamp": "32:30"
        },
        {
          "title": "Abaye's ruling that if they touch while cold, they do not transfer taste but rinsing may be required for greasy residue",
          "display_title": "Cold vs Heat",
          "timestamp": "33:04"
        },
        {
          "title": "Shmuel's limitation that the permission for eating together only applies if the guests do not recognize one another",
          "display_title": "Strangers Requirement",
          "timestamp": "35:00"
        },
        {
          "title": "The concept of tfisa achat (one bundle) and that eating together requires some sense of common meal, not just physical proximity",
          "display_title": "Tfisa Achat",
          "timestamp": "36:07"
        },
        {
          "title": "Abaye's ruling using lo plug (not making distinctions) that even feuding brothers cannot eat meat and milk together",
          "display_title": "No Distinctions",
          "timestamp": "37:09"
        },
        {
          "title": "Tosafot's discussion of separations between diners and how physical barriers or reminders allow meat and milk at the same table",
          "display_title": "Separations",
          "timestamp": "41:22"
        },
        {
          "title": "Explanation that ancient shulchan was a personal tray, not a shared table, affecting how the separation rule applies nowadays",
          "display_title": "Table Types",
          "timestamp": "42:50"
        }
      ]
    }
  ],
