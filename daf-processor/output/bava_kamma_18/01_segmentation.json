  "macro_segments": [
    {
      "title": "Rava's Question on Chatzi Nezek Tzeroros: Does Payment Depend on Initial Act or Final Breaking?",
      "display_title": "Chatzi Nezek—Initial vs.…",
      "timestamp": "00:19",
      "micro_segments": [
        {
          "title": "Introduction to the sugya of chatzi nezek tzeroros and Sumchus's disagreement",
          "display_title": "Tzeroros Overview",
          "timestamp": "00:19"
        },
        {
          "title": "Rava's question: animal steps on vessel, vessel rolls and breaks—is it gufo or kocho?",
          "display_title": "Rava's Vessel Question",
          "timestamp": "00:49"
        },
        {
          "title": "Proof from Rabbah: one who throws vessel and another breaks it with staff—exempt",
          "display_title": "Rabbah's Staff Case",
          "timestamp": "01:50"
        },
        {
          "title": "Gemara clarifies: for Rabbah it's clear, for Rava it's uncertain",
          "display_title": "Rabbah vs. Rava",
          "timestamp": "02:35"
        }
      ]
    },
    {
      "title": "The Hen and Rope Case: Attempting to Resolve Rava's Question",
      "display_title": "Hen & Rope Case",
      "timestamp": "02:58",
      "micro_segments": [
        {
          "title": "Baraita on hidus (hen hopping): debate whether it's muad or not",
          "display_title": "Hidus Debate",
          "timestamp": "02:58"
        },
        {
          "title": "Gemara explains: hidus must mean hopping and scattering pebbles, a tzeroros case",
          "display_title": "Hidus as Tzeroros",
          "timestamp": "03:18"
        },
        {
          "title": "Baraita on tarnigolim pecking rope holding bucket: full damages on bucket, half on jar broken by pieces",
          "display_title": "Tarnigolim Case",
          "timestamp": "05:01"
        },
        {
          "title": "Gemara: if it proves basar me'ikara, then Rava's question is answered",
          "display_title": "Proof of Initial Act",
          "timestamp": "05:29"
        },
        {
          "title": "Counter-explanation: maybe Sumchus's position—kocho pays full, koach kocho pays half",
          "display_title": "Sumchus Distinction",
          "timestamp": "07:08"
        },
        {
          "title": "Rav Ashi's question: does Sumchus hold koach kocho like kocho or like half-damage?",
          "display_title": "Rav Ashi Question",
          "timestamp": "10:13"
        },
        {
          "title": "Gemara says to avoid proving Rav Ashi's case, read baraita as Rabbanan—basar me'ikara",
          "display_title": "Resolve as Rabbanan",
          "timestamp": "11:32"
        },
        {
          "title": "Rav Bibi bar Abaye: maybe the animal kept pushing the bucket after it fell",
          "display_title": "Alt: Continued Pushing",
          "timestamp": "12:21"
        }
      ]
    },
    {
      "title": "Rava's Second Question: Does Chatzi Nezek Tzeroros Pay from Body (Migufo) or Out of Pocket (Me'aliya)?",
      "display_title": "Migufo vs. Me'aliya",
      "timestamp": "13:41",
      "micro_segments": [
        {
          "title": "Rava asks: chatzi nezek tzeroros—do we pay from the body like keren or out of pocket like regel?",
          "display_title": "Migufo Question",
          "timestamp": "13:41"
        },
        {
          "title": "Proof attempt: hidus baraita—muad/eino muad as mueod/niet moeud tracks to migufo vs. me'aliya",
          "display_title": "Hidus Evidence",
          "timestamp": "15:41"
        },
        {
          "title": "Gemara: can't prove it; might just be Sumchus vs. Rabbanan on full vs. half",
          "display_title": "Inconclusive",
          "timestamp": "16:24"
        }
      ]
    },
    {
      "title": "The Ember in the Grain Case: Complexity with Rabbi Eliezer and Sumchus",
      "display_title": "Ember in Grain",
      "timestamp": "17:13",
      "micro_segments": [
        {
          "title": "Dog took wafer from coals, ember burned haystack—full on biscuit, half on stack",
          "display_title": "Case Setup",
          "timestamp": "17:13"
        },
        {
          "title": "Tosefta says: chatzi nezek migufo—seemingly proves tzeroros pays from body",
          "display_title": "Tosefta Evidence",
          "timestamp": "19:13"
        },
        {
          "title": "Problem: Rabbi Eliezer disagrees (full amount); full migufo contradicts tzeroros logic",
          "display_title": "Rabbi Eliezer Contradict…",
          "timestamp": "19:37"
        },
        {
          "title": "Gemara explanation: not tzeroros but meshuneh (unusual)—case of keren in chatzer hanizak",
          "display_title": "Meshuneh Reading",
          "timestamp": "20:49"
        },
        {
          "title": "Rabbi Eliezer holds like Rabbi Tarfon: meshuneh keren in private property pays full",
          "display_title": "Rabbi Tarfon Position",
          "timestamp": "21:45"
        },
        {
          "title": "Gemara: why would Rabbi Eliezer pay migufo if it's full like Rabbi Tarfon?",
          "display_title": "Migufo Challenge",
          "timestamp": "24:01"
        },
        {
          "title": "Resolution: Rabbi Eliezer holds like Rabbi Yehuda (tam becomes muad)—first half migufo, second half out of pocket",
          "display_title": "Rabbi Yehuda Model",
          "timestamp": "25:25"
        },
        {
          "title": "Rav Sama to Ravina: Rabbi Yehuda's half-and-half works for tam→muad, not muad from start",
          "display_title": "Rav Sama Objection",
          "timestamp": "26:26"
        }
      ]
    },
    {
      "title": "Rava's Third Question: Does Warning Three Times (Ha'ada'ah) Turn Tzeroros into Full Damages?",
      "display_title": "Ha'ada'ah for Tzeroros",
      "timestamp": "28:50",
      "micro_segments": [
        {
          "title": "Rava asks: is there ha'ada'ah for tzeroros, or does warning not apply?",
          "display_title": "Ha'ada'ah Question",
          "timestamp": "28:50"
        },
        {
          "title": "Hidus baraita reread: maybe debate is whether warning three times makes it muad (full)",
          "display_title": "Three-Time Warning",
          "timestamp": "40:04"
        },
        {
          "title": "Gemara: can't prove it; might be one occurrence, just Sumchus vs. Rabbanan debate",
          "display_title": "Single vs. Repeated",
          "timestamp": "41:04"
        }
      ]
    },
    {
      "title": "Defecating Animal Case: Tzeroros as Extension of Body vs. Distinct from Body",
      "display_title": "Defecation Case",
      "timestamp": "41:18",
      "micro_segments": [
        {
          "title": "Baraita: animal defecated in dough—Rabbi Yehuda full amount, Rabbi Eliezer half",
          "display_title": "Case Setup",
          "timestamp": "41:18"
        },
        {
          "title": "Gemara: if normal act (crowded), debate might be three-time warning scenario",
          "display_title": "Normal vs. Unusual",
          "timestamp": "42:02"
        },
        {
          "title": "Why include defecation scenario? To show tzeroros is not viewed as body extension",
          "display_title": "Pedagogical Purpose",
          "timestamp": "42:57"
        },
        {
          "title": "Rabbi Yehuda holds like Sumchus (full); debate is Sumchus vs. Rabbanan",
          "display_title": "Sumchus vs. Rabbanan",
          "timestamp": "43:00"
        }
      ]
    }
