  "macro_segments": [
    {
      "title": "Introduction: Migo and the Integrity of the Court System",
      "display_title": "Migo & Court Integrity",
      "timestamp": "00:00",
      "micro_segments": [
        {
          "title": "Opening remarks on Daf 33 and review of Migo principle from previous day's case",
          "display_title": "Opening & Migo Review",
          "timestamp": "00:00"
        },
        {
          "title": "The forged document case: Why Tosafot rejects Migo when the alternative claim would involve dishonesty",
          "display_title": "Forged Doc & Migo",
          "timestamp": "00:31"
        },
        {
          "title": "The Rashba's responsum on false evidence in court and the tension with Ovid inish dina l'nafshe",
          "display_title": "Rashba & False Evidence",
          "timestamp": "01:08"
        },
        {
          "title": "Discussion of Migo in modern Batei Din and the gap between theory and practice",
          "display_title": "Migo in Modern Courts",
          "timestamp": "03:02"
        }
      ]
    },
    {
      "title": "Case of Rabba bar Sharshom: Mortgage, Migo, and the prohibition against collecting from orphans without oath",
      "display_title": "Rabba bar Sharshom",
      "timestamp": "04:25",
      "micro_segments": [
        {
          "title": "The rumor and admission: Rabba bar Sharshom held land as collateral (mashkanta) from orphans' father",
          "display_title": "Mortgage Explanation",
          "timestamp": "04:25"
        },
        {
          "title": "Explanation of mashkanta d'Sura and how the collateral arrangement worked",
          "display_title": "Mashkanta d'Sura",
          "timestamp": "05:24"
        },
        {
          "title": "Rabba's strategy: Using Migo based on Chazaka to avoid making a shevua when collecting the father's other debt from orphans",
          "display_title": "Strategy via Migo",
          "timestamp": "06:44"
        },
        {
          "title": "Abaye's rejection: Kol that the land belonged to orphans prevents the Migo claim",
          "display_title": "Abaye's Rejection",
          "timestamp": "12:46"
        },
        {
          "title": "Rashbam's explanation: The Kol about mashkanta prevents claiming Chazaka; Tosafot's explanation: the Kol about original ownership and the issue of Ha'azat Panim (brazenness)",
          "display_title": "Rashbam vs Tosafot",
          "timestamp": "16:21"
        }
      ]
    },
    {
      "title": "Case of Rav Idi bar Avin: Dispute over palm tree inheritance and the meaning of admission",
      "display_title": "Rav Idi Bar Avin",
      "timestamp": "22:57",
      "micro_segments": [
        {
          "title": "Two relatives claim closer kinship to inherit the palm tree; one squats on the land",
          "display_title": "Inheritance Dispute",
          "timestamp": "22:57"
        },
        {
          "title": "The admitting party concedes; debate whether this is a retraction or merely a gift",
          "display_title": "Admission Debate",
          "timestamp": "24:47"
        },
        {
          "title": "Rashbam's reading: non-contesting gift (Matana); Tosafot's alternative readings and the role of witnesses",
          "display_title": "Gift vs Retraction",
          "timestamp": "26:39"
        },
        {
          "title": "Third explanation: Witnesses established Rav Idi as a relative; Migo applies to fruit since witnesses don't establish closer kinship",
          "display_title": "Witnesses & Migo",
          "timestamp": "30:31"
        }
      ]
    },
    {
      "title": "Case of ancestral plot (Shel Avotai): Chazaka against testimony of original ownership",
      "display_title": "Ancestral Plot Claim",
      "timestamp": "33:53",
      "micro_segments": [
        {
          "title": "Two claimants: one has witnesses to original ownership, one has two years of Chazaka",
          "display_title": "Two Claimants",
          "timestamp": "33:53"
        },
        {
          "title": "Rav Chisda's Migo: Claimant with Chazaka could have claimed purchase; therefore believed on ancestral ownership",
          "display_title": "Rav Chisda Migo",
          "timestamp": "34:25"
        },
        {
          "title": "Abaye and Rava's rejection: Witnesses to original ownership contradict the claim of ancestral plot",
          "display_title": "Abaye & Rava",
          "timestamp": "35:27"
        }
      ]
    },
    {
      "title": "Case of one witness to Chazaka: The problem of evidentiary sufficiency and land reversion",
      "display_title": "One Witness Case",
      "timestamp": "37:15",
      "micro_segments": [
        {
          "title": "Claimant brings one witness to two years of Chazaka; Rav Nachman rules land and fruit revert",
          "display_title": "Insufficient Proof",
          "timestamp": "37:15"
        },
        {
          "title": "Rav Zvid: If claimant had claimed sharecropper or fruit rights (without claiming land), he would be believed",
          "display_title": "Sharecropper Claim",
          "timestamp": "39:45"
        },
        {
          "title": "Principle: People don't lie brazenly in public about ownership; therefore sharecropper claim is believed without a Shtar",
          "display_title": "Brazenness Principle",
          "timestamp": "40:10"
        },
        {
          "title": "Land requires a Shtar to verify, but fruit doesn't because Sharot for fruit are not customary",
          "display_title": "Land vs Fruit Shtar",
          "timestamp": "45:50"
        },
        {
          "title": "Case where claimant finds one witness to three years of Chazaka but still fails to prove ownership",
          "display_title": "Witness Problem",
          "timestamp": "48:43"
        }
      ]
    },
    {
      "title": "Case of the Silver Ingot (Naska): One witness as adverse or supportive testimony",
      "display_title": "Silver Ingot Case",
      "timestamp": "50:07",
      "micro_segments": [
        {
          "title": "Taker admits taking the item but claims it was his; one witness says it was stolen from the other party",
          "display_title": "Item Taking Scenario",
          "timestamp": "50:07"
        },
        {
          "title": "Rabbi Ami's dilemma: How to adjudicate when one witness makes a claim the defendant admits but reframes",
          "display_title": "Rabbi Ami's Dilemma",
          "timestamp": "50:29"
        },
        {
          "title": "Rabbi Ami's ruling: Defendant must take a Shevua he cannot make; one witness to taking makes defendant a Gazlan",
          "display_title": "Gazlan Principle",
          "timestamp": "51:56"
        },
        {
          "title": "Abaye's distinction: Witness to taking from backpack is adverse (supports payment); witness to three-year Chazaka is supportive (would win case with two witnesses)",
          "display_title": "Adverse vs Supportive",
          "timestamp": "54:40"
        }
      ]
    }
  ],
