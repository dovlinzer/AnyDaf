    {
      "title": "Placing the Lots on the Animals (Hanachah) and Its Necessity",
      "display_title": "Placing Lots",
      "timestamp": "50:07",
      "micro_segments": [
        {
          "title": "Braitah: If Torah Said 'Et HaSair Asher Alav' (On It) vs. 'Asher Ala Alav' (That Fell on It)",
          "display_title": "Asher Alav",
          "timestamp": "50:07"
        },
        {
          "title": "Once the Lot Is Drawn (Ala), It Is Not Necessary to Place It (Hanachah Is Not Me'akev)",
          "display_title": "Not Me'akev",
          "timestamp": "50:13"
        },
        {
          "title": "Gemara's Challenge: Can This Mean You Don't Even Lechatchila Have to Place It?",
          "display_title": "Lechatchila?",
          "timestamp": "50:33"
        },
        {
          "title": "Conclusion: Bedi'avad If You Don't Place It, You're Yotzei; Thus Hagralah Is Me'akev, Hanachah Is Not",
          "display_title": "Hagralah Yes/Hanachah No",
          "timestamp": "50:55"
        },
        {
          "title": "Rava's Alternative: The Language Means You Don't Have to Keep It on Until Shechita, Only Momentarily",
          "display_title": "Rava Moment",
          "timestamp": "51:14"
        },
        {
          "title": "This Reinterpretation Avoids Implications About Hagralah's Me'akev Status",
          "display_title": "Avoids Hagralah",
          "timestamp": "52:04"
        }
      ]
