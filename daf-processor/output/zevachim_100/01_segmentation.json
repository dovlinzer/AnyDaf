  "macro_segments": [
    {
      "title": "The Status of Onen at Night: Reviewing the Gemara's Initial Challenges to Rabbi Shimon's Position",
      "display_title": "Onen at Night Setup",
      "timestamp": "00:00",
      "micro_segments": [
        {
          "title": "Introduction and Review of Previous Discussion on Onen Eating Korbanos",
          "display_title": "Introduction",
          "timestamp": "00:00"
        },
        {
          "title": "The Two Key Distinctions: Yom Misa vs. Yom Kvura and the Shimon's Apparent Contradiction",
          "display_title": "Yom Misa/Kvura Distincti…",
          "timestamp": "00:14"
        },
        {
          "title": "Rabbi Shimon's Position: Aninus Layla is Not De'oraisa, Proven by Eating Korban Pesach at Night",
          "display_title": "Shimon's Proof",
          "timestamp": "01:10"
        },
        {
          "title": "The Internal Contradiction in Rabbi Shimon: Cannot Bring Pesach for Onen Because Not Shalem, Yet Can Eat It at Night",
          "display_title": "Shimon's Contradiction",
          "timestamp": "01:41"
        }
      ]
    },
    {
      "title": "Rav Mari's Resolution: The Difference Between Yom Misa and Yom Kvura Determines Whether Korban Pesach Is Brought",
      "display_title": "Rav Mari's Answer",
      "timestamp": "02:33",
      "micro_segments": [
        {
          "title": "Rav Mari's Distinction: When Death and Burial Occur on the Same Day (14th) vs. Different Days",
          "display_title": "Death/Burial Same Day",
          "timestamp": "02:33"
        },
        {
          "title": "Case 1: Yom Misa and Yom Kvura on Same Day (14th) – Aninus De'oraisa, Night Is Forbidden, No Pesach Brought",
          "display_title": "Same Day Case",
          "timestamp": "03:05"
        },
        {
          "title": "Case 2: Yom Kvura Only (Not Yom Misa) – Aninus Mi-Derabbanan, Night Is Permitted, Pesach May Be Brought",
          "display_title": "Different Days Case",
          "timestamp": "03:37"
        },
        {
          "title": "Rav Ashi's Challenge: How Can Rav Mari Limit Rabbi Shimon's Proof to Yom Kvura When the Debate Is About Yom Misa?",
          "display_title": "Rav Ashi's Challenge",
          "timestamp": "05:24"
        }
      ]
    },
    {
      "title": "Abbaye's Resolution: The Timing of When Onen Status vs. Pesach Obligation Occurs Determines Priority",
      "display_title": "Abbaye's Answer",
      "timestamp": "07:29",
      "micro_segments": [
        {
          "title": "Abbaye's Principle: Whichever Status Attaches First Takes Precedence (Before or After Chatzos)",
          "display_title": "Status Priority Principle",
          "timestamp": "07:29"
        },
        {
          "title": "Case 1: Death Before Chatzos – Onen Status Comes First, Pesach Obligation Cannot Override It",
          "display_title": "Death Before Chatzos",
          "timestamp": "08:03"
        },
        {
          "title": "Case 2: Death After Chatzos – Pesach Obligation Comes First, Onen Status Cannot Override It",
          "display_title": "Death After Chatzos",
          "timestamp": "08:29"
        },
        {
          "title": "Proof from Yosef the Kohen: The Story of Forced Tumah and Pesach Demonstrates Status Priority",
          "display_title": "Yosef Story",
          "timestamp": "11:58"
        },
        {
          "title": "The Baraita on Nazir: Even with Multiple Stringent Statuses, Meis Mitzvah Overrides All of Them",
          "display_title": "Nazir Baraita",
          "timestamp": "13:18"
        },
        {
          "title": "Reconciliation of Conflicting Baraitot: Yosef Before Chatzos vs. Uleachoso After Chatzos",
          "display_title": "Baraita Reconciliation",
          "timestamp": "17:04"
        },
        {
          "title": "Inference from Both Baraitot: Status Priority Principle Applies to Tumah, Therefore Also to Onen and Pesach",
          "display_title": "Inference to Onen",
          "timestamp": "18:12"
        }
      ]
    },
    {
      "title": "Rava's Resolution: The Distinction Between Bringing vs. Eating the Korban Pesach",
      "display_title": "Rava's Answer",
      "timestamp": "23:56",
      "micro_segments": [
        {
          "title": "Rava's Elegant Distinction: Don't Bring Pesach on Behalf of Onen; If Already Brought, Eating Is Permitted",
          "display_title": "Bring vs. Eat",
          "timestamp": "23:56"
        },
        {
          "title": "Case 1: Before Shechita and Zerika – Pesach Is Not Brought on Behalf of Onen Because He Is Not Shalem",
          "display_title": "Before Shechita",
          "timestamp": "24:31"
        },
        {
          "title": "Case 2: After Shechita and Zerika – Pesach Already Brought, Eating Overrides Aninus Layla Because It Is De'rabbanan",
          "display_title": "After Shechita",
          "timestamp": "24:31"
        },
        {
          "title": "Rav Adda's Challenge: If Already Brought, Why Permit Eating? What Was Done Was Done",
          "display_title": "Rav Adda's Challenge",
          "timestamp": "25:24"
        },
        {
          "title": "Ravina's Response: Eating the Pesach Is Me'akeiv (Essential) for Fulfilling the Mitzvah",
          "display_title": "Eating Me'akeiv",
          "timestamp": "26:27"
        },
        {
          "title": "The Unique Status of Korban Pesach: Unlike Other Korbanos, Eating Is Central, Not Peripheral",
          "display_title": "Pesach Eating Centrality",
          "timestamp": "27:00"
        }
      ]
    },
    {
      "title": "The Baraita on Yom Shmuah and Likkut Atzamos: Demonstrating the Hierarchy of Aninus Statuses and the Strength of Achilas Pesach",
      "display_title": "Yom Shmuah Baraita",
      "timestamp": "28:56",
      "micro_segments": [
        {
          "title": "The Baraita: Yom Shmuah Is Like Yom Likkut Atzamos for Pesach but Not Like Yom Kvurah",
          "display_title": "Baraita Text",
          "timestamp": "28:56"
        },
        {
          "title": "Apparent Contradiction Within the Baraita: First Says No Pesach at Night on Yom Kvurah; Later Says Can Eat Kodashim at Night",
          "display_title": "Internal Contradiction",
          "timestamp": "31:40"
        },
        {
          "title": "Rav Chisda's First Resolution: The Baraita Contains Conflicting Tannaim with Different Views on Night Following Yom Kvurah",
          "display_title": "Rav Chisda's Answer",
          "timestamp": "31:58"
        },
        {
          "title": "Rabba Bar Rav Huna's Resolution: Timing Matters – When Yom Shmuah/Likkut Occurs Before vs. After Nightfall",
          "display_title": "Rabba Bar Rav Huna",
          "timestamp": "32:19"
        },
        {
          "title": "Rav Ashi's Alternative Reading: Echad Zeh VeEchad Zeh Refers Only to Yom Shmuah vs. Likkut, Not Including Yom Kvurah",
          "display_title": "Rav Ashi's Reading",
          "timestamp": "38:03"
        },
        {
          "title": "The Gemara's Rejection: Rav Ashi's Reading Doesn't Account for Why Kodashim Are Mentioned If Pesach Is Forbidden",
          "display_title": "Rejection of Rav Ashi",
          "timestamp": "38:46"
        }
      ]
    },
    {
      "title": "The Tannaitic Debate on Aninus: Tanna Kamma vs. Rabbi on Whether Yom Kvurah Extends Into the Night",
      "display_title": "Tanna Kamma/Rabbi Debate",
      "timestamp": "40:28",
      "micro_segments": [
        {
          "title": "The Baraita: Ad Masai Misonin Alav – How Long Does Onen Status Last?",
          "display_title": "Duration of Onen",
          "timestamp": "40:28"
        },
        {
          "title": "Tanna Kamma: The Entire Day; Rabbi: Until Burial Occurs (Potentially Extending Beyond the Day)",
          "display_title": "Tanna Kamma vs. Rabbi",
          "timestamp": "40:54"
        },
        {
          "title": "Initial Challenge: Both Views Seem to Allow Night; How Do We Get a Debate on Whether Night Follows Yom Kvurah?",
          "display_title": "Initial Problem",
          "timestamp": "41:22"
        },
        {
          "title": "Rav Sheshes' Attempted Resolution: The Debate Is About Yom Kvurah, Not Yom Misa",
          "display_title": "Rav Sheshes' Attempt",
          "timestamp": "42:22"
        },
        {
          "title": "Rav Yosef's Counter-Challenge: But the Previous Baraita Says Yom Shmuah and Likkut Allow Eating; Implies Yom Kvurah Does Not",
          "display_title": "Rav Yosef's Challenge",
          "timestamp": "42:40"
        },
        {
          "title": "Gemara's Reinterpretation: Restructuring the Debate to Make Rabbi the Machmir – Tanna Kamma: Day Without Night; Rabbi: Including Night After Burial",
          "display_title": "Reinterpreted Debate",
          "timestamp": "44:45"
        },
        {
          "title": "Final Position: Yom Kvurah May or May Not Extend Into the Night for Kodashim; Likkut Atzamos and Yom Shmuah Do Not",
          "display_title": "Final Position",
          "timestamp": "48:44"
        }
      ]
    }
  ],
