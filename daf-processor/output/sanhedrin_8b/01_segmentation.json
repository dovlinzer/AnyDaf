{
  "masechta": "Sanhedrin",
  "daf": 8,
  "amud": "b",
  "macro_segments": [
    {
      "title": "Introduction to Motzi Shem Ra and the Yerushalmi's Two Explanations",
      "display_title": "Motzi Shem Ra Intro",
      "timestamp": "00:01",
      "micro_segments": [
        {
          "title": "Overview of Motzi Shem Ra and case classification",
          "display_title": "Case Classification",
          "timestamp": "00:01"
        },
        {
          "title": "Yerushalmi's two interpretations: against woman vs. against man",
          "display_title": "Yerushalmi Two Views",
          "timestamp": "00:13"
        }
      ]
    },
    {
      "title": "The Bavli's Cryptic Debate and Ulla's Explanation via Choshedim la'La'az",
      "display_title": "Ulla & La'az Debate",
      "timestamp": "00:28",
      "micro_segments": [
        {
          "title": "The Bavli's statement: Chachamim say twenty-three, Rabbi Meir says three",
          "display_title": "Bavli Position",
          "timestamp": "00:28"
        },
        {
          "title": "Ulla's explanation: the debate turns on fear of rumor and evolution to capital case",
          "display_title": "Ulla's Framework",
          "timestamp": "00:59"
        },
        {
          "title": "Rashi's reading: case against woman, three initially, fear of escalation to death penalty",
          "display_title": "Rashi's Reading",
          "timestamp": "01:24"
        },
        {
          "title": "Tosafot's objection: Motzi Shem Ra refers to case against man, not woman",
          "display_title": "Tosafot Disputes",
          "timestamp": "02:30"
        },
        {
          "title": "Tosafot's complex explanation involving neutralized witnesses and evolution to zomemin",
          "display_title": "Tosafot Zomemin Theory",
          "timestamp": "03:41"
        },
        {
          "title": "Two meanings of choshedim la'la'az: fear of escalation vs. fear of judges' honor",
          "display_title": "La'az Meanings",
          "timestamp": "05:02"
        },
        {
          "title": "Tosafot shows this debate parallels implicit disagreement in Yerushalmi",
          "display_title": "Bavli-Yerushalmi Parallel",
          "timestamp": "06:10"
        }
      ]
    },
    {
      "title": "Rava's Alternative: Judges' Honor Rather Than Fear of Escalation",
      "display_title": "Rava's Honor Theory",
      "timestamp": "08:17",
      "micro_segments": [
        {
          "title": "Rava: everyone agrees we don't fear rumor turning three into twenty-three",
          "display_title": "Rava Reframes",
          "timestamp": "08:17"
        },
        {
          "title": "The real debate is fear for honor of judges when court disperses",
          "display_title": "Honor of Judges",
          "timestamp": "08:31"
        },
        {
          "title": "The case: started with twenty-three, witnesses scattered, plaintiff seeks monetary case",
          "display_title": "Dispersal Scenario",
          "timestamp": "08:44"
        },
        {
          "title": "Rabbi Meir allows dismissing twenty judges; Chachamim say keep all twenty-three",
          "display_title": "Dismissal Dispute",
          "timestamp": "09:30"
        }
      ]
    },
    {
      "title": "Baraita Reconciliation: Case Against Woman vs. Case Against Man",
      "display_title": "Baraita & Cases",
      "timestamp": "09:53",
      "micro_segments": [
        {
          "title": "Baraita: monetary case three, capital case twenty-three",
          "display_title": "Baraita Statement",
          "timestamp": "09:53"
        },
        {
          "title": "Problem for Ulla: baraita seems to agree with Rabbi Meir that monetary is three",
          "display_title": "Ulla's Problem",
          "timestamp": "10:59"
        },
        {
          "title": "Rava's solution: husband brought witnesses of adultery, father proved them zomemin",
          "display_title": "Rava's Solution",
          "timestamp": "11:18"
        },
        {
          "title": "Case against man is always three; case against woman could be twenty-three if mekom nefashot",
          "display_title": "Man vs Woman Cases",
          "timestamp": "11:43"
        },
        {
          "title": "This parallels Yerushalmi's switch between case against woman and case against man",
          "display_title": "Yerushalmi Parallel",
          "timestamp": "13:07"
        }
      ]
    },
    {
      "title": "Amoraim's Alternative Interpretations: Hatra'ah Requirements and Witness Validity",
      "display_title": "Alternative Readings",
      "timestamp": "17:01",
      "micro_segments": [
        {
          "title": "Abaye: everyone agrees on choshedim la'la'az; real debate is hatra'ah specificity",
          "display_title": "Abaye & Hatra'ah",
          "timestamp": "17:01"
        },
        {
          "title": "Baraita on death penalties: explicit warning required identifying specific death",
          "display_title": "Baraita Death Rules",
          "timestamp": "17:35"
        },
        {
          "title": "Rabbi Meir: no specific death warning, so no capital case, three judges suffice",
          "display_title": "Meir No Capital",
          "timestamp": "18:37"
        },
        {
          "title": "Rav Pappa: woman is learned (chaverah), debate parallels Rabbi Yosi bar Rabbi Yehuda on warning for scholars",
          "display_title": "Pappa Chaverah",
          "timestamp": "19:16"
        },
        {
          "title": "Rav Ashi: warned with lashes not death, so never capital case, only three",
          "display_title": "Ashi Wrong Warning",
          "timestamp": "21:38"
        },
        {
          "title": "Ravina: one witness is relative, debate parallels Rabbi Yishmael on malkus judges",
          "display_title": "Ravina Relative",
          "timestamp": "22:48"
        }
      ]
    },
    {
      "title": "Rabbi Akiva's Three-Witness Rule and Kosher Witnesses in Monetary vs. Capital Cases",
      "display_title": "Akiva & Witnesses",
      "timestamp": "23:36",
      "micro_segments": [
        {
          "title": "Rabbi Akiva: Torah says two or three to teach third witness gets same punishment",
          "display_title": "Akiva Third Witness",
          "timestamp": "23:36"
        },
        {
          "title": "Principle: if one witness is karov or pasul, all testimony is void",
          "display_title": "All Void Principle",
          "timestamp": "25:06"
        },
        {
          "title": "Rabbi Yosi: principle applies only to dinei nefashot; monetary case keeps kosher witnesses",
          "display_title": "Yosi Distinction",
          "timestamp": "26:29"
        },
        {
          "title": "Rabbi (Yehuda): principle applies to both, but only if witnesses actively participate",
          "display_title": "Rabbi Active Witness",
          "timestamp": "26:51"
        },
        {
          "title": "Tosafot on requirement of yichud edim and appearing before beit din",
          "display_title": "Tosafot Yichud",
          "timestamp": "28:28"
        }
      ]
    },
    {
      "title": "Alternative Reading: Invalid Witness Case Reconciles Mishnah with Witness Principles",
      "display_title": "Invalid Witness Reading",
      "timestamp": "30:43",
      "micro_segments": [
        {
          "title": "One of three witnesses is pasul; Rabbi Meir says only monetary case possible with two kosher",
          "display_title": "Meir One Invalid",
          "timestamp": "30:43"
        },
        {
          "title": "Chachamim: invalid witness didn't warn or intend to testify, so two remain valid for capital",
          "display_title": "Chachamim Two Valid",
          "timestamp": "31:09"
        },
        {
          "title": "Another variant: warning given by non-witnesses, debate parallels Rabbi Yosi on witness warning requirement",
          "display_title": "Non-Witness Warning",
          "timestamp": "32:24"
        },
        {
          "title": "Final variant: contradiction in bedikos not chakiyros, debate parallels Ben Zakkai on detailed cross-examination",
          "display_title": "Bedikos Contradiction",
          "timestamp": "33:00"
        }
      ]
    },
    {
      "title": "Double Aveirа: Case of Zomemin Against Witnesses and Against Husband",
      "display_title": "Double Aveira",
      "timestamp": "35:31",
      "micro_segments": [
        {
          "title": "Husband brings witnesses of adultery, father brings witnesses proving zomemin",
          "display_title": "Classic Setup",
          "timestamp": "35:31"
        },
        {
          "title": "Husband's witnesses executed but don't pay kesubah fine (not kim lei)",
          "display_title": "Witnesses Executed",
          "timestamp": "35:47"
        },
        {
          "title": "Husband reverses: brings witnesses against father's witnesses, proving them zomemin",
          "display_title": "Reversal Case",
          "timestamp": "36:16"
        },
        {
          "title": "Father's witnesses executed and must pay hundred shekel to husband",
          "display_title": "Both Penalties",
          "timestamp": "36:40"
        },
        {
          "title": "Distinction: mammon lezeh venefashot lezeh—separate adjudication, not kim lei",
          "display_title": "Separate Crimes",
          "timestamp": "37:22"
        }
      ]
    }
  ],
