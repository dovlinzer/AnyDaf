{
  "masechta": "Bava Batra",
  "daf": 85,
  "amud": "a",
  "macro_segments": [
    {
      "title": "Introduction to Kinyan Kli and the Question of Its Validity in Different Domains",
      "display_title": "Kinyan Kli Overview",
      "timestamp": "00:15",
      "micro_segments": [
        {
          "title": "Previous Position: Kinyan Kli in a Simta and the Concept of Kli as Chatzer",
          "display_title": "Kli as Chatzer",
          "timestamp": "00:15"
        },
        {
          "title": "The Central Question: Does Kinyan Kli Work When the Vessel is in the Seller's Domain (Reshut Hamocher)?",
          "display_title": "Kli in Reshut Hamocher",
          "timestamp": "01:03"
        }
      ]
    },
    {
      "title": "Dispute Between Bavli and Eretz Yisrael Authorities: Kinyan Kli in Reshut Harabim",
      "display_title": "Kli in Reshut Harabim",
      "timestamp": "02:15",
      "micro_segments": [
        {
          "title": "Position of Rav and Shmuel: Kli Works Everywhere Except Reshut Harabim",
          "display_title": "Rav and Shmuel",
          "timestamp": "02:15"
        },
        {
          "title": "Position of Rabbi Yochanan and Reish Lakish: Kli Works Even in Reshut Harabim",
          "display_title": "Rabbi Yochanan EY Positi…",
          "timestamp": "02:39"
        },
        {
          "title": "Rav Papa's Reconciliation: The Dispute is About Terminology, Not Substance",
          "display_title": "Rav Papa Reconciles",
          "timestamp": "02:58"
        },
        {
          "title": "Gemara's Counter-Proof: Defining Reshut Harabim as Non-Private Domain Where You Have No Right to Place Vessels",
          "display_title": "Gemara's Counter-Proof",
          "timestamp": "03:25"
        },
        {
          "title": "Conclusion: Kinyan Kli Does Not Work in Reshut Harabim Proper Because You Have No Right to Place Vessels There",
          "display_title": "No Kli in True RH",
          "timestamp": "04:24"
        }
      ]
    },
    {
      "title": "Four Categories of Transactions in the Tosefta and the Rule That Kinyan Kli Works by Reshut, Not by Kli",
      "display_title": "Four Categories",
      "timestamp": "06:33",
      "micro_segments": [
        {
          "title": "First Category: Before the Measure Fills (Ad Shelo Nismaila) Belongs to Seller; After (Mishenismaila) Belongs to Buyer",
          "display_title": "Measure Filling Rule",
          "timestamp": "06:33"
        },
        {
          "title": "The Case When Measure Belongs to Third Party: It is the Seller's Kli Until Filled, Then the Buyer's by Kinyan Kli",
          "display_title": "Third Party Vessel",
          "timestamp": "07:47"
        },
        {
          "title": "The Case When Measure Belongs to One of the Parties: Every Bit Acquired Immediately (Rishon Rishon Kanah)",
          "display_title": "Rishon Rishon Kanah",
          "timestamp": "09:02"
        },
        {
          "title": "Tosefta's Four Domains: Reshut Harabim and Non-Private Chatzer (Works), Reshut Hamocher (Does Not Work)",
          "display_title": "Tosefta Domains",
          "timestamp": "12:47"
        },
        {
          "title": "Reshut Lokeach: Kinyan Works Automatically Once Agreement is Reached (Kibel Alav)",
          "display_title": "Reshut Lokeach",
          "timestamp": "15:14"
        },
        {
          "title": "Reshut of Third Party: Kli Works Only if Third Party Accepts It for Buyer (Kibel Alav)",
          "display_title": "Third Party Domain",
          "timestamp": "18:11"
        }
      ]
    },
    {
      "title": "Gittin Case: Can Kinyan Kli Work When Object is in Seller's Basket in Husband's Domain?",
      "display_title": "Gittin Case Analysis",
      "timestamp": "27:40",
      "micro_segments": [
        {
          "title": "The Gittin Proof: A Get Works When Thrown into the Wife's Bosom or Basket in the Husband's House",
          "display_title": "Get in Basket",
          "timestamp": "27:40"
        },
        {
          "title": "Explanation Attempts: Is It Because Basket is Suspended, Tied to Body, or Woman Has Ongoing Right to Space?",
          "display_title": "Suspension and Tie",
          "timestamp": "32:22"
        },
        {
          "title": "Rabbi Yochanan's Position: Woman Has Proprietary Right to Where Her Lap and Basket Are (Mekom Cheika Kanuy Lah)",
          "display_title": "Mekom Cheika Kanuy",
          "timestamp": "35:16"
        },
        {
          "title": "Rava's Explanation: Man is Not Particular About Where Wife Sits or Places Her Basket, Creating Ongoing Property Right",
          "display_title": "Rava's Explanation",
          "timestamp": "35:24"
        },
        {
          "title": "Conclusion: Gittin Case Cannot Prove Kinyan Kli in Reshut Hamocher Due to Circumstantial Differences",
          "display_title": "Gittin Distinction",
          "timestamp": "39:04"
        }
      ]
    },
    {
      "title": "The Tosefta as Evidence: Does Kinyan Kli Work in Reshut Hamocher or Not?",
      "display_title": "Tosefta Evidence",
      "timestamp": "40:45",
      "micro_segments": [
        {
          "title": "Simple Reading of Tosefta: In Seller's Domain, Kli Does Not Work Without Hagbahah or Removal",
          "display_title": "Tosefta Simple Read",
          "timestamp": "40:45"
        },
        {
          "title": "Gemara's Challenge: If We're Talking About Seller's Kli, Why Does It Work in Buyer's Domain (Reshut Lokeach)?",
          "display_title": "Gemara Challenge",
          "timestamp": "43:36"
        },
        {
          "title": "Gemara's Resolution: The Tosefta Actually Goes by Domain (Reshut), Not by Kli; Assume Apples in Available Bags of Domain Owner",
          "display_title": "Goes by Reshut",
          "timestamp": "45:01"
        }
      ]
    },
    {
      "title": "The Donkey Proof: Apples Brought into Buyer's House on Seller's Donkeys",
      "display_title": "Donkey Proof",
      "timestamp": "48:36",
      "micro_segments": [
        {
          "title": "Case Setup: Apples Unloaded (Pirkan) into Buyer's House Still in Seller's Bags",
          "display_title": "Pirkan Setup",
          "timestamp": "48:36"
        },
        {
          "title": "Rule: Pesak and Madad Matter Only if Gemirut Da'at is Established; Otherwise Either Party Can Retract",
          "display_title": "Pesak and Madad",
          "timestamp": "51:25"
        },
        {
          "title": "Apparent Proof: Once Unloaded in Buyer's Chatzer, Sale is Final Even with Apples in Seller's Bags",
          "display_title": "Chatzer Proof",
          "timestamp": "52:19"
        },
        {
          "title": "Gemara's Defenses: Either Apples Were Poured Out (No Bags) or Special Case of Strings of Garlic Without Bags",
          "display_title": "Gemara Defenses",
          "timestamp": "53:12"
        }
      ]
    }
  ],
