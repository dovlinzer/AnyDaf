        },
        {
          "title": "Braita on Shechitah: Shechitah of Chulin Inside and Kodashim In/Out Does Not Become Neveilah",
          "display_title": "Shechitah Braita",
          "timestamp": "19:32"
        },
        {
          "title": "The Inside-Outside Equivalence: Why Shechitah of Chulin Inside the Beit HaMikdash Is Not Neveilah",
          "display_title": "Inside-Outside Link",
          "timestamp": "22:29"
        },
        {
          "title": "Rava's Challenge: How Shechitah of Kodashim Outside Avoids Neveilah Status Despite Being Invalid Both Inside and Out",
          "display_title": "Rava Challenge",
          "timestamp": "22:52"
        },
        {
          "title": "Rava's Resolution: Shechitah of Kodashim Outside Is Meaningful (Chiyuv Karet) Therefore Not Neveilah Inside",
          "display_title": "Rava Resolution",
          "timestamp": "22:52"
        },
        {
          "title": "Rav Shimi bar Ashi: Cannot Learn from Things Done Improperly to Things Done Properly; Melikah of Kodashim Outside Remains Neveilah",
          "display_title": "Proper vs. Improper",
          "timestamp": "26:41"
        }
      ]
