  "amud": "a-b",
  "macro_segments": [
    {
      "title": "Introduction to Perek 2: Elu Metzios (Found Objects You May Keep)",
      "display_title": "Intro: Elu Metzios",
      "timestamp": "00:28",
      "micro_segments": [
        {
          "title": "Overview of Perek 2 and the foundational question of what objects may be kept",
          "display_title": "Perek Structure",
          "timestamp": "00:28"
        },
        {
          "title": "The Mishna: cases of found objects you may keep (scattered fruit, money, figs, bread, fish, meat, wool, flax, purple strips)",
          "display_title": "Mishna: Keepers",
          "timestamp": "01:06"
        },
        {
          "title": "Dispute between Rabbi Meir and Rabbi Yehuda over objects with distinguishing marks",
          "display_title": "R. Meir vs. R. Yehuda",
          "timestamp": "06:05"
        },
        {
          "title": "Rabbi Shimon ben Elazar on garments of anporya requiring no announcement",
          "display_title": "R. Shimon: Anporya",
          "timestamp": "07:02"
        }
      ]
    },
    {
      "title": "Scattered Fruit and Money: The Measure of a Kav in Four Amot",
      "display_title": "Kav be'Arba Amot",
      "timestamp": "07:35",
      "micro_segments": [
        {
          "title": "Gemara's quantification of scattered fruit: a kav in four amot",
          "display_title": "Quantity: Kav",
          "timestamp": "07:35"
        },
        {
          "title": "Gemara's challenge to quantification: the qualitative assessment of whether something appears dropped or intentionally placed",
          "display_title": "Quantity vs. Quality",
          "timestamp": "08:25"
        },
        {
          "title": "Rav Ukva bar Chama's explanation: the measure applies to grain left behind during harvest when effort vs. value determines whether owner will return",
          "display_title": "Rav Ukva's Explanation",
          "timestamp": "09:42"
        },
        {
          "title": "Rabbi Yirmeyah's questions on variations: half a kav in two amot, two kavim in eight amot, sesame seeds, dates, pomegranates—effort vs. monetary value",
          "display_title": "Variations & Effort",
          "timestamp": "12:14"
        }
      ]
    },
    {
      "title": "Yeiush Shelo Midaat (Giving Up Hope Without Awareness): The Central Debate between Abaye and Rava",
      "display_title": "Yeiush Shelo Midaat",
      "timestamp": "19:37",
      "micro_segments": [
        {
          "title": "Definition and parameters of yeiush shelo midaat: can hope be given up before the owner becomes aware of the loss?",
          "display_title": "Definition",
          "timestamp": "19:37"
        },
        {
          "title": "Abaye's position: yeiush requires conscious intent; unaware owner has no yeiush",
          "display_title": "Abaye: Conscious",
          "timestamp": "20:38"
        },
        {
          "title": "Rava's position: yeiush occurs when owner will inevitably give up hope upon discovering the loss",
          "display_title": "Rava: Inevitable",
          "timestamp": "20:54"
        },
        {
          "title": "Cases where both agree: objects with identifying marks (siman) and objects swept away by sea or river (avuda mimenu umikol adam)",
          "display_title": "Agreement Cases",
          "timestamp": "21:04"
        },
        {
          "title": "The disputed case: objects without identifying marks where owner is not yet aware of loss",
          "display_title": "Dispute: No Siman",
          "timestamp": "26:43"
        }
      ]
    },
    {
      "title": "Bringing Evidence: Explaining Cases in the Mishna as Either Avida Midaat or Rapid Awareness",
      "display_title": "Proofs from Mishna",
      "timestamp": "29:11",
      "micro_segments": [
        {
          "title": "Scattered fruit as avida midaat (intentionally left behind during warehouse clearing)",
          "display_title": "Scattered Fruit",
          "timestamp": "29:11"
        },
        {
          "title": "Scattered money and frequent checking of pockets (Rabbi Yitzchak's principle)",
          "display_title": "Scattered Money",
          "timestamp": "29:38"
        },
        {
          "title": "Figs and baker's bread: recognition through weight that they are missing",
          "display_title": "Weighty Items",
          "timestamp": "31:03"
        },
        {
          "title": "Strips of purple: valuable items regularly checked, following Rabbi Yitzchak's rule",
          "display_title": "Valuable Strips",
          "timestamp": "32:01"
        },
        {
          "title": "Money in synagogues and study halls: Rabbi Yitzchak applied to public spaces",
          "display_title": "Money in Shul",
          "timestamp": "32:49"
        }
      ]
    },
    {
      "title": "Leket (Gleanings) and Universal Awareness: The Case of Elderly Gatherers",
      "display_title": "Leket Case",
      "timestamp": "33:43",
      "micro_segments": [
        {
          "title": "When leket becomes permissible for all: after the nimoshos (elderly gatherers) have passed through",
          "display_title": "Leket Permission",
          "timestamp": "33:43"
        },
        {
          "title": "Question: poor people in other towns are not aware; how can we assume their yeiush?",
          "display_title": "Multi-Town Problem",
          "timestamp": "35:01"
        },
        {
          "title": "Answer: poor people in other towns give up hope from the beginning, knowing locals will gather first",
          "display_title": "Preemptive Yeiush",
          "timestamp": "36:32"
        }
      ]
    },
    {
      "title": "Figs vs. Olives: Permissible and Forbidden Fruit, and the Role of Disgust and Identifiability",
      "display_title": "Figs vs. Olives",
      "timestamp": "37:25",
      "micro_segments": [
        {
          "title": "Braita: figs on the road and overhanging fig trees are permissible; olives and carobs under their trees are forbidden",
          "display_title": "Braita Rule",
          "timestamp": "37:25"
        },
        {
          "title": "Abaye's explanation: figs are regularly known to fall, or become disgusting; olives and carobs do not regularly fall and remain clean",
          "display_title": "Abaye: Known Fall",
          "timestamp": "38:51"
        },
        {
          "title": "Rava's difficulty: if yeiush shelo midaat works, why should olives and carobs be forbidden?",
          "display_title": "Rava's Difficulty",
          "timestamp": "39:55"
        },
        {
          "title": "Rabbi Abahu's answer: olives and carobs are identifiable by their appearance; they are not considered without a siman",
          "display_title": "R. Abahu: Identifiable",
          "timestamp": "40:31"
        },
        {
          "title": "Rav Papa's refinement: figs become disgusting when they fall, so there is yeiush regardless; olives remain desirable, so no yeiush",
          "display_title": "R. Papa: Disgust",
          "timestamp": "41:23"
        }
      ]
    }
  ],
