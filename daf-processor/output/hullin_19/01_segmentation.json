{
  "masechta": "Hullin",
  "daf": 19,
  "amud": "a",
  "macro_segments": [
    {
      "title": "The Position of Rabbi Shimon ben Lakish on the Upper Limit of Shechita and the Debate Over Hagrama",
      "display_title": "Reish Lakish & Hagrama",
      "timestamp": "01:16",
      "micro_segments": [
        {
          "title": "Rabbi Shimon ben Lakish's permissive ruling: Shechita even at the tip of the hat",
          "display_title": "Reish Lakish Ruling",
          "timestamp": "01:16"
        },
        {
          "title": "Rabbi Yochanan's objection and Rav Papa's explanation of touching the strings",
          "display_title": "R. Yochanan Objects",
          "timestamp": "04:01"
        },
        {
          "title": "The debate over whether pagah means touching or encountering without contact",
          "display_title": "Pagah Debate",
          "timestamp": "05:39"
        },
        {
          "title": "Rav Papa's ruling: Leaving over strings makes it kosher",
          "display_title": "Shiyur B'Chite",
          "timestamp": "06:29"
        },
        {
          "title": "The halacha: Shechita is kosher only from the slanting of the cap downward",
          "display_title": "Hilchata Ruling",
          "timestamp": "07:58"
        }
      ]
    },
    {
      "title": "Rav Nachman's Position and Its Relationship to Tannaitic Opinions",
      "display_title": "Rav Nachman",
      "timestamp": "09:52",
      "micro_segments": [
        {
          "title": "Rav Nachman allows shechita from the angling of the cap downward",
          "display_title": "RN Allows Cap",
          "timestamp": "09:52"
        },
        {
          "title": "Rav Chanan challenges: How does this fit with the Mishnah's opinions?",
          "display_title": "Fitting Opinions",
          "timestamp": "10:16"
        },
        {
          "title": "Rav Nachman's response: I know my tradition, not the tannaim's debate",
          "display_title": "Tradition Defense",
          "timestamp": "11:26"
        },
        {
          "title": "Rabbi Yehoshua ben Levi explains how the tradition fits amoraic positions",
          "display_title": "Fitting Amoraim",
          "timestamp": "12:42"
        }
      ]
    },
    {
      "title": "The Conceptual Debate: Majority of the Cut vs. Correct Execution Throughout",
      "display_title": "Majority Debate",
      "timestamp": "15:29",
      "micro_segments": [
        {
          "title": "Rav Huna in the name of Rav: The debate concerns what happens after the majority is done correctly",
          "display_title": "Majority Principle",
          "timestamp": "15:29"
        },
        {
          "title": "The Rabbis' position: The entire shechita must be in the correct place",
          "display_title": "Rabbis Whole Act",
          "timestamp": "16:18"
        },
        {
          "title": "Rabbi Yosi bar Rabbi Yehuda's position: Majority is like the whole thing",
          "display_title": "RY Majority Stands",
          "timestamp": "16:36"
        },
        {
          "title": "Case: First two-thirds correct, last third too high—everyone agrees it's valid",
          "display_title": "Two-Thirds Good",
          "timestamp": "17:40"
        },
        {
          "title": "Case: First third too high, last two-thirds correct—everyone disagrees",
          "display_title": "First Third Bad",
          "timestamp": "17:52"
        },
        {
          "title": "The principle that when majority is cut, the life-force leaves at that point",
          "display_title": "Nafakat Chayuta",
          "timestamp": "18:03"
        }
      ]
    },
    {
      "title": "Rav Chisda's Challenge: Which Case Forms the Actual Debate?",
      "display_title": "Chisda Challenge",
      "timestamp": "19:14",
      "micro_segments": [
        {
          "title": "Rav Chisda reverses the case: Maybe the debate is when the beginning is wrong",
          "display_title": "Reverse Case",
          "timestamp": "19:14"
        },
        {
          "title": "Rabbi Yosi bar Rabbi Yehuda's reasoning: It's like having a pre-existing hole",
          "display_title": "Hole Analogy",
          "timestamp": "19:28"
        },
        {
          "title": "The Rabbis' counter: The correct place must be cut, not just reach the midline",
          "display_title": "Right Place Cut",
          "timestamp": "20:44"
        }
      ]
    },
    {
      "title": "The Broader Question of Majority in Shechita: Does It Stop the Analysis or Stand In for the Whole?",
      "display_title": "Rov Concept",
      "timestamp": "24:25",
      "micro_segments": [
        {
          "title": "Michael's parallel: The principle of miktzat hayom k'kulo and retroactive invalidation",
          "display_title": "Part of Day",
          "timestamp": "24:25"
        },
        {
          "title": "Rav Yosef questions whether the majority principle applies only to Rabbi Yosi bar Rabbi Yehuda",
          "display_title": "Majority Exclusive?",
          "timestamp": "26:10"
        },
        {
          "title": "Abaye's response: Within shechita, we know they debate about majority",
          "display_title": "Shechita Debate",
          "timestamp": "26:32"
        }
      ]
    },
    {
      "title": "Alternative Formulation: When Does the Invalid Act Occur—Beginning or End?",
      "display_title": "Lishna Achrina",
      "timestamp": "29:07",
      "micro_segments": [
        {
          "title": "Second version of Rav Huna's statement: The debate is when you begin incorrectly",
          "display_title": "Begin Wrong",
          "timestamp": "29:07"
        }
      ]
    },
    {
      "title": "The Middle-Third Case: Debating Whether the Middle Line or Majority of Trachea Matters",
      "display_title": "Middle Third Case",
      "timestamp": "29:32",
      "micro_segments": [
        {
          "title": "Case: First and last thirds correct, middle third too high",
          "display_title": "Good-Bad-Good",
          "timestamp": "29:32"
        }
      ]
    },
    {
      "title": "Alternative Formulation: When Does the Invalid Act Occur—Beginning or End? (continued)",
      "display_title": "Lishna Achrina (II)",
      "timestamp": "29:40",
      "micro_segments": [
        {
          "title": "If first two-thirds are correct, everyone agrees it's valid",
          "display_title": "First Two OK",
          "timestamp": "29:40"
        }
      ]
    },
    {
      "title": "The Middle-Third Case: Debating Whether the Middle Line or Majority of Trachea Matters (continued)",
      "display_title": "Middle Third Case (II)",
      "timestamp": "30:19",
      "micro_segments": [
        {
          "title": "Rav Huna in Rav's name: It's kosher because the life leaves when the middle is cut correctly",
          "display_title": "Life at Middle",
          "timestamp": "30:19"
        },
        {
          "title": "Rav Yehuda in Rav's name: It's invalid because you need the majority cut correctly",
          "display_title": "Majority Needed",
          "timestamp": "30:43"
        },
        {
          "title": "Mirror case: First and last thirds too high, middle third correct",
          "display_title": "Bad-Good-Bad",
          "timestamp": "31:25"
        },
        {
          "title": "Rav Yehuda: Now it's kosher (reversing his position)",
          "display_title": "RY Reverses",
          "timestamp": "36:01"
        },
        {
          "title": "Rav Huna takes offense: You're not being consistent with your position",
          "display_title": "RN Objects",
          "timestamp": "36:25"
        },
        {
          "title": "Rav Chisda warns Rav Huna not to reverse, as it undermines his first position",
          "display_title": "Don't Reverse",
          "timestamp": "36:39"
        }
      ]
    },
    {
      "title": "Rav Nachman's Testimony and the Comb-Like Shechita of Rabbi Elazar bar Minyumi",
      "display_title": "Comb Shechita",
      "timestamp": "37:19",
      "micro_segments": [
        {
          "title": "They ask Rav Nachman the middle-third case in Sura",
          "display_title": "Asked RN",
          "timestamp": "37:19"
        },
        {
          "title": "Rav Nachman: This is Rabbi Elazar bar Minyumi's position on comb-like shechita",
          "display_title": "Masreik Position",
          "timestamp": "37:19"
        },
        {
          "title": "The Gemara questions whether comb-like shechita in the kosher zone is really a chiddush",
          "display_title": "Kosher Zone Only",
          "timestamp": "37:19"
        }
      ]
    },
    {
      "title": "The Case of Pre-Existing Cuts: Front vs. Back Holes in the Trachea",
      "display_title": "Pre-Existing Cuts",
      "timestamp": "37:19",
      "micro_segments": [
        {
          "title": "Rabbi Abba reports Rav Kahana's questions to Rabbi Yochanan about pre-existing cuts",
          "display_title": "RK Questions",
          "timestamp": "37:19"
        },
        {
          "title": "Rav Kahana: If there's a front hole, you can finish it; if there's a back hole, you cannot",
          "display_title": "Front vs Back",
          "timestamp": "37:19"
        },
        {
          "title": "Rabbi Elazar explains: Front hole = non-Jew started, Jew finished; back hole = Jew started, non-Jew finished",
          "display_title": "Goy Analogy",
          "timestamp": "37:19"
        },
        {
          "title": "Rabbi Yochanan rejects the analogy as flawed",
          "display_title": "Reject Analogy",
          "timestamp": "37:19"
        },
        {
          "title": "Rava defends the objection: The analogy doesn't work because you're doing the whole act",
          "display_title": "Whole Act Defense",
          "timestamp": "37:19"
        }
      ]
    },
    {
      "title": "Shechita and Melikah: The Contrast Between Front/Side and Back of Neck",
      "display_title": "Shechita vs Melikah",
      "timestamp": "52:54",
      "micro_segments": [
        {
          "title": "Shechita from the side is valid; melikah from the side is invalid",
          "display_title": "Side Shechita",
          "timestamp": "52:54"
        },
        {
          "title": "Shechita from the back is invalid; melikah from the back is valid",
          "display_title": "Back Melikah",
          "timestamp": "52:54"
        },
        {
          "title": "Shechita from the front (throat) is valid; melikah from the front is invalid",
          "display_title": "Front Shechita",
          "timestamp": "52:54"
        },
        {
          "title": "Summary: The entire back of neck is kosher for melikah; the entire throat and sides are kosher for shechita",
          "display_title": "Summary",
          "timestamp": "52:54"
        }
      ]
    }
