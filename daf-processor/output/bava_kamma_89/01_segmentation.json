{
  "masechta": "Bava Kamma",
  "daf": 89,
  "amud": "b",
  "macro_segments": [
    {
      "title": "The Case of the Mother's Gift and the Question of Kinyan Peirot vs. Kinyan Haguf",
      "display_title": "Mother's Gift & Kinyan",
      "timestamp": "00:00",
      "micro_segments": [
        {
          "title": "Setup: Woman's Nichsei Miluog Property, Husband's Usufruct Rights, and the Question of Transfer Authority",
          "display_title": "Nichsei Miluog Setup",
          "timestamp": "00:00"
        },
        {
          "title": "The Proof from Father-and-Son Case: Can the Son Transfer Title When Father Retains Peirot?",
          "display_title": "Father-Son Proof",
          "timestamp": "01:46"
        },
        {
          "title": "Rabbi Yirmiyah bar Abba's Ruling and Its Implications for the Wife's Gift",
          "display_title": "R. Yirmiyah's Ruling",
          "timestamp": "02:25"
        }
      ]
    },
    {
      "title": "Rav Yehuda's Objection and the Alternative Explanation via Abaye",
      "display_title": "Rav Yehuda & Abaye",
      "timestamp": "03:00",
      "micro_segments": [
        {
          "title": "Shmuel's Position: The Father-Son Case Is Not Analogous to Wife and Husband",
          "display_title": "Shmuel's Distinction",
          "timestamp": "03:00"
        },
        {
          "title": "Rav Yosef's Reasoning: The Son's Inheritance Prospects in the Context of Multiple Heirs",
          "display_title": "Rav Yosef's Logic",
          "timestamp": "03:30"
        },
        {
          "title": "Abaye's Counterargument: The Son Will Not Inherit This Specific Property in Full",
          "display_title": "Abaye's Counter",
          "timestamp": "05:15"
        }
      ]
    },
    {
      "title": "Introduction of Takanas Usha as the Resolution",
      "display_title": "Takanas Usha",
      "timestamp": "08:00",
      "micro_segments": [
        {
          "title": "The Gemara's Acknowledgment that Principle Supports the Wife's Right, Yet Takanas Usha Overrides It",
          "display_title": "Principle vs. Takana",
          "timestamp": "08:00"
        },
        {
          "title": "Rabbi Yosi bar Chanina's Explicit Statement of Takanas Usha: Husband Inherits Despite Sale",
          "display_title": "R. Yosi's Statement",
          "timestamp": "08:34"
        },
        {
          "title": "Historical Context: When Was Takanas Usha Instituted and Who Knew of It?",
          "display_title": "Takana Timeline",
          "timestamp": "09:32"
        }
      ]
    },
    {
      "title": "The Braisa of the Woman Divorced and the Proof of Takanas Usha via Witnesses' Liability",
      "display_title": "Braisa: False Witnesses",
      "timestamp": "12:25",
      "micro_segments": [
        {
          "title": "The Case of False Witnesses Claiming the Woman Was Divorced and Collected Her Kesuvah",
          "display_title": "False Witnesses Setup",
          "timestamp": "12:25"
        },
        {
          "title": "The Liability Calculation: What Is the Monetary Value of the Kesuvah the Witnesses Tried to Rob?",
          "display_title": "Kesuvah Value",
          "timestamp": "13:31"
        },
        {
          "title": "Abaye's Question: Does the Nichsei Miluog Fully Lose Its Value, or Is It Separable from the Rest?",
          "display_title": "Abaye's Question",
          "timestamp": "17:53"
        },
        {
          "title": "The Gemara's Answer: The Discussion Concerns the Dowry and Other Components, Not Nichsei Miluog",
          "display_title": "Gemara's Answer",
          "timestamp": "22:10"
        }
      ]
    },
    {
      "title": "Továs Hana'ah: The Market Value of the Kesuvah and Its Ownership by the Wife",
      "display_title": "Tovas Hana'ah",
      "timestamp": "22:44",
      "micro_segments": [
        {
          "title": "Definition: Tovas Hana'ah as the Discounted Value of a Future, Conditional Benefit",
          "display_title": "Tovas Hana'ah Defined",
          "timestamp": "22:44"
        },
        {
          "title": "Rav Shaman's Objection and the Distinction Between Direct and Indirect Benefit",
          "display_title": "Rav Shaman's Objection",
          "timestamp": "25:36"
        },
        {
          "title": "Principle Established: The Wife Owns the Tovas Hana'ah, Not the Husband",
          "display_title": "Wife Owns Tovas",
          "timestamp": "26:32"
        },
        {
          "title": "Rava's Ruling: Tovas Hana'ah Belongs Wholly to the Wife; Husband Takes No Peirot from It",
          "display_title": "Rava's Ruling",
          "timestamp": "26:32"
        },
        {
          "title": "Explanation: Peirot Were Established for the Husband, But Peirot d'Peirot (Derivative Benefit) Were Not",
          "display_title": "Peirot d'Peirot",
          "timestamp": "28:13"
        }
      ]
    },
    {
      "title": "Return to the Mishna: Proof of Takanas Usha from the Woman's Inability to Pay for Injury",
      "display_title": "Back to Mishna",
      "timestamp": "29:16",
      "micro_segments": [
        {
          "title": "The Mishna's Statement: Woman and Slave Have Bad Encounters; If Injured They Pay, If They Injure Others They Are Exempt",
          "display_title": "Mishna Statement",
          "timestamp": "29:16"
        },
        {
          "title": "The Question: Why Can't She Sell Her Nichsei Miluog at Tovas Hana'ah to Pay the Injured Party?",
          "display_title": "Why Can't She Pay?",
          "timestamp": "30:39"
        },
        {
          "title": "The Gemara's Challenge: Shmuel's Rule on Forgiving Debts Prevents Forced Sale of Kesuvah Rights",
          "display_title": "Shmuel's Debt Rule",
          "timestamp": "34:55"
        }
      ]
    },
    {
      "title": "Case: Woman Injured Her Husband and the Rules Against Selling Kesuvah Back to Him",
      "display_title": "Woman Injured Husband",
      "timestamp": "44:59",
      "micro_segments": [
        {
          "title": "Braisa: Woman Who Injured Her Husband Does Not Lose Her Kesuvah; Her Husband Cannot Take It Back",
          "display_title": "Braisa Statement",
          "timestamp": "44:59"
        },
        {
          "title": "The Logical Problem: Why Not Sell the Kesuvah Back to the Husband at Tovas Hana'ah to Offset the Injury Debt?",
          "display_title": "Logical Problem",
          "timestamp": "45:17"
        },
        {
          "title": "Rabbi Meir's Principle: A Man Cannot Be Married Without a Kesuvah, to Prevent Easy Divorce",
          "display_title": "Rabbi Meir's Principle",
          "timestamp": "47:48"
        },
        {
          "title": "The Gemara's Resolution: Kesuvah Must Exceed the Injury Amount to Deter Divorce; Only Base Kesuvah De-Oraita Is Protected",
          "display_title": "Resolution: Kesuvah Base",
          "timestamp": "50:03"
        }
      ]
    },
    {
      "title": "Braisa on Selling Kesuvah to Third Parties vs. Back to Husband; Ketubas Benin Dichrin",
      "display_title": "Braisa: Sale & Benin",
      "timestamp": "53:30",
      "micro_segments": [
        {
          "title": "Principle: Woman Can Sell Kesuvah to Third Party Without Losing Ketubas Benin Dichrin",
          "display_title": "Third Party Sale",
          "timestamp": "53:30"
        },
        {
          "title": "Reasoning: Sale to Third Party Forced by Economic Need; Does Not Forfeit Rights Unrelated to That Sale",
          "display_title": "Economic Duress Logic",
          "timestamp": "54:34"
        },
        {
          "title": "Application to Husband: Woman Selling Kesuvah Back to Husband Also Does Not Lose Ketubas Benin Dichrin",
          "display_title": "Husband Sale Parallel",
          "timestamp": "56:45"
        },
        {
          "title": "Conclusion: Only in Cases Where Kesuvah Exceeds Oraita Amount Is Deduction Possible; Otherwise Benin Dichrin Remains",
          "display_title": "Benin Dichrin Protected",
          "timestamp": "57:39"
        }
      ]
    }
  ],
