{
  "masechta": "Eruvin",
  "daf": 84,
  "amud": "a",
  "macro_segments": [
    {
      "title": "Introduction to the Debate of Rav and Shmuel on Competing Access to Shared Spaces",
      "display_title": "Rav vs. Shmuel",
      "timestamp": "00:00",
      "micro_segments": [
        {
          "title": "Opening: The Framework of the Day's Discussion—Equal Easy Access, Equal Difficult Access, and Mixed Difficulty",
          "display_title": "Framework",
          "timestamp": "00:00"
        },
        {
          "title": "Shmuel's Position: Preference for Downward Access (Shilshul) Over Upward Access (Zrika)",
          "display_title": "Shmuel's Preference",
          "timestamp": "00:54"
        },
        {
          "title": "Rav's Position: Equal Competing Status When Access is Equally Difficult in Different Directions",
          "display_title": "Rav's Equal Status",
          "timestamp": "01:28"
        }
      ]
    },
    {
      "title": "Analysis of the Mishna's Mound Case: Reconciling Rav's Position with the Mishna's Attribution to the Mirpeset",
      "display_title": "Mound Case Analysis",
      "timestamp": "02:02",
      "micro_segments": [
        {
          "title": "The Gemara's Initial Question: How Does the Mishna Give the Mound to the Mirpeset if Access is Equally Difficult?",
          "display_title": "Initial Question",
          "timestamp": "02:02"
        },
        {
          "title": "Rav's Answer: The Mound is Close to the Mirpeset (Less Than Ten Tefachim), Making Access Easy for Them",
          "display_title": "Rav's Answer",
          "timestamp": "03:12"
        },
        {
          "title": "Resolving the Seifa: When the Mound is Less Than Ten, Both Mirpeset and Chatzer Have Easy Access, Hence Forbidden to Both",
          "display_title": "Seifa Resolution",
          "timestamp": "04:00"
        },
        {
          "title": "The Mupleget Case: When the Mound is Far (More Than Four Tefachim) from the Mirpeset, it Always Belongs to the Chatzer",
          "display_title": "Mupleget Distance",
          "timestamp": "06:09"
        }
      ]
    },
    {
      "title": "The Well Case and Its Challenge to Rav's Position on Competing Directions of Access",
      "display_title": "Well Case",
      "timestamp": "10:03",
      "micro_segments": [
        {
          "title": "Introduction to the Well Scenario: A Mound Around a Well Creates Ambiguity About Which Group Owns It",
          "display_title": "Well Introduction",
          "timestamp": "10:03"
        },
        {
          "title": "The Gemara's Dilemma: If Only the Top of the Mound Matters, Why Not Apply Rav's Principle to the Well's Actual Use?",
          "display_title": "Gemara Dilemma",
          "timestamp": "11:07"
        },
        {
          "title": "Rav Huna's Resolution: Mirpeset Refers to Those on the Balcony Itself, Not People Way Up in the Aliyah",
          "display_title": "Rav Huna's Answer",
          "timestamp": "16:47"
        },
        {
          "title": "The Case of a Well Filled with Water: Allowing Easy Access Within Ten Tefachim of the Top",
          "display_title": "Filled Well",
          "timestamp": "17:40"
        },
        {
          "title": "Abaye's Alternative: A Well Filled with Fruit (Tevel) Functions Like a Mound, Making the Top Usable",
          "display_title": "Fruit-Filled Well",
          "timestamp": "19:05"
        }
      ]
    },
    {
      "title": "The Airspace Case: Dividing Vertical Space Between Two Domains by the Ten-Tefach Boundary",
      "display_title": "Airspace Division",
      "timestamp": "22:27",
      "micro_segments": [
        {
          "title": "Setting Up the Airspace Problem: Two Domains (Chatzer Below and Aliyah Above) Separated by Vertical Distance",
          "display_title": "Airspace Setup",
          "timestamp": "22:27"
        },
        {
          "title": "The Protrusion Case (Ziz): Objects Below Ten Belong to Chatzer, Above Ten to Aliyah; Anything In Between is Forbidden",
          "display_title": "Ziz Protrusion",
          "timestamp": "24:09"
        },
        {
          "title": "Rav Nachman's Clarification: The Wall is Exactly 19 Tefachim, Leaving No Gap Between the Lower Ten and Upper Nine",
          "display_title": "Rav Nachman's Wall",
          "timestamp": "25:01"
        }
      ]
    },
    {
      "title": "The Two Gazuztraot (Ledges) Case: Competing Ledges Above the Sea and the Role of Proximity and Height",
      "display_title": "Two Gazuztraot",
      "timestamp": "29:00",
      "micro_segments": [
        {
          "title": "Introduction to Gazuztraot: Two Ledges Extending from Houses Over a Body of Water",
          "display_title": "Gazuztraot Intro",
          "timestamp": "29:00"
        },
        {
          "title": "The Basic Case: One Ledge Has a Mechitza (Partition), the Other Does Not; Both Are Forbidden Without an Eruv",
          "display_title": "Ledges & Partition",
          "timestamp": "30:46"
        },
        {
          "title": "Rava bar Avin's Clarification: The Case Assumes Practical Access via Walking Over, Even Within Four Tefachim",
          "display_title": "Rava bar Avin",
          "timestamp": "34:26"
        },
        {
          "title": "Abaye's Teaching: Formal Distance Boundaries (Within Ten) Override Practical Difficulty in Determining Shared Ownership",
          "display_title": "Abaye's Formal Rules",
          "timestamp": "35:15"
        }
      ]
    },
    {
      "title": "The Roof Case (Gag Samuch L'Reshut Harabim): Formal Rules Versus Practical Access in Mixed Domains",
      "display_title": "Roof Case",
      "timestamp": "40:32",
      "micro_segments": [
        {
          "title": "The Scenario: A Roof Near Public Domain (Reshut Harabim), Accessible from a Private Courtyard (Chatzer)",
          "display_title": "Roof Scenario",
          "timestamp": "40:32"
        },
        {
          "title": "Rav Nachman's Rule: A Fixed Ladder Makes the Roof Permissible; a Temporary Ladder Does Not, Because Without It Formal Boundaries Apply",
          "display_title": "Fixed vs. Temporary",
          "timestamp": "40:48"
        },
        {
          "title": "The Principle Illustrated: Even With a Temporary Ladder (Easier Access), We Apply Formal Rules (Within Ten), Not Practical Assessment",
          "display_title": "Formal vs. Practical",
          "timestamp": "43:12"
        },
        {
          "title": "Rav Papa's Objection: How Do We Know It's Not Also Easy for Reshut Harabim People to Place Items on the Roof?",
          "display_title": "Rav Papa's Objection",
          "timestamp": "45:05"
        }
      ]
    },
    {
      "title": "Conclusion: The Gemara's Commitment to Formal Legal Rules Over Practical Case-by-Case Assessment",
      "display_title": "Formal vs. Practical",
      "timestamp": "45:51",
      "micro_segments": [
        {
          "title": "The Underlying Principle: The Gemara Prefers Objective, Precise Legal Boundaries (Ten Tefachim) to Subjective Practical Judgments",
          "display_title": "Principle",
          "timestamp": "45:51"
        },
        {
          "title": "The Irony and Complexity: Strict Formal Rules Create Complications But Also Provide Consistency and Predictability",
          "display_title": "Irony",
          "timestamp": "46:25"
        }
      ]
    }
  ],
