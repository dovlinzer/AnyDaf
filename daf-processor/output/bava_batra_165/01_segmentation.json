      "micro_segments": [
        {
          "title": "Rabban Shimon ben Gamliel: All procedures follow the custom of the place",
          "display_title": "Rabban Shimon's Rule",
          "timestamp": "14:04"
        },
        {
          "title": "Gemara's question: Does the Tanna Kamma accept minhag hamedina?",
          "display_title": "Tanna Kamma's Position",
          "timestamp": "14:17"
        },
        {
          "title": "Rav Ashi's construction: When both mekushar and pashut are viable options in the same place",
          "display_title": "Rav Ashi's Construction",
          "timestamp": "15:56"
        },
        {
          "title": "Kfeida vs. Mar'eh Makom: Is an instruction insistent or merely suggestive?",
          "display_title": "Kfeida vs. Mar'eh Makom",
          "timestamp": "16:28"
        },
        {
          "title": "Three sages who hold mar'eh makom: Rabban Shimon ben Gamliel, Rabbi Shimon, and Rabbi Elazar",
          "display_title": "Three Sages Agree",
          "timestamp": "20:58"
        }
      ]
    },
    {
      "title": "The Validity of a Shtar with One Witness and the Question of Combination",
      "display_title": "Shtar Be-Ed Echad",
      "timestamp": "23:25",
      "micro_segments": [
        {
          "title": "Why the Mishna needs to teach that pashut with one witness is invalid",
          "display_title": "Mishna's Necessity",
          "timestamp": "23:25"
        },
        {
          "title": "Abaye's position: One written witness and one oral witness do not combine",
          "display_title": "Abaye's Position",
          "timestamp": "24:53"
        },
        {
          "title": "Rashbam's interpretation: Abaye means no weight as a shtar, but still valid as testimony of one witness",
          "display_title": "Rashbam's Interpretation",
          "timestamp": "27:11"
        },
        {
          "title": "Amemar's position: One written and one oral witness do combine and create valid testimony",
          "display_title": "Amemar's Position",
          "timestamp": "28:45"
        }
      ]
    },
    {
      "title": "The Story of Rabbi Yirmiyah: Combination of Witnesses and Judges from Different Courts",
      "display_title": "Rabbi Yirmiyah Story",
      "timestamp": "32:08",
      "micro_segments": [
        {
          "title": "Background: Rabbi Yirmiyah kicked out of the beit midrash for asking boundary questions",
          "display_title": "Yirmiyah Expelled",
          "timestamp": "32:08"
        },
        {
          "title": "First question sent to Rabbi Yirmiyah: One witness in a written document, one oral—can they combine?",
          "display_title": "First Question",
          "timestamp": "33:42"
        },
        {
          "title": "Tanna Kamma vs. Rabbi Yehoshua ben Korcha: Whether witnesses testifying different events can combine",
          "display_title": "Tanna Kamma Debate",
          "timestamp": "34:02"
        },
        {
          "title": "Rabbi Yirmiyah's humble response: They should combine according to Rabbi Yehoshua ben Korcha",
          "display_title": "Yirmiyah's Response",
          "timestamp": "37:47"
        },
        {
          "title": "Second question: Two witnesses testifying in different courts—can courts combine their testimonies?",
          "display_title": "Second Question",
          "timestamp": "39:01"
        },
        {
          "title": "Tanna Kamma vs. Rabbi Natan: Whether witnesses must testify together or can testify at different times",
          "display_title": "Testimony Timing",
          "timestamp": "39:50"
        },
        {
          "title": "Rabbi Yirmiyah's response: Combination should occur; judges can confer across courts",
          "display_title": "Courts Combine",
          "timestamp": "40:36"
        },
        {
          "title": "Third question: Three judges validating a shtar, one dies—must they document his absence?",
          "display_title": "Third Question",
          "timestamp": "43:15"
        },
        {
          "title": "Rabbi Yirmiyah's response: They must write that one is no longer present",
          "display_title": "Acknowledging Absence",
          "timestamp": "44:29"
        },
        {
          "title": "Conclusion: Rabbi Yirmiyah is brought back into the beit midrash",
          "display_title": "Yirmiyah Restored",
          "timestamp": "44:44"
        }
      ]
    },
    {
      "title": "The Validity of a Shtar with One Witness and the Question of Combination (continued)",
      "display_title": "Shtar Be-Ed Echad (II)",
      "timestamp": "45:32",
      "micro_segments": [
        {
          "title": "Tosafot's limitation: The oral witness must testify to the handing over of the shtar (edei mesirah)",
          "display_title": "Tosafot's Limitation",
          "timestamp": "45:32"
        }
      ]
    },
    {
      "title": "Contradictions in the Shtar: Amount Discrepancies and the Minimalist Principle",
      "display_title": "Contradictions in Shtar",
      "timestamp": "49:35",
      "micro_segments": [
        {
          "title": "Minimalist reading: When amounts are stated in different equivalents, the smaller amount is collected",
          "display_title": "Minimalist Principle",
          "timestamp": "49:35"
        },
        {
          "title": "Erased amounts: When the amount is entirely erased, minimum is two (or smallest unit)",
          "display_title": "Erased Amount",
          "timestamp": "51:16"
        },
        {
          "title": "Yad ba'al hashtar al hatachtona: The bottom of the shtar takes precedence when there is clear contradiction",
          "display_title": "Bottom Takes Precedence",
          "timestamp": "53:00"
        },
        {
          "title": "Why write the top if bottom controls: The top serves as backup to correct erasures in the bottom",
          "display_title": "Backup Function",
          "timestamp": "54:00"
        },
        {
          "title": "Rabbinical teaching on silver vs. gold coins: Minimum units and what kinds of coins exist",
          "display_title": "Coin Types & Minimums",
          "timestamp": "54:37"
        }
      ]
    },
    {
      "title": "Currency Terminology in Shtarot: Silver, Gold, Dinars, and Interpretation by Material Type",
      "display_title": "Currency Terminology",
      "timestamp": "55:00",
      "micro_segments": [
        {
          "title": "Kesef (silver): Assumed to mean one silver dinar as minimum",
          "display_title": "Silver Default",
          "timestamp": "55:00"
        },
        {
          "title": "Kesef dinarim: Plural form indicates minimum of two silver dinars",
          "display_title": "Silver Dinars Plural",
          "timestamp": "55:05"
        },
        {
          "title": "Kesef bidinarim: Silver in the amount of dinarim implies gold dinarim as the unit",
          "display_title": "Silver in Gold Units",
          "timestamp": "55:20"
        },
        {
          "title": "Zahav (gold): Assumed to mean one gold dinar as minimum",
          "display_title": "Gold Default",
          "timestamp": "55:40"
        },
        {
          "title": "Rabbi Elazar's principle: Kesef and zahav refer to minted coins (matbe'a), not ingots or bars",
          "display_title": "Minted Coins",
          "timestamp": "55:54"
        },
        {
          "title": "Rav Pappa's geographic qualifier: In places where small silver denominations don't exist, interpret accordingly",
          "display_title": "Geographic Variation",
          "timestamp": "56:18"
        },
        {
          "title": "Zahav bidinarim: Gold in the amount of dinarim implies silver dinarim as the unit",
          "display_title": "Gold in Silver Units",
          "timestamp": "56:54"
        },
        {
          "title": "Gold pennies do not exist: A reductio argument against interpreting zahav as small coins",
          "display_title": "No Gold Pennies",
          "timestamp": "57:27"
        }
      ]
    }
