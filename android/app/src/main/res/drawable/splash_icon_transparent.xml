<?xml version="1.0" encoding="utf-8"?>
<!--
    Splash screen "icon" that is the same colour as the background (#1B3A8A).
    Android 12+ always renders the splash icon — making it a solid blue square
    that matches the background makes it completely invisible.
    The icon background colour is also set to #1B3A8A in themes.xml.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#1B3A8A"
        android:pathData="M0,0h108v108h-108z" />
</vector>
