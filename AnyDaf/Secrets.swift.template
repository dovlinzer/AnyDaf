// Secrets.swift.template
// Copy this file to Secrets.swift (same directory) and fill in your values.
// Secrets.swift is gitignored and must never be committed.
enum Secrets {
    /// Shared secret sent with every Claude API call.
    /// Must match the APP_SECRET value set in Supabase:
    ///   supabase secrets set APP_SECRET=your-value-here
    static let appSecret = "YOUR_APP_SECRET_HERE"

    /// Supabase anon (public) key — read-only, safe to embed in the app.
    /// Found in: Supabase dashboard → Settings → API → anon / public key
    static let supabaseAnonKey = "YOUR_SUPABASE_ANON_KEY_HERE"
}
