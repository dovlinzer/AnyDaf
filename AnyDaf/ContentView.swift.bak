import SwiftUI

struct ContentView: View {
    @StateObject private var feedManager = FeedManager()
    @StateObject private var audioPlayer = AudioPlayer()

    private let pageManager = TalmudPageManager.shared

    @State private var selectedTractateIndex = 0
    @State private var selectedDaf: Int = 2

    var tractate: Tractate { allTractates[selectedTractateIndex] }

    var currentAudioURL: URL? {
        feedManager.audioURL(tractate: tractate.name, daf: selectedDaf)
    }

    var body: some View {
        NavigationStack {
            GeometryReader { proxy in
                VStack(spacing: 0) {

                    // ── Controls strip: top 1/3 of available height ────────
                    VStack(spacing: 0) {
                        HStack(alignment: .center, spacing: 0) {

                            // Tractate picker
                            VStack(spacing: 2) {
                                Text("Tractate")
                                    .font(.caption2)
                                    .foregroundStyle(.secondary)
                                Picker("Tractate", selection: $selectedTractateIndex) {
                                    ForEach(allTractates.indices, id: \.self) { i in
                                        Text(allTractates[i].name).tag(i)
                                    }
                                }
                                .pickerStyle(.wheel)
                                .frame(maxWidth: .infinity)
                                .frame(height: 100)
                                .clipped()
                            }

                            // Daf picker
                            VStack(spacing: 2) {
                                Text("Daf")
                                    .font(.caption2)
                                    .foregroundStyle(.secondary)
                                Picker("Daf", selection: $selectedDaf) {
                                    ForEach(tractate.dafRange, id: \.self) { daf in
                                        Text("\(daf)").tag(daf)
                                    }
                                }
                                .pickerStyle(.wheel)
                                .frame(width: 70)
                                .frame(height: 100)
                                .clipped()
                            }

                            // Play / Pause button
                            VStack(spacing: 4) {
                                if audioPlayer.isBuffering || feedManager.isLoading {
                                    ProgressView()
                                        .frame(width: 44, height: 44)
                                } else {
                                    Button {
                                        if audioPlayer.isPlaying || audioPlayer.currentTime > 0 {
                                            audioPlayer.togglePlayPause()
                                        } else if let url = currentAudioURL {
                                            audioPlayer.play(url: url)
                                        }
                                    } label: {
                                        Image(systemName: audioPlayer.isPlaying
                                              ? "pause.circle.fill"
                                              : "play.circle.fill")
                                            .font(.system(size: 44))
                                            .foregroundStyle(canPlay
                                                             ? Color.accentColor
                                                             : Color.secondary.opacity(0.3))
                                    }
                                    .disabled(!canPlay)
                                }
                                Text(audioPlayer.isPlaying ? "Pause" : "Play")
                                    .font(.caption2)
                                    .foregroundStyle(.secondary)
                            }
                            .frame(width: 80)
                            .padding(.horizontal, 4)
                        }
                        .padding(.horizontal)
                        .onChange(of: selectedTractateIndex) { _, _ in
                            selectedDaf = tractate.startDaf
                            audioPlayer.stop()
                        }
                        .onChange(of: selectedDaf) { _, _ in
                            audioPlayer.stop()
                        }

                        // ── "No episode" notice ───────────────────────────
                        if !feedManager.isLoading && feedManager.hasIndex && currentAudioURL == nil {
                            Text("No episode found for this daf")
                                .font(.caption2)
                                .foregroundStyle(.secondary)
                                .padding(.vertical, 2)
                        }

                        // ── Progress bar (only while audio is active) ─────
                        if audioPlayer.duration > 0 {
                            VStack(spacing: 2) {
                                Slider(
                                    value: Binding(
                                        get: { audioPlayer.duration > 0
                                            ? audioPlayer.currentTime / audioPlayer.duration : 0 },
                                        set: { audioPlayer.seek(to: $0) }
                                    )
                                )
                                .padding(.horizontal)

                                HStack {
                                    Text(formatTime(audioPlayer.currentTime))
                                    Spacer()
                                    Text(formatTime(audioPlayer.duration))
                                }
                                .font(.caption.monospacedDigit())
                                .foregroundStyle(.secondary)
                                .padding(.horizontal)
                            }
                            .padding(.bottom, 4)
                        }
                    }
                    .frame(height: proxy.size.height / 3)
                    .clipped()

                    Divider()

                    // ── Daf page images: bottom 2/3 ───────────────────────
                    if pageManager.hasPages(for: tractate.name) {
                        DafPageView(
                            tractate: tractate.name,
                            daf: selectedDaf,
                            pageManager: pageManager
                        )
                        .frame(maxWidth: .infinity, maxHeight: .infinity)
                    } else {
                        Spacer()
                    }
                }
            }
            .navigationTitle("AnyDaf")
            .navigationBarTitleDisplayMode(.inline)
            .toolbar {
                ToolbarItem(placement: .topBarLeading) {
                    if feedManager.episodeCount > 0 {
                        Text("\(feedManager.episodeCount) episodes")
                            .font(.caption)
                            .foregroundStyle(.secondary)
                    }
                }
                ToolbarItem(placement: .topBarTrailing) {
                    Button {
                        Task { await feedManager.fetchAll() }
                    } label: {
                        Image(systemName: "arrow.clockwise")
                    }
                    .disabled(feedManager.isLoading)
                }
            }
        }
        .task {
            await feedManager.refreshIfNeeded()
        }
    }

    private var canPlay: Bool {
        currentAudioURL != nil && !feedManager.isLoading && !audioPlayer.isBuffering
    }

    private func formatTime(_ seconds: Double) -> String {
        guard seconds.isFinite, seconds >= 0 else { return "0:00" }
        let mins = Int(seconds) / 60
        let secs = Int(seconds) % 60
        return "\(mins):\(String(format: "%02d", secs))"
    }
}

// MARK: - Daf Page Viewer

struct DafPageView: View {
    let tractate: String
    let daf: Int
    let pageManager: TalmudPageManager

    @State private var selectedSide = 0  // 0 = amud aleph (a), 1 = amud bet (b)

    var body: some View {
        VStack(spacing: 0) {
            Picker("Amud", selection: $selectedSide) {
                Text("Amud א (a)").tag(0)
                Text("Amud ב (b)").tag(1)
            }
            .pickerStyle(.segmented)
            .padding(.horizontal, 12)
            .padding(.vertical, 6)

            let sideA = selectedSide == 0
            if let url = pageManager.imageURL(tractate: tractate, daf: daf, sideA: sideA) {
                ZoomableAsyncImage(url: url)
                    .frame(maxWidth: .infinity, maxHeight: .infinity)
            } else {
                Text("No image for daf \(daf)\(sideA ? "a" : "b")")
                    .font(.caption)
                    .foregroundStyle(.secondary)
                    .frame(maxWidth: .infinity, maxHeight: .infinity)
            }
        }
    }
}

#Preview {
    ContentView()
}
